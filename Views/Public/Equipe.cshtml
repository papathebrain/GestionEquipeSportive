    .mini-pos-more {
        font-size: .5rem; font-weight: 800; color: rgba(255,255,255,.6);
        background: rgba(255,255,255,.18); border-radius: 3px; padding: 1px 4px;
        white-space: nowrap;
    }
    .mini-trading-card .mini-bande {
        position:absolute; bottom:0; left:0; right:0; height:3px;
        background:var(--couleur-secondaire);
    }
    /* ── Galerie match : animation d'apparition ── */
    @@keyframes galerieItemIn {
        from { opacity: 0; transform: translateY(18px) scale(.97); }
        to   { opacity: 1; transform: translateY(0)    scale(1); }
    }
    .galerie-item-anim {
        opacity: 0;
        animation: galerieItemIn .38s cubic-bezier(.22,.68,0,1.2) forwards;
    }
    .galerie-img {
        width: 100%; height: 160px; object-fit: cover; cursor: pointer;
        border-radius: .375rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.15);
        transition: transform .2s, box-shadow .2s;
        display: block;
    }
    .galerie-img:hover { transform: scale(1.04); box-shadow: 0 6px 20px rgba(0,0,0,.28); }
    /* ── Mini cartes staff (style identique aux joueurs) ────────────────── */
    .mini-staff-card {
        border-radius: 10px; overflow: hidden; cursor: pointer;
        transition: transform .15s, box-shadow .15s;
        box-shadow: 0 4px 12px rgba(0,0,0,.2);
        position: relative; aspect-ratio: 2/3;
    }
    .mini-staff-card:hover { transform: translateY(-4px) scale(1.04); box-shadow: 0 10px 28px rgba(0,0,0,.35); }
    .mini-staff-card .mini-photo { width:100%; height:100%; object-fit:cover; display:block; }
    .mini-staff-card .mini-no-photo {
        width:100%; height:100%; background:var(--couleur-primaire);
        display:flex; align-items:center; justify-content:center;
        font-size:3rem; color:rgba(255,255,255,.2);
    }
    .mini-staff-card .mini-gradient {
        position:absolute; bottom:0; left:0; right:0; height:50%;
        background:linear-gradient(to top,rgba(0,0,0,.92) 0%,rgba(0,0,0,.5) 55%,transparent 100%);
    }
    .mini-staff-card .mini-info {
        position:absolute; bottom:0; left:0; right:0;
        padding:6px 8px 4px;
        background: linear-gradient(to top, var(--couleur-primaire) 60%, transparent 100%);
    }
    .mini-staff-card .mini-nom {
        font-size:.72rem; font-weight:800; color:#fff;
        line-height:1.2; text-transform:uppercase; letter-spacing:.02em;
        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .mini-staff-card .mini-pos {
        font-size:.58rem; color:rgba(255,255,255,.72); margin-top:1px;
        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .mini-staff-card .mini-bande {
        position:absolute; bottom:0; left:0; right:0; height:3px;
        background:var(--couleur-secondaire);
    }
    /* ── Modal staff MUT ─────────────────────────────────────────────────── */
    #modalStaff .modal-content { background: transparent !important; border: none !important; box-shadow: none !important; }
    #modalStaff .modal-dialog { max-width: 320px; width: 100%; margin-left: auto; margin-right: auto; }
    #staffMutCard { position: relative !important; inset: auto !important; width: 300px; height: auto !important; }
    .staff-card-wrapper { display: inline-block; }
</style>

@* ── Modal joueur (carte MUT) ─────────────────────────────────────────────── *@
