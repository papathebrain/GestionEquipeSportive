    .mini-trading-card:hover { transform: translateY(-4px) scale(1.04); box-shadow: 0 10px 28px rgba(0,0,0,.35); }
    .mini-trading-card .mini-photo { width:100%; height:100%; object-fit:cover; display:block; }
    .mini-trading-card .mini-no-photo {
        width:100%; height:100%; background:var(--couleur-primaire);
        display:flex; align-items:center; justify-content:center;
        font-size:2rem; font-weight:900; color:rgba(255,255,255,.25);
        font-family:Impact,Arial Black,sans-serif;
    }
    .mini-trading-card .mini-gradient {
        position:absolute; bottom:0; left:0; right:0; height:55%;
        background:linear-gradient(to top,rgba(0,0,0,.88) 0%,rgba(0,0,0,.3) 60%,transparent 100%);
    }
    .mini-trading-card .mini-numero {
        position:absolute; top:6px; left:8px;
        font-size:1.1rem; font-weight:900; color:#fff;
        text-shadow:0 1px 4px rgba(0,0,0,.8);
        font-family:Impact,Arial Black,sans-serif;
    }
    .mini-trading-card .mini-badge {
        position:absolute; top:6px; right:6px;
    }
    .mini-trading-card .mini-info {
        position:absolute; bottom:0; left:0; right:0;
        padding:4px 7px 6px; text-align:center;
    }
    .mini-trading-card .mini-nom {
        font-size:.72rem; font-weight:800; color:#fff;
