@{
    // Sérialiser les événements du calendrier pour la vue grille JS
    var calEventsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Matchs.Select(m => new {
            date = m.DateMatch.ToString("yyyy-MM-dd"),
            titre = (m.EstDomicile ? "vs " : "\u0040 ") + m.Adversaire,
            sous = m.AResultat ? $"{m.ScoreEquipe}\u2013{m.ScoreAdversaire}" : (m.EstDomicile ? "Domicile" : "Extérieur"),
            lieu = m.Lieu ?? "",
            heure = m.HeureDebutMatch ?? "",
            heureFin = "",
            heureArrivee = m.HeureArriveeVestiaire ?? "",
            heureDepart = m.HeureDepartAutobus ?? "",
            icon = "bi-flag-fill",
            color = m.AResultat ? (m.Resultat == "V" ? "#198754" : m.Resultat == "D" ? "#dc3545" : "#6c757d") : "#6c757d"
        }).Concat(Model.Evenements.Select(ev => new {
            date = ev.DateDebut.ToString("yyyy-MM-dd"),
            titre = ev.Titre,
            sous = ev.Type switch {
                TypeEvenement.Pratique => "Pratique",
                TypeEvenement.ReunionParents => "Réunion de parents",
                TypeEvenement.Tournoi => "Tournoi",
                TypeEvenement.Jamboree => "Jamborée",
                TypeEvenement.Evaluation => "Évaluation / Tryout",
                TypeEvenement.ActiviteEquipe => "Activité d'équipe",
                _ => "Autre"
            },
            lieu = ev.Lieu ?? "",
            heure = ev.DateDebut.ToString("HH:mm"),
            heureFin = ev.DateFin.HasValue ? ev.DateFin.Value.ToString("HH:mm") : "",
            heureArrivee = "",
            heureDepart = "",
            icon = ev.Type switch {
                TypeEvenement.Pratique => "bi-stopwatch-fill",
                TypeEvenement.ReunionParents => "bi-people-fill",
                TypeEvenement.Tournoi => "bi-trophy-fill",
                TypeEvenement.Jamboree => "bi-flag-fill",
                TypeEvenement.Evaluation => "bi-clipboard-check-fill",
                TypeEvenement.ActiviteEquipe => "bi-star-fill",
                _ => "bi-calendar-event"
            },
            color = ev.Type switch {
                TypeEvenement.Pratique => "#0d6efd",
                TypeEvenement.ReunionParents => "#6f42c1",
                TypeEvenement.Tournoi => "#ffc107",
                TypeEvenement.Jamboree => "#20c997",
                TypeEvenement.Evaluation => "#fd7e14",
                TypeEvenement.ActiviteEquipe => "#198754",
                _ => "#6c757d"
            }
        }))
    );
}
<script id="cal-events-json" type="application/json">@Html.Raw(calEventsJson)</script>

@* ── Styles carte de trading ──────────────────────────────────────────────── *@
<style>
    /* ── Carte MUT joueur ───────────────────────────────────────────────────── */
    #modalJoueur .modal-content { background: transparent !important; border: none !important; box-shadow: none !important; }
    #modalJoueur .modal-dialog { max-width: 320px; width: 100%; margin-left: auto; margin-right: auto; }

    /* ── Flip wrapper ── */
    .mut-flip-scene {
        width: 300px; height: 470px;
        perspective: 1200px;
    }
    .mut-flip-inner {
        width: 100%; height: 100%; position: relative;
        transform-style: preserve-3d;
        transition: transform 0.65s cubic-bezier(.4,.2,.2,1);
    }
    .mut-flip-inner.flipped { transform: rotateY(180deg); }
    /* Le verso est un flex column qui remplit la hauteur */
    .mut-card-back { overflow: hidden; }

    .mut-card {
        position: absolute; inset: 0;
        width: 300px;
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(145deg, var(--couleur-primaire), color-mix(in srgb, var(--couleur-primaire) 60%, #000));
        box-shadow:
            0 0 20px color-mix(in srgb, var(--couleur-secondaire) 60%, transparent),
            0 0 60px color-mix(in srgb, var(--couleur-secondaire) 25%, transparent),
            inset 0 0 20px rgba(255,255,255,.05);
        color: #fff;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
    }
    /* Verso */
    .mut-card-back {
        transform: rotateY(180deg);
        display: flex; flex-direction: column;
        background: linear-gradient(160deg, color-mix(in srgb, var(--couleur-primaire) 85%, #000), color-mix(in srgb, var(--couleur-primaire) 50%, #000));
    }
    /* Bouton flip */
    .mut-flip-btn {
        position: absolute; bottom: 9px; right: 12px;
        width: 36px; height: 36px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,.5);
        background: rgba(0,0,0,.35); color: #fff;
        font-size: 1rem; cursor: pointer; z-index: 10;
        display: flex; align-items: center; justify-content: center;
        transition: background .2s, transform .15s;
        backdrop-filter: blur(4px);
    }
    .mut-flip-btn:hover { background: rgba(0,0,0,.6); transform: scale(1.1) rotate(20deg); }
    /* Verso — en-tête */
    .mut-back-header {
        padding: 20px 18px 14px; text-align: center; flex-shrink: 0;
        background: rgba(0,0,0,.25); position: relative;
    }
    .mut-back-avatar {
        width: 72px; height: 72px; border-radius: 50%;
        object-fit: cover; border: 3px solid rgba(255,255,255,.3);
        display: block; margin: 0 auto 10px;
    }
    .mut-back-avatar-ph {
        width: 72px; height: 72px; border-radius: 50%;
        background: rgba(255,255,255,.12);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 10px; font-size: 1.8rem;
    }
    .mut-back-nom {
        font-size: 1rem; font-weight: 800; line-height: 1.2;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .mut-back-badges {
        display: flex; flex-wrap: wrap; gap: 4px;
        justify-content: center; margin-top: 6px;
    }
    /* Verso — corps scrollable */
    .mut-back-body {
        flex: 1; overflow-y: auto; padding: 14px 18px 10px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,.2) transparent;
    }
    .mut-back-body::-webkit-scrollbar { width: 4px; }
    .mut-back-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,.2); border-radius: 2px; }
    .mut-back-desc {
        font-size: .82rem; line-height: 1.7;
        color: rgba(255,255,255,.85); margin-top: 4px;
    }
    .mut-back-stats-table {
        width: 100%; font-size: .78rem;
        border-collapse: collapse; margin-bottom: 8px;
        display:none;
    }
    .mut-back-stats-table td { padding: 3px 0; }
    .mut-back-stats-table td:first-child { color: rgba(255,255,255,.55); padding-right: 12px; }
    .mut-back-stats-table td:last-child { font-weight: 700; text-align: right; color: var(--couleur-secondaire); }
    /* Numéro haut gauche — masqué */
    .mut-rating { display: none; }
    /* Logo école en haut à droite */
    .mut-logo {
        position: absolute; top: 10px; right: 12px;
        width: 44px; height: 44px; object-fit: contain;
        filter: drop-shadow(0 2px 6px rgba(0,0,0,.5));
        z-index: 4;
    }
    .mut-logo-placeholder {
        position: absolute; top: 10px; right: 12px;
        width: 44px; height: 44px; border-radius: 50%;
        background: rgba(255,255,255,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: rgba(255,255,255,.5);
        z-index: 4;
    }
    /* Zone photo */
    .mut-image-container {
        position: relative; height: 210px; overflow: hidden;
    }
    .mut-image-container img {
        width: 100%; height: 100%; object-fit: cover;
        display: none;
    }
    .mut-image-container img.active { display: block; }
    .mut-no-photo {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        background: color-mix(in srgb, var(--couleur-primaire) 80%, #000);
        font-size: 5rem; font-weight: 900;
        color: rgba(255,255,255,.15);
        font-family: Impact, Arial Black, sans-serif;
    }
    /* Dégradé overlay bas de photo */
    .mut-overlay {
        position: absolute; bottom: 0; height: 80px; width: 100%;
        background: linear-gradient(to top, rgba(0,0,0,.85), transparent);
        pointer-events: none;
    }
    /* Boutons navigation photo */
    .mut-arrow {
        position: absolute; top: 50%; transform: translateY(-50%);
        background: rgba(0,0,0,.45); border: none; color: #fff;
        font-size: 1.2rem; width: 30px; height: 30px;
        border-radius: 50%; cursor: pointer; z-index: 5;
        display: flex; align-items: center; justify-content: center;
        transition: background .2s;
    }
    .mut-arrow:hover { background: rgba(0,0,0,.75); }
    .mut-arrow.left  { left: 8px; }
    .mut-arrow.right { right: 8px; }
    /* Infos bas de carte */
    .mut-info { padding: 16px 18px 18px; }
    .mut-name-row {
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
    }
    .mut-name {
        font-size: 1.25rem; font-weight: 800; line-height: 1.1;
        text-transform: uppercase; letter-spacing: .04em;
        flex: 1; min-width: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .mut-name-logo {
        flex-shrink: 0; width: 36px; height: 36px; object-fit: contain;
        filter: drop-shadow(0 1px 4px rgba(0,0,0,.4));
    }
    .mut-name-logo-placeholder {
        flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%;
        background: rgba(255,255,255,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; color: rgba(255,255,255,.5);
    }
    .mut-position {
        font-size: .8rem; opacity: .7; margin-top: 2px;
    }
    .mut-number {
        font-size: 2.4rem; font-weight: 900; margin-top: 6px;
        color: var(--couleur-secondaire);
        font-family: Impact, Arial Black, sans-serif;
        line-height: 1;
    }
    /* Stats bas */
    .mut-stats {
        margin-top: 12px;
        display: flex; justify-content: space-around;
        font-size: .7rem; text-transform: uppercase;
        letter-spacing: .06em;
        border-top: 1px solid rgba(255,255,255,.12);
        padding-top: 10px;
    }
    .mut-stat { text-align: center; }
    .mut-stat span {
        display: block;
        font-size: 1.1rem; font-weight: 800;
        color: var(--couleur-secondaire);
    }
    /* Description */
    .mut-desc {
        font-size: .75rem; opacity: .7; margin-top: 8px;
        line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
    }
    /* Bande couleur bas */
    .mut-bande { height: 5px; background: var(--couleur-secondaire); }

    /* Empêche double-tap zoom mobile */
    .mut-arrow { touch-action: manipulation; }
    /* Mini cartes de collection */
    .mini-trading-card {
        border-radius: 10px; overflow: hidden; cursor: pointer;
        transition: transform .15s, box-shadow .15s;
        box-shadow: 0 4px 12px rgba(0,0,0,.2);
        position: relative; aspect-ratio: 2/3;
    }
    .mini-trading-card:hover { transform: translateY(-4px) scale(1.04); box-shadow: 0 10px 28px rgba(0,0,0,.35); }
    .mini-trading-card .mini-photo { width:100%; height:100%; object-fit:cover; display:block; }
    .mini-trading-card .mini-no-photo {
        width:100%; height:100%; background:var(--couleur-primaire);
        display:flex; align-items:center; justify-content:center;
        font-size:2rem; font-weight:900; color:rgba(255,255,255,.25);
        font-family:Impact,Arial Black,sans-serif;
    }
    .mini-trading-card .mini-gradient {
        position:absolute; bottom:0; left:0; right:0; height:50%;
        background:linear-gradient(to top,rgba(0,0,0,.92) 0%,rgba(0,0,0,.5) 55%,transparent 100%);
    }
    .mini-trading-card .mini-numero {
        position:absolute; top:6px; left:8px;
        font-size:1.1rem; font-weight:900; color:#fff;
        text-shadow:0 1px 4px rgba(0,0,0,.8);
        font-family:Impact,Arial Black,sans-serif;
    }
    .mini-trading-card .mini-badge {
        position:absolute; top:6px; right:6px;
    }
    /* Bande bas style popup MUT */
    .mini-trading-card .mini-info {
        position:absolute; bottom:0; left:0; right:0;
        padding:6px 8px 4px;
        background: linear-gradient(to top, var(--couleur-primaire) 60%, transparent 100%);
    }
    .mini-trading-card .mini-nom {
        font-size:.72rem; font-weight:800; color:#fff;
        line-height:1.2; text-transform:uppercase; letter-spacing:.02em;
        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .mini-trading-card .mini-pos {
        font-size:.58rem; color:rgba(255,255,255,.72); margin-top:1px;
        white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .mini-trading-card .mini-bande {
        position:absolute; bottom:0; left:0; right:0; height:3px;
        background:var(--couleur-secondaire);
    }
    /* ── Galerie match : animation d'apparition ── */
    @@keyframes galerieItemIn {
        from { opacity: 0; transform: translateY(18px) scale(.97); }
        to   { opacity: 1; transform: translateY(0)    scale(1); }
    }
    .galerie-item-anim {
        opacity: 0;
        animation: galerieItemIn .38s cubic-bezier(.22,.68,0,1.2) forwards;
    }
    .galerie-img {
        width: 100%; height: 160px; object-fit: cover; cursor: pointer;
        border-radius: .375rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.15);
        transition: transform .2s, box-shadow .2s;
        display: block;
    }
    .galerie-img:hover { transform: scale(1.04); box-shadow: 0 6px 20px rgba(0,0,0,.28); }
    /* ── Cartes staff (page publique) ───────────────────────────────────── */
    .staff-pub-card {
        border-radius: 12px; overflow: hidden; cursor: pointer;
        background: #fff;
        box-shadow: 0 4px 14px rgba(0,0,0,.13);
        transition: transform .18s, box-shadow .18s;
        display: flex; flex-direction: column;
    }
    .staff-pub-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(0,0,0,.2); }
    .staff-pub-photo {
        width: 100%; aspect-ratio: 1/1; overflow: hidden;
        background: var(--couleur-primaire);
        display: flex; align-items: center; justify-content: center;
    }
    .staff-pub-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .staff-pub-nophoto { font-size: 3.5rem; color: rgba(255,255,255,.3); }
    .staff-pub-info { padding: 10px 12px 8px; flex: 1; }
    .staff-pub-nom {
        font-weight: 700; font-size: .9rem; color: #212529;
        line-height: 1.2; margin-bottom: 4px;
    }
    .staff-pub-titre {
        display: inline-block;
        font-size: .68rem; font-weight: 600; color: #fff;
        background: var(--couleur-secondaire);
        padding: 2px 7px; border-radius: 20px;
        margin-bottom: 3px;
    }
    .staff-pub-respo { font-size: .72rem; color: #6c757d; margin-top: 2px; }
    .staff-pub-bande { height: 5px; background: var(--couleur-primaire); flex-shrink: 0; }
</style>

@* ── Modal joueur (carte MUT) ─────────────────────────────────────────────── *@
<div class="modal fade" id="modalJoueur" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-transparent border-0 shadow-none">
            <div class="modal-body p-0 d-flex flex-column align-items-center">
                <!-- Bouton fermer -->
                <div class="d-flex justify-content-end w-100 mb-2 px-1" style="max-width:310px;">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"
                            style="background-color:rgba(0,0,0,.5);border-radius:50%;padding:8px;opacity:1;"></button>
                </div>
                <!-- Flip scene -->
                <div class="mut-flip-scene">
                    <div class="mut-flip-inner" id="mutFlipInner">

                        <!-- ── RECTO ── -->
                        <div class="mut-card">
                            <div class="mut-rating" id="mutRating"></div>
                            <div id="mutLogoWrap"></div>
                            <div class="mut-image-container" id="mutImageContainer">
                                <div class="mut-overlay"></div>
                                <button class="mut-arrow left" id="mutPrev" style="display:none;" onclick="mutNavPhoto(-1)">&#8249;</button>
                                <button class="mut-arrow right" id="mutNext" style="display:none;" onclick="mutNavPhoto(1)">&#8250;</button>
                            </div>
                            <div class="mut-info">
                                <div class="mut-name-row">
                                    <div class="mut-name" id="mutName"></div>
                                    <div id="mutNameLogo"></div>
                                </div>
                                <div class="mut-position" id="mutPosition"></div>
                                <div class="mut-number" id="mutNumber"></div>
                                <div class="mut-stats" id="mutStats"></div>
                            </div>
                            <div class="mut-bande"></div>
                            <!-- Bouton flip verso -->
                            <button class="mut-flip-btn" id="mutBtnFlip" title="Voir les détails">
                                <i class="bi bi-arrow-repeat"></i>
                            </button>
                        </div>

                        <!-- ── VERSO ── -->
                        <div class="mut-card mut-card-back">
                            <div class="mut-back-header">
                                <div id="mutBackAvatar"></div>
                                <div class="mut-back-nom" id="mutBackNom"></div>
                                <div class="mut-back-badges" id="mutBackBadges"></div>
                            </div>
                            <div class="mut-back-body" id="mutBackBody">
                                <table class="mut-back-stats-table" id="mutBackStats"></table>
                                <div id="mutBackDescWrap" style="display:none;">
                                    <hr style="border-color:rgba(255,255,255,.15);margin:8px 0;">
                                    <p class="mut-back-desc" id="mutBackDesc"></p>
                                </div>
                            </div>
                            <div class="mut-bande"></div>
                            <!-- Bouton flip recto -->
                            <button class="mut-flip-btn" id="mutBtnUnflip" title="Voir la photo">
                                <i class="bi bi-arrow-repeat" style="transform:scaleX(-1);display:inline-block;"></i>
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Modal entraineur ─────────────────────────────────────────────────────── *@
<div class="modal fade" id="modalStaff" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:340px;">
        <div class="modal-content bg-transparent border-0 shadow-none">
            <div class="modal-body p-0 d-flex flex-column align-items-center">
                <div class="d-flex justify-content-end w-100 mb-2 px-2">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"
                            style="background-color:rgba(0,0,0,.45);border-radius:50%;padding:8px;opacity:1;"></button>
                </div>
                <div class="trading-card-wrapper">
                    <div class="card-face card-front" style="border-radius:18px;overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.55);position:relative;width:100%;height:100%;">
                        <div id="staffPhotoTrack" style="position:absolute;inset:0;"></div>
                        <div style="position:absolute;bottom:0;left:0;right:0;height:58%;background:linear-gradient(to top,rgba(0,0,0,.92) 0%,rgba(0,0,0,.45) 55%,transparent 100%);z-index:2;border-radius:0 0 16px 16px;"></div>
                        <div id="staffFrontBadge" style="position:absolute;top:14px;right:14px;z-index:3;"></div>
                        <div style="position:absolute;bottom:0;left:0;right:0;height:6px;background-color:var(--couleur-secondaire);z-index:3;"></div>
                        <div style="position:absolute;bottom:20px;left:0;right:0;text-align:center;padding:0 14px;z-index:3;">
                            <div id="staffFrontNom" style="font-size:1.15rem;font-weight:900;color:#fff;text-shadow:0 2px 6px rgba(0,0,0,.9);letter-spacing:.03em;line-height:1.2;"></div>
                            <div id="staffFrontTitre" style="font-size:.8rem;color:rgba(255,255,255,.7);margin-top:3px;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Lightbox galerie ─────────────────────────────────────────────────────── *@
<div id="lightbox" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.92);align-items:center;justify-content:center;touch-action:pan-y;">
    <button id="lbClose" style="position:absolute;top:18px;right:22px;background:none;border:none;color:#fff;font-size:2rem;cursor:pointer;z-index:2;">&#x2715;</button>
    <button id="lbPrev" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.12);border:none;color:#fff;font-size:2.5rem;width:48px;height:64px;border-radius:8px;cursor:pointer;">&#8249;</button>
    <button id="lbNext" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.12);border:none;color:#fff;font-size:2.5rem;width:48px;height:64px;border-radius:8px;cursor:pointer;">&#8250;</button>
    <img id="lbImg" src="" alt="" style="max-width:92vw;max-height:88vh;border-radius:6px;object-fit:contain;user-select:none;display:block;" />
    <div id="lbCounter" style="position:absolute;bottom:18px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.65);font-size:.9rem;"></div>
</div>

@section Scripts {
<script>
    // ── Données JSON ──────────────────────────────────────────────────────────
    var galeriesData     = JSON.parse(document.getElementById('galeries-json').textContent);
    var matchTitres      = JSON.parse(document.getElementById('titres-json').textContent);
    var joueurPhotos     = JSON.parse(document.getElementById('joueur-photos-json').textContent);
    var statsJoueursData = JSON.parse(document.getElementById('stats-joueurs-json').textContent);
    var dernierMatchPhotosId = JSON.parse(document.getElementById('dernier-match-photos-id').textContent);
    var logoEcole  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Ecole.LogoPath ?? ""));
    var nomEquipe  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Equipe.Nom));

    // ── Galerie matchs ────────────────────────────────────────────────────────
    var matchActif = null;
    var galeriePhotosActuelles = [];

    function afficherGalerie(matchId, row) {
        var allMedia = galeriesData[matchId];
        if (!allMedia || allMedia.length === 0) return;
        document.querySelectorAll('.match-row-galerie').forEach(function(r) { r.classList.remove('table-active'); });
        if (row) row.classList.add('table-active');
        document.getElementById('galerieTitre').innerHTML = '<i class="bi bi-images me-2"></i>' + (matchTitres[matchId] || '');

        var photos = allMedia.filter(function(m) { return m.type !== 'video'; });
        var videos = allMedia.filter(function(m) { return m.type === 'video'; });

        // Garder seulement les photos pour le lightbox
        galeriePhotosActuelles = photos;

        var photoHtml = photos.map(function(p, i) {
            var delay = (i * 55) + 'ms';
            return '<div class="col-6 col-md-3 galerie-item-anim" style="animation-delay:' + delay + ';">'
                 + '<img src="' + p.chemin + '" alt="' + p.description + '" loading="lazy"'
                 + ' class="galerie-img galerie-photo" data-index="' + i + '" />'
                 + '</div>';
        }).join('');

        var videoHtml = '';
        if (videos.length > 0) {
            var baseDelay = photos.length * 55;
            videoHtml = '<div class="col-12 mt-2 galerie-item-anim" style="animation-delay:' + baseDelay + 'ms;">'
                + '<div class="small text-muted mb-2 fw-semibold">'
                + '<i class="bi bi-camera-video me-1"></i>Vidéos (' + videos.length + ')</div></div>'
                + videos.map(function(v, vi) {
                    var vDelay = (baseDelay + (vi + 1) * 55) + 'ms';
                    return '<div class="col-12 col-md-6 galerie-item-anim" style="animation-delay:' + vDelay + ';">'
                        + '<video src="' + v.chemin + '" controls preload="metadata"'
                        + ' class="w-100 rounded shadow-sm" style="max-height:280px;background:#000;">'
                        + '</video>'
                        + (v.description ? '<div class="small text-muted mt-1">' + v.description + '</div>' : '')
                        + '</div>';
                }).join('');
        }

        document.getElementById('galeriePhotos').innerHTML = photoHtml + videoHtml;
        var section = document.getElementById('galerieSection');
        section.style.display = '';
        matchActif = matchId;
    }

    function fermerGalerie() {
        // Pauser toutes les vidéos avant de fermer
        document.querySelectorAll('#galeriePhotos video').forEach(function(v) { v.pause(); });
        document.getElementById('galerieSection').style.display = 'none';
        document.querySelectorAll('.match-row-galerie').forEach(function(r) { r.classList.remove('table-active'); });
        matchActif = null;
    }

    // ── Lightbox ──────────────────────────────────────────────────────────────
    var lbIndex = 0;
    var lbPhotos = [];
    var lb = document.getElementById('lightbox');
    var lbImg = document.getElementById('lbImg');
    var lbCounter = document.getElementById('lbCounter');

    function ouvrirLightbox(photos, index) {
        lbPhotos = photos;
        lbIndex = index;
        lbImg.src = lbPhotos[lbIndex].chemin;
        lbCounter.textContent = (lbIndex + 1) + ' / ' + lbPhotos.length;
        lb.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function fermerLightbox() {
        lb.style.display = 'none';
        document.body.style.overflow = '';
    }
    function lbNaviguer(delta) {
        lbIndex = (lbIndex + delta + lbPhotos.length) % lbPhotos.length;
        lbImg.src = lbPhotos[lbIndex].chemin;
        lbCounter.textContent = (lbIndex + 1) + ' / ' + lbPhotos.length;
    }
    document.getElementById('lbClose').addEventListener('click', fermerLightbox);
    document.getElementById('lbPrev').addEventListener('click', function() { lbNaviguer(-1); });
    document.getElementById('lbNext').addEventListener('click', function() { lbNaviguer(1); });
    lb.addEventListener('click', function(e) { if (e.target === lb) fermerLightbox(); });
    document.addEventListener('keydown', function(e) {
        if (lb.style.display === 'none') return;
        if (e.key === 'Escape') fermerLightbox();
        if (e.key === 'ArrowLeft') lbNaviguer(-1);
        if (e.key === 'ArrowRight') lbNaviguer(1);
    });
    // Swipe tactile
    var lbTouchStartX = 0;
    lb.addEventListener('touchstart', function(e) { lbTouchStartX = e.changedTouches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - lbTouchStartX;
        if (Math.abs(dx) > 50) lbNaviguer(dx < 0 ? 1 : -1);
    }, { passive: true });

    // ── Carte MUT joueur ──────────────────────────────────────────────────────
    var mutPhotos = [];
    var mutPhotoIdx = 0;

    function mutRenderPhotos(logoSrc) {
        var container = document.getElementById('mutImageContainer');
        container.querySelectorAll('img.mut-photo-img').forEach(function(i){ i.remove(); });
        container.querySelectorAll('.mut-no-photo').forEach(function(d){ d.remove(); });
        var overlay = container.querySelector('.mut-overlay');

        if (!mutPhotos.length) {
            var ph = document.createElement('div');
            ph.className = 'mut-no-photo';
            if (logoSrc) {
                var logoImg = document.createElement('img');
                logoImg.src = logoSrc;
                logoImg.style.cssText = 'width:80px;height:80px;object-fit:contain;opacity:.75;filter:drop-shadow(0 4px 14px rgba(0,0,0,.5));';
                ph.appendChild(logoImg);
            }
            container.insertBefore(ph, overlay);
            document.getElementById('mutPrev').style.display = 'none';
            document.getElementById('mutNext').style.display = 'none';
            return;
        }

        mutPhotos.forEach(function(src, i) {
            var img = document.createElement('img');
            img.src = src;
            img.className = 'mut-photo-img' + (i === mutPhotoIdx ? ' active' : '');
            container.insertBefore(img, overlay);
        });
        var multi = mutPhotos.length > 1;
        document.getElementById('mutPrev').style.display = multi ? '' : 'none';
        document.getElementById('mutNext').style.display = multi ? '' : 'none';
    }

    function mutNavPhoto(delta) {
        var imgs = document.getElementById('mutImageContainer').querySelectorAll('img.mut-photo-img');
        if (!imgs.length) return;
        imgs[mutPhotoIdx].classList.remove('active');
        mutPhotoIdx = (mutPhotoIdx + delta + imgs.length) % imgs.length;
        imgs[mutPhotoIdx].classList.add('active');
    }

    function ouvrirJoueur(el) {
        var joueurId     = el.dataset.joueurId || '';
        var nom          = el.dataset.fullnom  || '';
        var numero       = el.dataset.numero   || '';
        var photo        = el.dataset.photo    || '';
        var position     = el.dataset.position || '';
        var posSpec      = el.dataset.positionSpecifique || '';
        var desc         = el.dataset.description || '';
        var consentement = el.dataset.consentement !== 'false';

        // Construire la liste de photos
        var extras = joueurPhotos[joueurId] || [];
        mutPhotos = [];
        mutPhotoIdx = 0;
        if (consentement) {
            if (photo) mutPhotos.push(photo);
            extras.forEach(function(p){ if (p.chemin) mutPhotos.push(p.chemin); });
        }

        // Reset flip → recto
        document.getElementById('mutFlipInner').classList.remove('flipped');

        // Rating interne
        document.getElementById('mutRating').textContent = numero;

        // Logo à droite du nom (recto)
        document.getElementById('mutLogoWrap').innerHTML = '';
        var nameLogo = document.getElementById('mutNameLogo');
        if (logoEcole) {
            nameLogo.innerHTML = '<img class="mut-name-logo" src="' + logoEcole + '" alt="">';
        } else {
            nameLogo.innerHTML = '<div class="mut-name-logo-placeholder"><i class="bi bi-shield-fill"></i></div>';
        }

        // Recto — nom, position, numéro
        document.getElementById('mutName').textContent     = nom;
        document.getElementById('mutPosition').textContent = [position, posSpec].filter(Boolean).join(' — ');
        document.getElementById('mutNumber').textContent   = numero ? '#' + numero : '';

        // Recto — stats
        var statsEl = document.getElementById('mutStats');
        var sj = statsJoueursData[joueurId];
        if (sj && sj.matchsJoues > 0) {
            var presences = sj.matchsJoues - sj.absences;
            statsEl.innerHTML =
                '<div class="mut-stat">Joués<span>' + sj.matchsJoues + '</span></div>'
              + '<div class="mut-stat">Présences<span>' + presences + '</span></div>'
              + '<div class="mut-stat">Absences<span>' + sj.absences + '</span></div>';
        } else {
            statsEl.innerHTML = '';
        }

        // Verso — avatar
        var avatarEl = document.getElementById('mutBackAvatar');
        if (consentement && (photo || mutPhotos.length)) {
            var avatarSrc = mutPhotos.length ? mutPhotos[0] : photo;
            avatarEl.innerHTML = '<img class="mut-back-avatar" src="' + avatarSrc + '" alt="">';
        } else if (logoEcole) {
            avatarEl.innerHTML = '<img class="mut-back-avatar" src="' + logoEcole + '" alt="" style="object-fit:contain;background:rgba(255,255,255,.1);padding:8px;">';
        } else {
            avatarEl.innerHTML = '<div class="mut-back-avatar-ph"><i class="bi bi-person-fill"></i></div>';
        }

        // Verso — nom + badges
        document.getElementById('mutBackNom').textContent = nom;
        var badgesEl = document.getElementById('mutBackBadges');
        badgesEl.innerHTML = '';
        if (position) badgesEl.innerHTML += '<span class="badge bg-light text-dark" style="font-size:.7rem;">' + position + '</span>';
        if (posSpec)  badgesEl.innerHTML += '<span class="badge" style="background:var(--couleur-secondaire);font-size:.7rem;">' + posSpec + '</span>';
        if (numero)   badgesEl.innerHTML += '<span class="badge bg-dark" style="font-size:.7rem;">#' + numero + '</span>';

        // Verso — stats tableau
        var backStats = document.getElementById('mutBackStats');
        backStats.innerHTML = '';
        if (sj && sj.matchsJoues > 0) {
            var pr = sj.matchsJoues - sj.absences;
            backStats.innerHTML =
                '<tr><td>Matchs joués</td><td>' + sj.matchsJoues + '</td></tr>'
              + '<tr><td>Présences</td><td>' + pr + '</td></tr>'
              + '<tr><td>Absences</td><td>' + sj.absences + '</td></tr>';
        }

        // Verso — description
        var descWrap = document.getElementById('mutBackDescWrap');
        if (desc) {
            document.getElementById('mutBackDesc').textContent = desc;
            descWrap.style.display = '';
        } else {
            descWrap.style.display = 'none';
        }

        // Photos recto (passe le logo si pas de consentement)
        mutRenderPhotos(consentement ? null : logoEcole);

        new bootstrap.Modal(document.getElementById('modalJoueur')).show();
    }

    // ── Flip card handlers ────────────────────────────────────────────────────
    document.getElementById('mutBtnFlip').addEventListener('click', function() {
        document.getElementById('mutFlipInner').classList.add('flipped');
    });
    document.getElementById('mutBtnUnflip').addEventListener('click', function() {
        document.getElementById('mutFlipInner').classList.remove('flipped');
    });

    // ── Carte entraineur ──────────────────────────────────────────────────────
    function ouvrirStaff(el) {
        var nom    = el.dataset.fullnom     || '';
        var photo  = el.dataset.photo       || '';
        var titre  = el.dataset.titre       || '';
        var respo  = el.dataset.responsable || '';

        var track = document.getElementById('staffPhotoTrack');
        if (photo) {
            track.innerHTML = '<img src="' + photo + '" style="width:100%;height:100%;object-fit:cover;display:block;" alt="">';
        } else {
            track.innerHTML = '<div style="width:100%;height:100%;background:var(--couleur-primaire);display:flex;align-items:center;justify-content:center;">'
                + '<i class="bi bi-person-fill" style="font-size:6rem;color:rgba(255,255,255,.18);"></i></div>';
        }
        document.getElementById('staffFrontNom').textContent   = nom;
        document.getElementById('staffFrontTitre').textContent = respo || titre;
        document.getElementById('staffFrontBadge').innerHTML   = titre
            ? '<span class="badge" style="background-color:var(--couleur-secondaire);font-size:.75rem;">' + titre + '</span>' : '';

        new bootstrap.Modal(document.getElementById('modalStaff')).show();
    }

    // ── Event delegation ──────────────────────────────────────────────────────
    document.addEventListener('click', function(e) {
        if (e.target.closest('#mutPrev') || e.target.closest('#mutNext')) return; // géré en inline
        var lbTrigger = e.target.closest('.galerie-photo');
        if (lbTrigger) { ouvrirLightbox(galeriePhotosActuelles, parseInt(lbTrigger.dataset.index, 10)); return; }
        var joueurCard = e.target.closest('.joueur-card');
        if (joueurCard) { ouvrirJoueur(joueurCard); return; }
        var staffCard = e.target.closest('.staff-card');
        if (staffCard) { ouvrirStaff(staffCard); return; }
        var matchRow = e.target.closest('.match-row-galerie');
        if (matchRow) afficherGalerie(matchRow.dataset.matchId, matchRow);
    });

    // ── Sélection auto galerie du dernier match avec photos ───────────────────
    function initAutoGalerie() {
        if (dernierMatchPhotosId !== null) {
            var row = document.querySelector('.match-row-galerie[data-match-id="' + dernierMatchPhotosId + '"]');
            afficherGalerie(String(dernierMatchPhotosId), row);
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAutoGalerie);
    } else {
        initAutoGalerie();
    }

    // ── Calendrier grille ────────────────────────────────────────────────────
    var calEvents = JSON.parse(document.getElementById('cal-events-json').textContent);
    var calMois   = new Date(); calMois.setDate(1); calMois.setHours(0,0,0,0);
    var moisFR    = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
    var joursAbreges = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];

    function renderCalGrille() {
        var y = calMois.getFullYear(), m = calMois.getMonth();
        document.getElementById('calMoisTitre').textContent = moisFR[m] + ' ' + y;

        var premierJour = new Date(y, m, 1).getDay(); // 0=dim
        var nbJours = new Date(y, m + 1, 0).getDate();
        var aujourd = new Date(); aujourd.setHours(0,0,0,0);

        // Events du mois indexés par jour
        var evtDuMois = {};
        var prefixe = y + '-' + String(m + 1).padStart(2, '0') + '-';
        calEvents.forEach(function(ev) {
            if (ev.date.startsWith(prefixe)) {
                var j = parseInt(ev.date.slice(8, 10), 10);
                if (!evtDuMois[j]) evtDuMois[j] = [];
                evtDuMois[j].push(ev);
            }
        });

        var html = '<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;">';
        // En-têtes jours
        joursAbreges.forEach(function(j) {
            html += '<div class="text-center small fw-bold py-1 text-muted">' + j + '</div>';
        });
        // Cases vides avant le 1er
        for (var i = 0; i < premierJour; i++) html += '<div></div>';
        // Jours du mois
        for (var d = 1; d <= nbJours; d++) {
            var dateD = new Date(y, m, d);
            var isToday = dateD.getTime() === aujourd.getTime();
            var evts = evtDuMois[d] || [];
            var cellBg = isToday ? 'background:rgba(var(--bs-primary-rgb),.07);outline:2px solid var(--couleur-primaire);' : 'background:#f8f9fa;';
            html += '<div style="min-height:130px;border-radius:8px;padding:6px;' + cellBg + '">';
            html += '<div class="fw-bold mb-1 ' + (isToday ? 'text-primary' : 'text-muted') + '" style="font-size:.8rem;">' + d + '</div>';
            evts.forEach(function(ev) {
                // Tooltip
                var tip = ev.titre;
                if (ev.lieu)         tip += '\nLieu : '             + ev.lieu;
                if (ev.heureArrivee) tip += '\nVestiaire : '        + ev.heureArrivee;
                if (ev.heureDepart)  tip += '\nAutobus : '          + ev.heureDepart;
                if (ev.heure)        tip += '\nD\u00e9but du match : ' + ev.heure + (ev.heureFin ? '\u2013' + ev.heureFin : '');

                html += '<div style="background:' + ev.color + '14;border-left:3px solid ' + ev.color + ';border-radius:4px;padding:4px 6px;margin-bottom:4px;font-size:.72rem;line-height:1.4;" title="' + tip.replace(/"/g, '&quot;') + '">'
                    + '<div class="fw-semibold">' + ev.titre.substring(0, 22) + (ev.titre.length > 22 ? '\u2026' : '') + '</div>';
                if (ev.lieu)         html += '<div class="text-muted"><i class="bi bi-geo-alt me-1"></i>' + ev.lieu + '</div>';
                if (ev.heureArrivee) html += '<div class="text-muted"><i class="bi bi-door-open me-1"></i>Vestiaire ' + ev.heureArrivee + '</div>';
                if (ev.heureDepart)  html += '<div class="text-muted"><i class="bi bi-bus-front me-1"></i>Autobus ' + ev.heureDepart + '</div>';
                if (ev.heure)        html += '<div class="text-muted"><i class="bi bi-play-circle me-1"></i>D\u00e9but ' + ev.heure + (ev.heureFin ? '\u2013' + ev.heureFin : '') + '</div>';
                html += '</div>';
            });
            html += '</div>';
        }
        html += '</div>';
        document.getElementById('calGrille').innerHTML = html;
    }

    document.getElementById('btnListe').addEventListener('click', function() {
        document.getElementById('calVueListe').style.display = '';
        document.getElementById('calVueGrille').style.display = 'none';
        this.classList.add('active');
        document.getElementById('btnGrille').classList.remove('active');
    });
    document.getElementById('btnGrille').addEventListener('click', function() {
        document.getElementById('calVueListe').style.display = 'none';
        document.getElementById('calVueGrille').style.display = '';
        this.classList.add('active');
        document.getElementById('btnListe').classList.remove('active');
        renderCalGrille();
    });
    document.getElementById('calPrevMois').addEventListener('click', function() {
        calMois.setMonth(calMois.getMonth() - 1);
        renderCalGrille();
    });
    document.getElementById('calNextMois').addEventListener('click', function() {
        calMois.setMonth(calMois.getMonth() + 1);
        renderCalGrille();
    });

    // Render initial du calendrier
    renderCalGrille();

    // ── Recherche joueurs ─────────────────────────────────────────────────────
    var rechercheEl = document.getElementById('rechercheJoueur');
    if (rechercheEl) rechercheEl.addEventListener('input', function() {
        var q = this.value.toLowerCase().trim(), total = 0;
        document.querySelectorAll('.position-group').forEach(function(grp) {
            var vis = 0;
            grp.querySelectorAll('.joueur-card').forEach(function(c) {
                var show = !q || c.dataset.nom.includes(q) || c.dataset.prenom.includes(q) || c.dataset.numero.includes(q);
                c.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            grp.style.display = vis > 0 ? '' : 'none';
            total += vis;
        });
        document.getElementById('aucunResultat').style.display = total === 0 ? '' : 'none';
    });
</script>
}
