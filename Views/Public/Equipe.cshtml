@model GestionEquipeSportive.ViewModels.PublicEquipeViewModel
@using GestionEquipeSportive.Models
@using System.Globalization
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = $"{Model.SportDisplay} — {Model.NiveauDisplay} {Model.Equipe.AnneeScolaire}";
    ViewBag.NomEcole = Model.Ecole.Nom;
    ViewBag.CouleurPrimaire = Model.Ecole.CouleurPrimaire;
    ViewBag.CouleurSecondaire = Model.Ecole.CouleurSecondaire;
    ViewBag.LogoPath = Model.Ecole.LogoPath;
    var frCA = new CultureInfo("fr-CA");
    var now = DateTime.Now;
}

@* ── Bannière ─────────────────────────────────────────────────────────────── *@
<div style="background-color:@Model.Ecole.CouleurPrimaire; color:#fff; position:relative; overflow:hidden; min-height:200px;">
    @if (Model.PhotoBanniere != null)
    {
        <div style="position:absolute;inset:0;background:url('@Model.PhotoBanniere.CheminFichier') center/cover no-repeat;opacity:.3;"></div>
    }

    <div class="container py-4" style="position:relative;z-index:1;">
        @if (Model.ProchainMatch != null)
        {
            var pm = Model.ProchainMatch;
            <div class="d-flex align-items-center gap-3 flex-wrap mb-2">
                <span class="rounded px-3 py-1 fw-bold text-uppercase small"
                      style="background-color:var(--couleur-secondaire);letter-spacing:.05em;">
                    Prochain match
                </span>
                <span class="fs-5 fw-semibold">
                    @pm.DateMatch.ToString("dddd d MMMM yyyy", frCA)
                    @if (!string.IsNullOrEmpty(pm.HeureDebutMatch))
                    { <span class="opacity-75 ms-1">@pm.HeureDebutMatch</span> }
                </span>
            </div>
            <div class="fs-4 fw-bold">@(pm.EstDomicile ? "vs" : "@") @pm.Adversaire</div>
            @if (!string.IsNullOrEmpty(pm.Lieu))
            { <div class="mt-1 opacity-75"><i class="bi bi-geo-alt me-1"></i>@pm.Lieu</div> }
            @if (!pm.EstDomicile && !string.IsNullOrEmpty(pm.HeureDepartAutobus))
            { <div class="mt-1 opacity-75 small"><i class="bi bi-bus-front me-1"></i>Autobus : @pm.HeureDepartAutobus</div> }
        }
        else if (Model.DernierMatchAvecResultat != null)
        {
            var dm = Model.DernierMatchAvecResultat;
            var resultCss = dm.Resultat switch { "V" => "#198754", "D" => "#dc3545", _ => "#6c757d" };
            var resultLabel = dm.Resultat switch { "V" => "Victoire", "D" => "Défaite", _ => "Nul" };
            <div class="d-flex align-items-center gap-3 flex-wrap mb-2">
                <span class="rounded px-3 py-1 fw-bold text-uppercase small"
                      style="background-color:@resultCss;letter-spacing:.05em;">@resultLabel</span>
                <span class="opacity-75 small">Dernier match · @dm.DateMatch.ToString("d MMMM yyyy", frCA)</span>
            </div>
            <div class="d-flex align-items-baseline gap-3">
                <span class="fw-bold" style="font-size:3.5rem;line-height:1;">@dm.ScoreEquipe</span>
                <span class="opacity-50 fs-4">–</span>
                <span class="fw-bold" style="font-size:3.5rem;line-height:1;">@dm.ScoreAdversaire</span>
                <span class="fs-4 ms-2">@(dm.EstDomicile ? "vs" : "@") @dm.Adversaire</span>
            </div>
        }
        else
        {
            <div class="fs-3 fw-bold">@Model.Equipe.Nom</div>
            <div class="opacity-75">@Model.SportDisplay — @Model.NiveauDisplay — @Model.Equipe.AnneeScolaire</div>
        }
    </div>
</div>

@* ── Stats ────────────────────────────────────────────────────────────────── *@
@if (Model.Stats.MatchsJoues > 0)
{
    <div style="background-color:@Model.Ecole.CouleurPrimaire;opacity:.9;">
        <div class="container">
            <div class="row g-0 text-white text-center">
                <div class="col-4 py-2 border-end border-white border-opacity-25">
                    <div class="fw-bold fs-4">@Model.Stats.Victoires</div>
                    <div class="small opacity-75">Victoires</div>
                </div>
                <div class="col-4 py-2 border-end border-white border-opacity-25">
                    <div class="fw-bold fs-4">@Model.Stats.Defaites</div>
                    <div class="small opacity-75">Défaites</div>
                </div>
                <div class="col-4 py-2">
                    <div class="fw-bold fs-4">@Model.Stats.Nuls</div>
                    <div class="small opacity-75">Nuls</div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Liens sociaux ────────────────────────────────────────────────────────── *@
@if (Model.Ecole.LiensSociaux.Any())
{
    <div style="background-color:@Model.Ecole.CouleurPrimaire;" class="border-top border-white border-opacity-10">
        <div class="container py-2 d-flex gap-3 flex-wrap justify-content-center">
            @foreach (var lien in Model.Ecole.LiensSociaux)
            {
                var lienIcon = lien.Type switch {
                    "Facebook"    => "bi-facebook",
                    "Instagram"   => "bi-instagram",
                    "X / Twitter" => "bi-twitter-x",
                    "YouTube"     => "bi-youtube",
                    "TikTok"      => "bi-tiktok",
                    _             => "bi-globe"
                };
                <a href="@lien.Url" target="_blank" rel="noopener noreferrer"
                   class="lien-social-pub d-flex align-items-center gap-1 small text-decoration-none text-white">
                    <i class="bi @lienIcon"></i>
                    @(string.IsNullOrEmpty(lien.Label) ? lien.Type : lien.Label)
                </a>
            }
        </div>
    </div>
}

@* ── Navigation sous-menus ───────────────────────────────────────────────── *@
<div class="sticky-top bg-white shadow-sm" style="top:0;z-index:100;">
    <div class="container">
        <ul class="nav nav-tabs border-0" id="publicTabs">
            <li class="nav-item">
                <a class="nav-link active fw-semibold" data-bs-toggle="tab" href="#tab-matchs">
                    <i class="bi bi-calendar3 me-1"></i>Matchs
                    <span class="badge bg-secondary ms-1">@Model.Matchs.Count</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-calendrier">
                    <i class="bi bi-calendar-event me-1"></i>Calendrier
                    <span class="badge bg-secondary ms-1">@(Model.Matchs.Count + Model.Evenements.Count)</span>
                </a>
            </li>
            @if (Model.Staff.Any())
            {
                <li class="nav-item">
                    <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-coachs">
                        <i class="bi bi-person-badge me-1"></i>Entraineurs
                        <span class="badge bg-secondary ms-1">@Model.Staff.Count</span>
                    </a>
                </li>
            }
            @if (Model.Joueurs.Any())
            {
                <li class="nav-item">
                    <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-joueurs">
                        <i class="bi bi-people me-1"></i>Joueurs
                        <span class="badge bg-secondary ms-1">@Model.Joueurs.Count</span>
                    </a>
                </li>
            }
        </ul>
    </div>
</div>

<div class="container my-4">
    <div class="tab-content">

        @* ── Onglet Matchs ─────────────────────────────────────────────────── *@
        <div class="tab-pane fade show active" id="tab-matchs">
            @{
                var matchsAvenir = Model.Matchs.Where(m => !m.AResultat && m.DateMatch >= now).OrderBy(m => m.DateMatch).ToList();
                var matchsPassés = Model.Matchs.Where(m => m.AResultat || m.DateMatch < now).OrderByDescending(m => m.DateMatch).ToList();
            }

            @if (matchsAvenir.Any())
            {
                <h2 class="h5 section-title mb-3"><i class="bi bi-calendar-event me-2"></i>Prochains matchs</h2>
                <div class="row g-3 mb-4">
                    @foreach (var m in matchsAvenir)
                    {
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100" style="border-left:4px solid var(--couleur-secondaire) !important;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-bold fs-5">@(m.EstDomicile ? "vs" : "@") @m.Adversaire</div>
                                            <div class="text-muted small">
                                                <i class="bi bi-calendar3 me-1"></i>@m.DateMatch.ToString("dddd d MMMM yyyy", frCA)
                                                @if (!string.IsNullOrEmpty(m.HeureDebutMatch))
                                                { <span class="ms-2"><i class="bi bi-clock me-1"></i>@m.HeureDebutMatch</span> }
                                            </div>
                                            @if (!string.IsNullOrEmpty(m.Lieu))
                                            { <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@m.Lieu</div> }
                                        </div>
                                        <span class="badge @(m.EstDomicile ? "bg-success" : "bg-secondary")">
                                            @(m.EstDomicile ? "Domicile" : "Extérieur")
                                        </span>
                                    </div>
                                    @if (!m.EstDomicile && (!string.IsNullOrEmpty(m.HeureDepartAutobus) || !string.IsNullOrEmpty(m.HeureArriveeVestiaire)))
                                    {
                                        <hr class="my-2" />
                                        <div class="small text-muted d-flex gap-3 flex-wrap">
                                            @if (!string.IsNullOrEmpty(m.HeureArriveeVestiaire))
                                            { <span><i class="bi bi-door-open me-1"></i>Vestiaire @m.HeureArriveeVestiaire</span> }
                                            @if (!string.IsNullOrEmpty(m.HeureDepartAutobus))
                                            { <span><i class="bi bi-bus-front me-1"></i>Autobus @m.HeureDepartAutobus</span> }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (matchsPassés.Any())
            {
                <h2 class="h5 section-title mb-3"><i class="bi bi-clock-history me-2"></i>Résultats</h2>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Adversaire</th>
                                <th class="d-none d-md-table-cell">Lieu</th>
                                <th class="text-center">Résultat</th>
                                <th class="text-center"><i class="bi bi-images"></i></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in matchsPassés)
                            {
                                var hasPhotos = Model.MatchesMedias.TryGetValue(m.Id, out var photos) && photos.Any();
                                <tr class="@(hasPhotos ? "match-row-galerie" : "")"
                                    data-match-id="@m.Id"
                                    style="@(hasPhotos ? "cursor:pointer;" : "")"
                                    title="@(hasPhotos ? "Voir la galerie" : "")">
                                    <td class="text-nowrap small">@m.DateMatch.ToString("d MMM yyyy", frCA)</td>
                                    <td>
                                        <span class="fw-semibold">@(m.EstDomicile ? "vs" : "@") @m.Adversaire</span>
                                        @if (m.EstDomicile)
                                        { <span class="badge bg-info text-dark ms-1 small">Domicile</span> }
                                    </td>
                                    <td class="text-muted small d-none d-md-table-cell">@m.Lieu</td>
                                    <td class="text-center">
                                        @if (m.AResultat)
                                        {
                                            var cls = m.Resultat switch { "V" => "bg-success", "D" => "bg-danger", _ => "bg-secondary" };
                                            <span class="badge @cls me-1">@m.Resultat</span>
                                            <span class="fw-semibold">@m.ScoreEquipe – @m.ScoreAdversaire</span>
                                        }
                                        else
                                        { <span class="text-muted small">—</span> }
                                    </td>
                                    <td class="text-center">
                                        @if (hasPhotos)
                                        {
                                            <span class="badge rounded-pill" style="background-color:var(--couleur-secondaire);">
                                                <i class="bi bi-camera me-1"></i>@photos!.Count
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Galerie dynamique *@
                <div id="galerieSection" class="mt-3" style="display:none;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h3 class="h6 section-title mb-0" id="galerieTitre"></h3>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="fermerGalerie()">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                    <div class="row g-2" id="galeriePhotos"></div>
                </div>
            }

            @if (!Model.Matchs.Any())
            {
                <p class="text-muted text-center py-4">Aucun match au calendrier.</p>
            }

        </div>

        @* ── Onglet Calendrier ───────────────────────────────────────────────── *@
        <div class="tab-pane fade" id="tab-calendrier">
            @{
                var pubCalItems = new List<(DateTime Date, DateTime? DateFin, string Titre, string SousTexte, string Lieu, string IconClass, string IconColor, string Heure)>();
                foreach (var m in Model.Matchs)
                {
                    var resultColor = m.AResultat ? (m.Resultat switch { "V" => "#198754", "D" => "#dc3545", _ => "#6c757d" }) : "#6c757d";
                    var adversaire = (m.EstDomicile ? "vs " : "\u0040 ") + m.Adversaire;
                    var sous = m.AResultat ? $"{m.ScoreEquipe}\u2013{m.ScoreAdversaire}" : "Match";
                    var heure = m.HeureDebutMatch ?? "";
                    pubCalItems.Add((m.DateMatch, null, adversaire, sous, m.Lieu ?? "", "bi-flag-fill", resultColor, heure));
                }
                foreach (var ev in Model.Evenements)
                {
                    var (icon, color) = ev.Type switch
                    {
                        TypeEvenement.Pratique => ("bi-stopwatch-fill", "#0d6efd"),
                        TypeEvenement.ReunionParents => ("bi-people-fill", "#6f42c1"),
                        TypeEvenement.Tournoi => ("bi-trophy-fill", "#ffc107"),
                        TypeEvenement.Jamboree => ("bi-flag-fill", "#20c997"),
                        TypeEvenement.Evaluation => ("bi-clipboard-check-fill", "#fd7e14"),
                        TypeEvenement.ActiviteEquipe => ("bi-star-fill", "#198754"),
                        _ => ("bi-calendar-event", "#6c757d")
                    };
                    var typeLabel = ev.Type switch
                    {
                        TypeEvenement.Pratique => "Pratique",
                        TypeEvenement.ReunionParents => "Réunion de parents",
                        TypeEvenement.Tournoi => "Tournoi",
                        TypeEvenement.Jamboree => "Jamborée",
                        TypeEvenement.Evaluation => "Évaluation / Tryout",
                        TypeEvenement.ActiviteEquipe => "Activité d'équipe",
                        _ => "Autre"
                    };
                    var heure = ev.DateDebut.ToString("HH:mm");
                    pubCalItems.Add((ev.DateDebut, ev.DateFin, ev.Titre, typeLabel, ev.Lieu ?? "", icon, color, heure));
                }
                var pubGrouped = pubCalItems.OrderBy(x => x.Date).GroupBy(x => new DateTime(x.Date.Year, x.Date.Month, 1)).ToList();
            }

            @* Toggle liste / grille *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 section-title mb-0"><i class="bi bi-calendar3 me-2"></i>Calendrier</h2>
                <div class="btn-group btn-group-sm" role="group" id="calViewToggle">
                    <button type="button" class="btn btn-outline-secondary active" id="btnListe">
                        <i class="bi bi-list-ul me-1"></i>Liste
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="btnGrille">
                        <i class="bi bi-grid-3x3-gap me-1"></i>Calendrier
                    </button>
                </div>
            </div>

            @* ── Vue Liste ──────────────────────────────────────────────── *@
            <div id="calVueListe">
                @if (!pubCalItems.Any())
                {
                    <p class="text-muted text-center py-4"><i class="bi bi-calendar-x me-2"></i>Aucun événement au calendrier.</p>
                }
                else
                {
                    @foreach (var grp in pubGrouped)
                    {
                        <div class="mb-4">
                            <h3 class="h6 text-uppercase fw-bold text-muted mb-2">@grp.Key.ToString("MMMM yyyy", frCA)</h3>
                            <div class="list-group shadow-sm">
                                @foreach (var item in grp)
                                {
                                    <div class="list-group-item border-0 py-3">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="text-center flex-shrink-0" style="min-width:42px;">
                                                <div class="fw-bold fs-4 lh-1" style="color:var(--couleur-primaire);">@item.Date.Day</div>
                                                <div class="text-muted" style="font-size:.68rem;text-transform:uppercase;">@item.Date.ToString("ddd", frCA)</div>
                                            </div>
                                            <div style="width:3px;border-radius:2px;background:@item.IconColor;align-self:stretch;flex-shrink:0;"></div>
                                            <div class="flex-grow-1">
                                                <div class="d-flex align-items-center gap-2 fw-semibold small">
                                                    <i class="bi @item.IconClass" style="color:@item.IconColor;"></i>
                                                    @item.Titre
                                                </div>
                                                <div class="small text-muted">@item.SousTexte</div>
                                                @if (!string.IsNullOrEmpty(item.Heure))
                                                {
                                                    <div class="small text-muted"><i class="bi bi-clock me-1"></i>@item.Heure@(item.DateFin.HasValue ? " – " + item.DateFin.Value.ToString("HH:mm") : "")</div>
                                                }
                                                @if (!string.IsNullOrEmpty(item.Lieu))
                                                {
                                                    <div class="small text-muted"><i class="bi bi-geo-alt me-1"></i>@item.Lieu</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            @* ── Vue Grille ─────────────────────────────────────────────── *@
            <div id="calVueGrille" style="display:none;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <button type="button" id="calPrevMois" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span id="calMoisTitre" class="fw-bold fs-5"></span>
                    <button type="button" id="calNextMois" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
                <div id="calGrille"></div>
            </div>
        </div>

        @* ── Onglet Entraineurs ───────────────────────────────────────────────── *@
        @if (Model.Staff.Any())
        {
            <div class="tab-pane fade" id="tab-coachs">
                <div class="row g-2">
                    @foreach (var s in Model.Staff.OrderBy(s => s.Titre).ThenBy(s => s.Nom))
                    {
                        <div class="col-6 col-sm-4 col-md-3 col-lg-2 staff-card"
                             data-fullnom="@s.Prenom @s.Nom"
                             data-photo="@s.PhotoPath"
                             data-titre="@s.Titre"
                             data-responsable="@s.ResponsableDe"
                             style="cursor:pointer;">
                            <div class="mini-trading-card">
                                @if (!string.IsNullOrEmpty(s.PhotoPath))
                                {
                                    <img src="@s.PhotoPath" alt="@s.Prenom @s.Nom" class="mini-photo" />
                                }
                                else
                                {
                                    <div class="mini-no-photo"><i class="bi bi-person-fill" style="font-size:2.5rem;color:rgba(255,255,255,.3);"></i></div>
                                }
                                <div class="mini-gradient"></div>
                                <div class="mini-badge">
                                    <span class="badge" style="font-size:.55rem;background-color:var(--couleur-secondaire);">@s.Titre</span>
                                </div>
                                <div class="mini-info">
                                    <div class="mini-nom">@s.Prenom @s.Nom</div>
                                    @if (!string.IsNullOrEmpty(s.ResponsableDe))
                                    {
                                        <div class="mini-pos">@s.ResponsableDe</div>
                                    }
                                </div>
                                <div class="mini-bande"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Onglet Joueurs ─────────────────────────────────────────────────── *@
        @if (Model.Joueurs.Any())
        {
            <div class="tab-pane fade" id="tab-joueurs">
                @* Barre de recherche *@
                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="rechercheJoueur" class="form-control border-start-0"
                               placeholder="Rechercher par nom, prénom ou numéro..." />
                    </div>
                </div>

                @* Joueurs groupés par position *@
                @{
                    var groupesPosition = Model.Joueurs
                        .GroupBy(j => j.Position)
                        .OrderBy(g => g.Key)
                        .ToList();
                }
                @foreach (var groupe in groupesPosition)
                {
                    <div class="position-group mb-4" data-position="@groupe.Key.ToLower()">
                        <h3 class="h6 section-title text-uppercase fw-bold mb-3">
                            @groupe.Key
                            <span class="badge bg-secondary ms-1 text-lowercase fw-normal">@groupe.Count()</span>
                        </h3>
                        <div class="row g-2">
                            @foreach (var j in groupe.OrderBy(j => j.Numero))
                            {
                                <div class="col-6 col-sm-4 col-md-3 col-lg-2 joueur-card"
                                     data-nom="@j.Nom.ToLower()"
                                     data-prenom="@j.Prenom.ToLower()"
                                     data-numero="@j.Numero.ToLower()"
                                     data-fullnom="@j.Prenom @j.Nom"
                                     data-photo="@j.PhotoPath"
                                     data-position="@j.Position"
                                     data-position-specifique="@j.PositionSpecifique"
                                     data-description="@j.Description"
                                     data-joueur-id="@j.Id"
                                     data-nofiche="@j.NoFiche"
                                     data-consentement="@j.ConsentementPhoto.ToString().ToLower()"
                                     style="cursor:pointer;">
                                    <div class="mini-trading-card">
                                        @if (!string.IsNullOrEmpty(j.PhotoPath) && j.ConsentementPhoto)
                                        {
                                            <img src="@j.PhotoPath" alt="@j.Prenom @j.Nom" class="mini-photo" />
                                        }
                                        else
                                        {
                                            <div class="mini-no-photo">#@j.Numero</div>
                                        }
                                        <div class="mini-gradient"></div>
                                        <div class="mini-numero">#@j.Numero</div>
                                        @if (!string.IsNullOrEmpty(j.PositionSpecifique))
                                        {
                                            <div class="mini-badge">
                                                <span class="badge" style="font-size:.55rem;background-color:var(--couleur-secondaire);">@j.PositionSpecifique</span>
                                            </div>
                                        }
                                        <div class="mini-info">
                                            <div class="mini-nom">@j.Prenom @j.Nom</div>
                                            <div class="mini-pos">@j.Position</div>
                                        </div>
                                        <div class="mini-bande"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <p id="aucunResultat" class="text-muted text-center py-3" style="display:none;">
                    Aucun joueur trouvé.
                </p>
            </div>
        }

    </div>
</div>

@* ── Données JSON pour galeries ───────────────────────────────────────────── *@
@{
    var galeriesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.MatchesMedias.ToDictionary(
            kvp => kvp.Key.ToString(),
            kvp => kvp.Value.Select(p => new { chemin = p.CheminFichier, description = p.Description ?? "" }).ToList()
        )
    );
    var titresJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Matchs
            .Where(m => m.AResultat)
            .ToDictionary(
                m => m.Id.ToString(),
                m => (m.EstDomicile ? "vs" : "\u0040") + " " + m.Adversaire + " \u2014 " + m.DateMatch.ToString("d MMM yyyy", frCA)
            )
    );
}
