@model GestionEquipeSportive.ViewModels.PublicEquipeViewModel
@using GestionEquipeSportive.Models
@using System.Globalization
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = $"{Model.SportDisplay} — {Model.NiveauDisplay} {Model.Equipe.AnneeScolaire}";
    ViewBag.NomEcole = Model.Ecole.Nom;
    ViewBag.CouleurPrimaire = Model.CouleurPrimaire;
    ViewBag.CouleurSecondaire = Model.CouleurSecondaire;
    ViewBag.LogoPath = Model.LogoPath;
    var frCA = new CultureInfo("fr-CA");
    var now = DateTime.Now;
}

@section HeaderRight {
    @{
        // Toutes les équipes publiques de cette école (courante incluse), groupées par sport
        var toutesEquipes = Model.AutresEquipesEcole
            .Append((Equipe: Model.Equipe, Url: "#"))
            .OrderBy(x => x.Equipe.TypeSport)
            .ThenBy(x => x.Equipe.Niveau)
            .ThenBy(x => x.Equipe.AnneeScolaire)
            .ToList();

        var parSport = toutesEquipes
            .GroupBy(x => x.Equipe.TypeSport)
            .OrderBy(g => g.Key)
            .ToList();
    }
    <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
        @* ── Liens sociaux ── *@
        @if (Model.Ecole.LiensSociaux.Any())
        {
            <div class="d-flex align-items-center gap-2 me-1">
                @foreach (var lien in Model.Ecole.LiensSociaux)
                {
                    var lienIcon = lien.Type switch {
                        "Facebook"    => "bi-facebook",
                        "Instagram"   => "bi-instagram",
                        "X / Twitter" => "bi-twitter-x",
                        "YouTube"     => "bi-youtube",
                        "TikTok"      => "bi-tiktok",
                        _             => "bi-globe"
                    };
                    <a href="@lien.Url" target="_blank" rel="noopener noreferrer"
                       class="header-social-link" title="@(string.IsNullOrEmpty(lien.Label) ? lien.Type : lien.Label)">
                        <i class="bi @lienIcon"></i>
                    </a>
                }
            </div>
        }
        @* ── Switcher équipes de la même école ── *@
        @if (toutesEquipes.Count > 1)
        {
            <div class="dropdown switcher-dropdown">
                <button class="switcher-btn dropdown-toggle" data-bs-toggle="dropdown" type="button">
                    <i class="bi bi-people me-1"></i>@Model.Equipe.Nom — @Model.Equipe.AnneeScolaire
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width:260px;">
                    <li><h6 class="dropdown-header"><i class="bi bi-shield-fill me-1"></i>@Model.Ecole.Nom</h6></li>
                    @foreach (var sportGroupe in parSport)
                    {
                        var sportLabel = sportGroupe.Key switch {
                            TypeSport.FootballAmericain => "Football",
                            TypeSport.FlagFootball      => "Flag Football",
                            TypeSport.Soccer            => "Soccer",
                            TypeSport.Volleyball        => "Volleyball",
                            TypeSport.Hockey            => "Hockey",
                            _                           => sportGroupe.Key.ToString()
                        };
                        <li><hr class="dropdown-divider my-1"></li>
                        <li><span class="dropdown-header py-1 text-uppercase fw-bold" style="font-size:.7rem;letter-spacing:.06em;">@sportLabel</span></li>
                        @foreach (var (equipe, url) in sportGroupe)
                        {
                            var isCurrent = equipe.Id == Model.Equipe.Id;
                            <li>
                                <a class="dropdown-item @(isCurrent ? "active" : "")" href="@url">
                                    @if (isCurrent) { <i class="bi bi-check2 me-1"></i> }
                                    <span class="fw-semibold">@equipe.Nom</span>
                                    <span class="text-muted ms-1" style="font-size:.8rem;">@equipe.AnneeScolaire</span>
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        }
    </div>
}

@* ── Bannière ─────────────────────────────────────────────────────────────── *@
@{
    var aucunMatch = Model.ProchainMatch == null && Model.DernierMatchAvecResultat == null && !Model.Matchs.Any();
    string? bgBanniere = null;
    if (Model.PhotoBanniere != null)
    {
        bgBanniere = Model.PhotoBanniere.CheminFichier;
    }
    else
    {
        // Essayer les photos du dernier match ou des joueurs
        var anyMatchPhoto = Model.MatchesMedias.Values
            .SelectMany(l => l.Where(m => m.TypeMedia == TypeMedia.Photo && !string.IsNullOrEmpty(m.CheminFichier)))
            .Select(m => m.CheminFichier!).FirstOrDefault();
        if (anyMatchPhoto != null)
        {
            bgBanniere = anyMatchPhoto;
        }
        else
        {
            var anyJoueurPhoto = Model.JoueurMedias.Values
                .SelectMany(l => l.Where(m => !string.IsNullOrEmpty(m.CheminFichier)))
                .Select(m => m.CheminFichier!).FirstOrDefault();
            bgBanniere = anyJoueurPhoto ?? $"/images/defaults/football-{Random.Shared.Next(1, 5)}.svg";
        }
    }

    // Image aléatoire pour la bannière prochain match (matchs en priorité, puis joueurs)
    string? pubBgImg = null;
    if (Model.ProchainMatch != null)
    {
        var toutes = Model.MatchesMedias.Values
            .SelectMany(l => l.Where(m => m.TypeMedia == TypeMedia.Photo && !string.IsNullOrEmpty(m.CheminFichier)))
            .Select(m => m.CheminFichier!)
            .ToList();
        if (!toutes.Any())
            toutes = Model.JoueurMedias.Values
                .SelectMany(l => l.Where(m => !string.IsNullOrEmpty(m.CheminFichier)))
                .Select(m => m.CheminFichier!)
                .ToList();
        if (toutes.Any())
            pubBgImg = toutes[Random.Shared.Next(toutes.Count)];
    }
}

@if (Model.ProchainMatch != null)
{
    var pubPm = Model.ProchainMatch;
    var pubAdvLogo = pubPm.AdversaireId.HasValue && Model.AdversaireLogos.TryGetValue(pubPm.AdversaireId.Value, out var pubAlp) ? pubAlp : null;
    <style>
        /* ── Conteneur ── */
        #pubBanniere {
            background:linear-gradient(135deg,@Model.CouleurPrimaire 0%,color-mix(in srgb,@Model.CouleurPrimaire 38%,#000) 100%);
            color:#fff;position:relative;overflow:hidden;min-height:280px;
            display:flex;align-items:center;justify-content:center;
        }
        /* ── Fond photo ── */
        .pub-bg { position:absolute;inset:0;background-size:cover;background-position:center;
            pointer-events:none;opacity:0;animation:pubBgIn 1.6s ease .2s forwards; }
        @@keyframes pubBgIn { to { opacity:.26;transform:scale(1); } from { opacity:0;transform:scale(1.1); } }

        /* ── Flash initial ── */
        .pub-flash { position:absolute;inset:0;background:#fff;pointer-events:none;z-index:20;
            animation:pubFlash0 .5s ease forwards; }
        @@keyframes pubFlash0 { 0%{opacity:.9} 100%{opacity:0} }

        /* ── Scanlines CRT ── */
        .pub-scanlines { position:absolute;inset:0;pointer-events:none;z-index:1;
            background:repeating-linear-gradient(0deg,transparent 0,transparent 3px,rgba(0,0,0,.07) 3px,rgba(0,0,0,.07) 4px); }

        /* ── Rayons (tournent indéfiniment) ── */
        .pub-speedlines { position:absolute;inset:-50%;pointer-events:none;z-index:1;
            background:repeating-conic-gradient(rgba(255,255,255,.04) 0deg 1.5deg,transparent 1.5deg 9deg);
            animation:pubSpin 10s linear infinite; }
        @@keyframes pubSpin { to { transform:rotate(360deg); } }

        /* ── Lueurs ── */
        .pub-glow { position:absolute;border-radius:50%;filter:blur(70px);pointer-events:none;z-index:1; }

        /* ── Éclairs de choc (injectés par JS) ── */
        .pub-clash-flash { position:absolute;inset:0;background:radial-gradient(circle,rgba(255,255,255,.85) 0%,transparent 70%);
            pointer-events:none;z-index:15;animation:pubClashFlash .3s ease forwards; }
        @@keyframes pubClashFlash { 0%{opacity:1} 100%{opacity:0} }
        @@keyframes pubShakeEl {
            0%,100%{transform:translateX(0) translateY(0)}
            15%{transform:translateX(-9px) translateY(3px)}
            30%{transform:translateX(9px)  translateY(-3px)}
            45%{transform:translateX(-6px) translateY(2px)}
            60%{transform:translateX(6px)  translateY(-2px)}
            75%{transform:translateX(-3px)}
            90%{transform:translateX(3px)}
        }
        @@keyframes pubSparkFly {
            0%   { transform:translate(-50%,-50%) rotate(var(--a)) translateY(0)                   scale(1);   opacity:1; }
            100% { transform:translate(-50%,-50%) rotate(var(--a)) translateY(calc(-1*var(--d)))   scale(0);   opacity:0; }
        }

        /* ── Contenu ── */
        .pub-inner { position:relative;z-index:5;display:flex;flex-direction:column;align-items:center;padding:22px 20px;width:100%; }

        /* ── Badge ── */
        .pub-badge { display:inline-block;padding:5px 18px;border-radius:3px;
            font-weight:900;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:#fff;
            
            
            animation:pubBadgeDrop .4s cubic-bezier(.34,1.56,.64,1) .1s both; }
        @@keyframes pubBadgeDrop { from{opacity:0;transform:translateY(-20px) scaleX(.6)} to{opacity:1;transform:none} }

        /* ── Zone logos + VS ── */
        .pub-vs-wrap { display:flex;align-items:center;justify-content:center;gap:28px;width:100%;max-width:500px; }

        /* ── LOGO GAUCHE — 5s, 2 chocs puis final ── */
        .pub-logo-left {
            width:96px;height:96px;object-fit:contain;flex-shrink:0;
            animation:pubLogoL 5s cubic-bezier(.4,0,.2,1) forwards,
                       pubLogoGlow 2s ease-in-out 5.1s infinite alternate;
        }
        @@keyframes pubLogoL {
            /*  0.0s  */ 0%  { opacity:0; transform:translateX(-340px) scale(.45) rotate(-18deg); }
            /*  0.2s  */ 4%  { opacity:1; }
            /* Choc 1 →  1.2s */ 24% { transform:translateX(60px)  scale(1.3)  rotate(6deg); }
            /* Recul  →  1.7s */ 34% { transform:translateX(-160px) scale(.85) rotate(-10deg); }
            /* Choc 2 →  2.6s */ 52% { transform:translateX(52px)  scale(1.24) rotate(4deg); }
            /* Recul  →  3.2s */ 64% { transform:translateX(-100px) scale(.88) rotate(-6deg); }
            /* Élan final → 3.7s */ 74% { transform:translateX(44px)  scale(1.2) rotate(2deg); }
            /* Impact → 4.0s */  80% { transform:translateX(0) scale(1.05); }
            /* Settle → 4.5s */  90% { transform:translateX(-5px) scale(.98); }
            /* Repos  → 5.0s */ 100% { transform:translateX(0) scale(1); }
        }

        /* ── LOGO DROIT — miroir ── */
        .pub-logo-right {
            width:96px;height:96px;object-fit:contain;flex-shrink:0;
            animation:pubLogoR 5s cubic-bezier(.4,0,.2,1) forwards,
                       pubLogoGlow 2s ease-in-out 5.4s infinite alternate;
        }
        @@keyframes pubLogoR {
            0%  { opacity:0; transform:translateX(340px)  scale(.45) rotate(18deg); }
            4%  { opacity:1; }
            24% { transform:translateX(-60px)  scale(1.3)  rotate(-6deg); }
            34% { transform:translateX(160px)  scale(.85)  rotate(10deg); }
            52% { transform:translateX(-52px)  scale(1.24) rotate(-4deg); }
            64% { transform:translateX(100px)  scale(.88)  rotate(6deg); }
            74% { transform:translateX(-44px)  scale(1.2)  rotate(-2deg); }
            80% { transform:translateX(0)      scale(1.05); }
            90% { transform:translateX(5px)    scale(.98); }
           100% { transform:translateX(0)      scale(1); }
        }

        @@keyframes pubLogoGlow {
            from { filter:drop-shadow(0 0 8px  rgba(255,255,255,.3)) drop-shadow(0 4px 10px rgba(0,0,0,.7)); }
            to   { filter:drop-shadow(0 0 30px rgba(255,255,255,.9)) drop-shadow(0 4px 16px rgba(0,0,0,.8)); }
        }

        .pub-logo-ph { width:96px;height:96px;border-radius:50%;flex-shrink:0;
            border:2px dashed rgba(255,255,255,.22);display:flex;align-items:center;justify-content:center; }

        /* ── VS — apparaît au choc final (80%) → 4.0s ── */
        .pub-vs {
            font-size:2.8rem;font-weight:900;color:#fff;letter-spacing:.06em;flex-shrink:0;
            animation:pubVsAppear 5s ease forwards, pubVsPulse 1.4s ease-in-out 5.1s infinite alternate;
        }
        @@keyframes pubVsAppear {
            0%,74% { opacity:0; transform:scale(0); }
            80%    { opacity:1; transform:scale(2.2); filter:brightness(4); }
            90%    { transform:scale(.88); filter:brightness(1); }
            100%   { opacity:1; transform:scale(1); }
        }
        @@keyframes pubVsPulse {
            from { text-shadow:0 0 12px rgba(255,255,255,.3); letter-spacing:.04em; }
            to   { text-shadow:0 0 60px rgba(255,255,255,1);  letter-spacing:.1em; }
        }

        /* ── Texte info — apparaît après 4.5s ── */
        .pub-adversaire { font-size:1.35rem;font-weight:800;color:#fff;text-align:center;margin-top:12px;
            text-shadow:0 2px 8px rgba(0,0,0,.5);
            animation:pubInfoIn .5s cubic-bezier(.34,1.56,.64,1) 4.5s both; }
        .pub-date { font-size:.82rem;font-weight:500;color:rgba(255,255,255,.85);text-align:center;margin-top:5px;
            animation:pubInfoIn .5s cubic-bezier(.34,1.56,.64,1) 4.65s both; }
        .pub-details { font-size:.75rem;color:rgba(255,255,255,.6);text-align:center;margin-top:4px;
            animation:pubInfoIn .5s cubic-bezier(.34,1.56,.64,1) 4.8s both; }
        @@keyframes pubInfoIn {
            from { opacity:0; transform:translateY(16px) scale(.92); }
            to   { opacity:1; transform:none; }
        }
    </style>

    <div id="pubBanniere">
        @if (!string.IsNullOrEmpty(pubBgImg))
        { <div class="pub-bg" style="background-image:url('@pubBgImg');"></div> }
        <div class="pub-flash"></div>
        <div class="pub-scanlines"></div>
        <div class="pub-speedlines"></div>
        <div class="pub-glow" style="width:380px;height:380px;background:@Model.CouleurSecondaire;opacity:.18;top:-130px;left:-110px;"></div>
        <div class="pub-glow" style="width:260px;height:260px;background:#fff;opacity:.05;bottom:-80px;right:-60px;"></div>

        <div class="pub-inner">
            <div class="pub-badge">⚡ Prochain match</div>

            <div class="pub-vs-wrap">
                @if (!string.IsNullOrEmpty(Model.LogoPath))
                { <img src="@Model.LogoPath" alt="@Model.NomEquipe" class="pub-logo-left" /> }
                else
                { <div class="pub-logo-ph" style="animation:pubLogoL 5s cubic-bezier(.4,0,.2,1) forwards;"><i class="bi bi-shield-fill" style="font-size:2.4rem;color:rgba(255,255,255,.28);"></i></div> }

                <div class="pub-vs">VS</div>

                @if (!string.IsNullOrEmpty(pubAdvLogo))
                { <img src="@pubAdvLogo" alt="@pubPm.Adversaire" class="pub-logo-right" /> }
                else
                { <div style="width:96px;height:96px;flex-shrink:0;display:flex;align-items:center;justify-content:center;animation:pubLogoR 5s cubic-bezier(.4,0,.2,1) forwards;"><span style="font-size:2.6rem;filter:drop-shadow(0 2px 8px rgba(0,0,0,.4));">🏈</span></div> }
            </div>

            <div class="pub-adversaire">@pubPm.Adversaire</div>
            <div class="pub-date">
                @pubPm.DateMatch.ToString("dddd d MMMM yyyy", frCA)
                @if (!string.IsNullOrEmpty(pubPm.HeureDebutMatch)) { <span>· @pubPm.HeureDebutMatch</span> }
            </div>
            @if (!string.IsNullOrEmpty(pubPm.Lieu) || !string.IsNullOrEmpty(pubPm.HeureArriveeVestiaire) || !string.IsNullOrEmpty(pubPm.HeureDepartAutobus))
            {
                <div class="pub-details">
                    @if (!string.IsNullOrEmpty(pubPm.Lieu)) { <span><i class="bi bi-geo-alt me-1"></i>@pubPm.Lieu</span> }
                    @if (!string.IsNullOrEmpty(pubPm.HeureArriveeVestiaire)) { <span class="ms-3"><i class="bi bi-door-open me-1"></i>Vestiaire @pubPm.HeureArriveeVestiaire</span> }
                    @if (!string.IsNullOrEmpty(pubPm.HeureDepartAutobus)) { <span class="ms-3"><i class="bi bi-bus-front me-1"></i>Autobus @pubPm.HeureDepartAutobus</span> }
                </div>
            }
        </div>
    </div>
}
else
{
@if (Model.DernierMatchAvecResultat != null)
{
    var dm = Model.DernierMatchAvecResultat;
    var musiqueVictoire = Model.Theme?.MusiqueVictoirePath;
    var musiqueDefaite  = Model.Theme?.MusiqueDefaitePath;

    if (dm.Resultat == "V")
    {
    @* ── Animation VICTOIRE ─────────────────────────────────────────────── *@
    <style>
        #resBanniere {
            background:linear-gradient(135deg,#0a5c2e 0%,#1a8a44 50%,#0d4a25 100%);
            color:#fff;position:relative;overflow:hidden;min-height:260px;
            display:flex;align-items:center;justify-content:center;
        }
        .res-bg { position:absolute;inset:0;background-size:cover;background-position:center;
            pointer-events:none;opacity:0;animation:resBgIn 1.8s ease .3s forwards; }
        @@keyframes resBgIn { from{opacity:0;transform:scale(1.08)} to{opacity:.22;transform:scale(1)} }
        .res-scanlines { position:absolute;inset:0;pointer-events:none;
            background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.08) 4px);z-index:0; }
        /* Confetti particles */
        .confetti-wrap { position:absolute;inset:0;pointer-events:none;z-index:1;overflow:hidden; }
        .confetti-p { position:absolute;top:-18px;width:10px;height:10px;border-radius:2px;
            animation:confettiFall linear forwards; }
        @@keyframes confettiFall {
            0%   { transform:translateY(0) rotate(0deg);    opacity:1; }
            100% { transform:translateY(320px) rotate(520deg); opacity:0; }
        }
        /* Trophy slam */
        .res-trophy { font-size:4.5rem;display:block;text-align:center;line-height:1;
            animation:trophySlamIn .55s cubic-bezier(.22,1.8,.36,1) .4s both;
            filter:drop-shadow(0 0 18px #ffd700cc); }
        @@keyframes trophySlamIn {
            from { opacity:0;transform:translateY(-120px) scale(.4) rotate(-15deg); }
            80%  { transform:translateY(10px) scale(1.12) rotate(3deg); }
            to   { opacity:1;transform:translateY(0) scale(1) rotate(0); }
        }
        /* Score */
        .res-score-wrap { display:flex;align-items:center;justify-content:center;gap:16px;margin:10px 0 6px;
            animation:scorePop .55s cubic-bezier(.22,1.6,.36,1) 1s both; }
        @@keyframes scorePop {
            from { opacity:0;transform:scale(.4); }
            80%  { transform:scale(1.18); }
            to   { opacity:1;transform:scale(1); }
        }
        .res-score-nous { font-size:4.2rem;font-weight:900;line-height:1;color:#ffd700;
            text-shadow:0 0 24px #ffd700,0 3px 12px rgba(0,0,0,.5); }
        .res-score-sep   { font-size:2.4rem;opacity:.5;font-weight:300; }
        .res-score-eux   { font-size:4.2rem;font-weight:900;line-height:1;opacity:.7; }
        /* VICTOIRE! */
        .res-label-v { font-size:2.1rem;font-weight:900;text-transform:uppercase;letter-spacing:.12em;
            color:#ffd700;text-shadow:0 0 30px #ffd700aa,0 2px 8px rgba(0,0,0,.6);text-align:center;
            animation:victoireSplash .7s cubic-bezier(.22,2,.36,1) 1.6s both; }
        @@keyframes victoireSplash {
            from { opacity:0;transform:scale(2.5) rotate(-5deg); }
            70%  { transform:scale(.92) rotate(1deg); }
            to   { opacity:1;transform:scale(1) rotate(0); }
        }
        /* Glow burst */
        .res-burst { position:absolute;pointer-events:none;z-index:0;border-radius:50%;
            background:radial-gradient(circle,#ffd70044 0%,transparent 70%);
            width:500px;height:500px;top:50%;left:50%;transform:translate(-50%,-50%);
            animation:burstPulse 2s ease-in-out 1.8s infinite alternate; }
        @@keyframes burstPulse { from{opacity:.5;transform:translate(-50%,-50%) scale(.8)} to{opacity:.9;transform:translate(-50%,-50%) scale(1.2)} }
        /* Sub info */
        .res-sub { font-size:.8rem;color:rgba(255,255,255,.7);text-align:center;margin-top:6px;
            animation:resFadeUp .5s ease 2.5s both; }
        .res-logo-v { width:52px;height:52px;object-fit:contain;
            animation:logoGlowIn .7s ease .4s both;filter:drop-shadow(0 0 12px #ffd700cc); }
        @@keyframes logoGlowIn {
            from{opacity:0;transform:scale(.5)} 70%{transform:scale(1.15)} to{opacity:1;transform:scale(1)}
        }
        @@keyframes resFadeUp {
            from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none}
        }
        .res-inner { position:relative;z-index:2;text-align:center;padding:24px 16px; }
        .res-adv-v { font-size:1rem;opacity:.8;animation:resFadeUp .5s ease 2.2s both; }
    </style>
    <div id="resBanniere">
        @if (bgBanniere != null) { <div class="res-bg" style="background-image:url('@bgBanniere');"></div> }
        <div class="res-scanlines"></div>
        <div class="res-burst"></div>
        <div class="confetti-wrap" id="confettiWrap"></div>
        <div class="res-inner">
            @if (!string.IsNullOrEmpty(Model.LogoPath))
            { <img src="@Model.LogoPath" alt="" class="res-logo-v mb-2" /> }
            <span class="res-trophy">🏆</span>
            <div class="res-score-wrap">
                <span class="res-score-nous">@dm.ScoreEquipe</span>
                <span class="res-score-sep">–</span>
                <span class="res-score-eux">@dm.ScoreAdversaire</span>
            </div>
            <div class="res-label-v">⚡ Victoire ! ⚡</div>
            <div class="res-adv-v">vs @dm.Adversaire</div>
            <div class="res-sub">@dm.DateMatch.ToString("d MMMM yyyy", frCA)</div>
        </div>
    </div>
    <script>
    (function(){
        // Confetti
        var wrap = document.getElementById('confettiWrap');
        var colors = ['#ffd700','#fff','#4ade80','#facc15','#86efac','#fbbf24','#a3e635'];
        for(var i=0;i<55;i++){
            var p = document.createElement('div');
            p.className='confetti-p';
            p.style.left=Math.random()*100+'%';
            p.style.backgroundColor=colors[Math.floor(Math.random()*colors.length)];
            p.style.width=(7+Math.random()*9)+'px';
            p.style.height=(7+Math.random()*9)+'px';
            p.style.borderRadius=Math.random()>.5?'50%':'2px';
            var dur=1.8+Math.random()*2.8;
            p.style.animationDuration=dur+'s';
            p.style.animationDelay=(Math.random()*2)+'s';
            wrap.appendChild(p);
        }
        // Musique
        var musiqueVicUrl   = '@Html.Raw(musiqueVictoire ?? "")';
        var musiqueVicDebut = @(Model.Theme?.MusiqueVictoireDebut ?? 0);
        var musiqueVicDuree = @(Model.Theme?.MusiqueVictoireDuree ?? 10);
        if(musiqueVicUrl) {
            var audV=new Audio(musiqueVicUrl);
            audV.volume=0.82;
            function jouerVic(){ audV.currentTime=musiqueVicDebut; audV.play().catch(function(){}); setTimeout(function(){ var step=0.04; var fade=setInterval(function(){ audV.volume=Math.max(0,audV.volume-step); if(audV.volume===0){clearInterval(fade);audV.pause();} },120); },Math.max(0,musiqueVicDuree-2)*1000); }
            audV.play().catch(function(){
                document.addEventListener('click',function h(){jouerVic();document.removeEventListener('click',h);},{once:true});
            });
            if(audV.readyState>=2){ jouerVic(); } else { audV.addEventListener('canplay',jouerVic,{once:true}); }
        }
    })();
    </script>
    }
    else if (dm.Resultat == "D")
    {
    @* ── Animation DÉFAITE ──────────────────────────────────────────────── *@
    <style>
        #resBanniereD {
            background:linear-gradient(160deg,#0d1117 0%,#1c2333 55%,#0a0e17 100%);
            color:#fff;position:relative;overflow:hidden;min-height:260px;
            display:flex;align-items:center;justify-content:center;
        }
        .resd-bg { position:absolute;inset:0;background-size:cover;background-position:center;
            pointer-events:none;opacity:0;animation:resdBgIn 2s ease .5s forwards; }
        @@keyframes resdBgIn { from{opacity:0} to{opacity:.14} }
        /* Shake au départ */
        @@keyframes shakeD {
            0%,100%{transform:none}
            10%{transform:translateX(-8px) rotate(-1deg)}
            20%{transform:translateX(8px) rotate(1deg)}
            30%{transform:translateX(-6px)}
            40%{transform:translateX(6px)}
            50%{transform:translateX(-3px)}
            60%{transform:none}
        }
        #resBanniereD { animation:shakeD .7s ease .1s both; }
        /* Grosses gouttes */
        .rain-wrap { position:absolute;inset:0;pointer-events:none;z-index:1;overflow:hidden; }
        .rain-drop {
            position:absolute;top:-80px;
            background:radial-gradient(ellipse 40% 60% at 50% 30%, rgba(255,255,255,.85), rgba(200,220,255,.35));
            border-radius:50% 50% 60% 60% / 40% 40% 60% 60%;
            animation:rainFall linear infinite;
            filter:blur(.4px);
        }
        @@keyframes rainFall {
            0%  { transform:translateY(0) rotate(8deg); opacity:0; }
            8%  { opacity:1; }
            90% { opacity:.85; }
            100%{ transform:translateY(900px) rotate(12deg); opacity:0; }
        }
        /* Logo qui s'affaisse */
        .resd-logo { width:52px;height:52px;object-fit:contain;
            animation:logoDroop 1.2s cubic-bezier(.4,0,.2,1) .3s both;
            filter:grayscale(.55) brightness(.7); }
        @@keyframes logoDroop {
            0%  { opacity:0;transform:scale(.5) translateY(-30px); }
            50% { opacity:1;transform:scale(1.1) translateY(0); }
            75% { transform:scale(1) translateY(0) rotate(-4deg); }
            100%{ transform:scale(1) translateY(0) rotate(0); }
        }
        /* Score */
        .resd-score-wrap { display:flex;align-items:center;justify-content:center;gap:16px;margin:10px 0 6px;
            animation:resdScoreIn .7s ease 1.1s both; }
        @@keyframes resdScoreIn {
            from{opacity:0;transform:translateY(24px)}
            to{opacity:1;transform:none}
        }
        .resd-score-nous { font-size:4.2rem;font-weight:900;line-height:1;color:#94a3c8;
            text-shadow:0 0 18px rgba(148,163,200,.4); }
        .resd-score-sep   { font-size:2.4rem;opacity:.4;font-weight:300; }
        .resd-score-eux   { font-size:4.2rem;font-weight:900;line-height:1;opacity:.6; }
        /* DÉFAITE */
        .resd-label { font-size:2rem;font-weight:900;text-transform:uppercase;letter-spacing:.1em;
            color:#ef4444;text-shadow:0 0 20px rgba(239,68,68,.45);text-align:center;
            animation:defaiteSlam .6s cubic-bezier(.22,1.5,.36,1) 1.8s both; }
        @@keyframes defaiteSlam {
            from{opacity:0;transform:scale(1.8);filter:blur(6px)}
            to{opacity:.8;transform:scale(1);filter:none}
        }
        /* Vignette sombre */
        .resd-vignette { position:absolute;inset:0;pointer-events:none;z-index:0;
            background:radial-gradient(ellipse at center,transparent 25%,rgba(0,0,0,.65) 100%);
            animation:vignIn 1.5s ease .2s both; }
        @@keyframes vignIn { from{opacity:0} to{opacity:1} }
        .resd-inner { position:relative;z-index:2;text-align:center;padding:24px 16px; }
        .resd-sub { font-size:.8rem;color:rgba(255,255,255,.45);text-align:center;margin-top:6px;
            animation:resdFadeUp .5s ease 2.6s both; }
        .resd-adv { font-size:1rem;opacity:.6;animation:resdFadeUp .5s ease 2.3s both; }
        @@keyframes resdFadeUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }
        /* Pulse bleu-gris lent */
        .resd-pulse { position:absolute;inset:0;pointer-events:none;z-index:0;
            background:radial-gradient(ellipse at center,rgba(50,80,140,.2) 0%,transparent 70%);
            animation:resdPulse 3s ease-in-out 2s infinite alternate; }
        @@keyframes resdPulse { from{opacity:.2} to{opacity:.7} }
    </style>
    <div id="resBanniereD">
        @if (bgBanniere != null) { <div class="resd-bg" style="background-image:url('@bgBanniere');"></div> }
        <div class="resd-vignette"></div>
        <div class="resd-pulse"></div>
        <div class="rain-wrap" id="rainWrap"></div>
        <div class="resd-inner">
            @if (!string.IsNullOrEmpty(Model.LogoPath))
            { <img src="@Model.LogoPath" alt="" class="resd-logo mb-2" /> }
            <div class="resd-score-wrap">
                <span class="resd-score-nous">@dm.ScoreEquipe</span>
                <span class="resd-score-sep">–</span>
                <span class="resd-score-eux">@dm.ScoreAdversaire</span>
            </div>
            <div class="resd-label">Défaite</div>
            <div class="resd-adv">vs @dm.Adversaire</div>
            <div class="resd-sub">@dm.DateMatch.ToString("d MMMM yyyy", frCA)</div>
        </div>
    </div>
    <script>
    (function(){
        // Pluie
        var wrap = document.getElementById('rainWrap');
        for(var i=0;i<38;i++){
            var d=document.createElement('div');
            d.className='rain-drop';
            d.style.left=Math.random()*100+'%';
            d.style.width=(12+Math.random()*16)+'px';
            d.style.height=(30+Math.random()*50)+'px';
            var dur=.55+Math.random()*.6;
            d.style.animationDuration=dur+'s';
            d.style.animationDelay=(Math.random()*2)+'s';
            wrap.appendChild(d);
        }
        // Musique
        var musiqueDefUrl   = '@Html.Raw(musiqueDefaite ?? "")';
        var musiqueDefDebut = @(Model.Theme?.MusiqueDefaiteDebut ?? 0);
        var musiqueDefDuree = @(Model.Theme?.MusiqueDefaiteDuree ?? 10);
        if(musiqueDefUrl) {
            var audD=new Audio(musiqueDefUrl);
            audD.volume=0.72;
            function jouerDef(){ audD.currentTime=musiqueDefDebut; audD.play().catch(function(){}); setTimeout(function(){ var step=0.035; var fade=setInterval(function(){ audD.volume=Math.max(0,audD.volume-step); if(audD.volume===0){clearInterval(fade);audD.pause();} },120); },Math.max(0,musiqueDefDuree-2)*1000); }
            audD.play().catch(function(){
                document.addEventListener('click',function h(){jouerDef();document.removeEventListener('click',h);},{once:true});
            });
            if(audD.readyState>=2){ jouerDef(); } else { audD.addEventListener('canplay',jouerDef,{once:true}); }
        }
    })();
    </script>
    }
    else
    {
    @* ── Nul ── simple banner *@
    <div style="background-color:@Model.CouleurPrimaire; color:#fff; position:relative; overflow:hidden; min-height:200px;">
        @if (bgBanniere != null)
        { <div style="position:absolute;inset:0;background:url('@bgBanniere') center/cover no-repeat;opacity:.3;"></div> }
        <div class="container py-4" style="position:relative;z-index:1;">
            <div class="d-flex align-items-center gap-3 flex-wrap mb-2">
                <span class="rounded px-3 py-1 fw-bold text-uppercase small"
                      style="background-color:#6c757d;letter-spacing:.05em;">Nul</span>
                <span class="opacity-75 small">Dernier match · @dm.DateMatch.ToString("d MMMM yyyy", frCA)</span>
            </div>
            <div class="d-flex align-items-baseline gap-3">
                <span class="fw-bold" style="font-size:3.5rem;line-height:1;">@dm.ScoreEquipe</span>
                <span class="opacity-50 fs-4">–</span>
                <span class="fw-bold" style="font-size:3.5rem;line-height:1;">@dm.ScoreAdversaire</span>
                <span class="fs-4 ms-2">@dm.Adversaire</span>
            </div>
        </div>
    </div>
    }
}
else
{
    @* ── Aucun match ── *@
    <div style="background-color:@Model.CouleurPrimaire; color:#fff; position:relative; overflow:hidden; min-height:200px;">
        @if (bgBanniere != null)
        { <div style="position:absolute;inset:0;background:url('@bgBanniere') center/cover no-repeat;opacity:.3;"></div> }
        <div class="container py-4" style="position:relative;z-index:1;">
            <div class="fs-3 fw-bold">@Model.Equipe.Nom</div>
            <div class="opacity-75">@Model.SportDisplay — @Model.NiveauDisplay — @Model.Equipe.AnneeScolaire</div>
        </div>
    </div>
}
}

@* ── Stats ────────────────────────────────────────────────────────────────── *@
@if (Model.Stats.MatchsJoues > 0)
{
    <div style="background-color:@Model.CouleurPrimaire;opacity:.9;">
        <div class="container">
            <div class="row g-0 text-white text-center">
                <div class="col-4 py-2 border-end border-white border-opacity-25">
                    <div class="fw-bold fs-4">@Model.Stats.Victoires</div>
                    <div class="small opacity-75">Victoires</div>
                </div>
                <div class="col-4 py-2 border-end border-white border-opacity-25">
                    <div class="fw-bold fs-4">@Model.Stats.Defaites</div>
                    <div class="small opacity-75">Défaites</div>
                </div>
                <div class="col-4 py-2">
                    <div class="fw-bold fs-4">@Model.Stats.Nuls</div>
                    <div class="small opacity-75">Nuls</div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Navigation sous-menus ───────────────────────────────────────────────── *@
<div class="sticky-top bg-white shadow-sm" style="top:0;z-index:100;">
    <div class="container">
        <ul class="nav nav-tabs border-0" id="publicTabs">
            <li class="nav-item">
                <a class="nav-link active fw-semibold" data-bs-toggle="tab" href="#tab-matchs">
                    <i class="bi bi-calendar3 me-1"></i>Matchs
                    <span class="badge bg-secondary ms-1">@Model.Matchs.Count</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-calendrier">
                    <i class="bi bi-calendar-event me-1"></i>Calendrier
                    <span class="badge bg-secondary ms-1">@(Model.Matchs.Count + Model.Evenements.Count)</span>
                </a>
            </li>
            @if (Model.Staff.Any())
            {
                <li class="nav-item">
                    <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-coachs">
                        <i class="bi bi-person-badge me-1"></i>Entraineurs
                        <span class="badge bg-secondary ms-1">@Model.Staff.Count</span>
                    </a>
                </li>
            }
            @if (Model.Joueurs.Any())
            {
                <li class="nav-item">
                    <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-joueurs">
                        <i class="bi bi-people me-1"></i>Joueurs
                        <span class="badge bg-secondary ms-1">@Model.Joueurs.Count</span>
                    </a>
                </li>
            }
        </ul>
    </div>
</div>

<div class="container my-4">
    <div class="tab-content">

        @* ── Onglet Matchs ─────────────────────────────────────────────────── *@
        <div class="tab-pane fade show active" id="tab-matchs">
            @{
                var matchsAvenir = Model.Matchs.Where(m => !m.AResultat && m.DateMatch >= now).OrderBy(m => m.DateMatch).ToList();
                var matchsPassés = Model.Matchs.Where(m => m.AResultat || m.DateMatch < now).OrderByDescending(m => m.DateMatch).ToList();
            }

            @if (matchsAvenir.Any())
            {
                <h2 class="h5 section-title mb-3"><i class="bi bi-calendar-event me-2"></i>Prochains matchs</h2>
                <div class="row g-3 mb-4">
                    @foreach (var m in matchsAvenir)
                    {
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100" style="border-left:4px solid var(--couleur-secondaire) !important;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            @{
                                                var fAdvLogo = m.AdversaireId.HasValue && Model.AdversaireLogos.TryGetValue(m.AdversaireId.Value, out var fLp) ? fLp : null;
                                            }
                                            <div class="fw-bold fs-5 d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(fAdvLogo))
                                                {
                                                    <img src="@fAdvLogo" alt="" style="width:36px;height:36px;object-fit:contain;" />
                                                }
                                                @m.Adversaire
                                            </div>
                                            <div class="text-muted small">
                                                <i class="bi bi-calendar3 me-1"></i>@m.DateMatch.ToString("dddd d MMMM yyyy", frCA)
                                                @if (!string.IsNullOrEmpty(m.HeureDebutMatch))
                                                { <span class="ms-2"><i class="bi bi-clock me-1"></i>@m.HeureDebutMatch</span> }
                                            </div>
                                            @if (!string.IsNullOrEmpty(m.Lieu))
                                            { <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@m.Lieu</div> }
                                        </div>
                                        <span class="badge @(m.EstDomicile ? "bg-success" : "bg-secondary")">
                                            @(m.EstDomicile ? "Domicile" : "Extérieur")
                                        </span>
                                    </div>
                                    @if (!m.EstDomicile && (!string.IsNullOrEmpty(m.HeureDepartAutobus) || !string.IsNullOrEmpty(m.HeureArriveeVestiaire)))
                                    {
                                        <hr class="my-2" />
                                        <div class="small text-muted d-flex gap-3 flex-wrap">
                                            @if (!string.IsNullOrEmpty(m.HeureArriveeVestiaire))
                                            { <span><i class="bi bi-door-open me-1"></i>Vestiaire @m.HeureArriveeVestiaire</span> }
                                            @if (!string.IsNullOrEmpty(m.HeureDepartAutobus))
                                            { <span><i class="bi bi-bus-front me-1"></i>Autobus @m.HeureDepartAutobus</span> }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (matchsPassés.Any())
            {
                <h2 class="h5 section-title mb-3"><i class="bi bi-clock-history me-2"></i>Résultats</h2>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Adversaire</th>
                                <th class="d-none d-md-table-cell">Lieu</th>
                                <th class="text-center">Résultat</th>
                                <th class="text-center"><i class="bi bi-camera me-1"></i><i class="bi bi-camera-video"></i></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in matchsPassés)
                            {
                                var allMedia = Model.MatchesMedias.TryGetValue(m.Id, out var meds) ? meds : new List<MatchMedia>();
                                var photoCount = allMedia.Count(mm => mm.TypeMedia == TypeMedia.Photo);
                                var videoCount = allMedia.Count(mm => mm.TypeMedia == TypeMedia.Video);
                                var hasMedia = photoCount > 0 || videoCount > 0;
                                <tr class="@(hasMedia ? "match-row-galerie" : "")"
                                    data-match-id="@m.Id"
                                    style="@(hasMedia ? "cursor:pointer;" : "")"
                                    title="@(hasMedia ? "Voir photos / vidéos" : "")">
                                    <td class="text-nowrap small">@m.DateMatch.ToString("d MMM yyyy", frCA)</td>
                                    <td>
                                        @{
                                            var pAdvLogo = m.AdversaireId.HasValue && Model.AdversaireLogos.TryGetValue(m.AdversaireId.Value, out var pLp) ? pLp : null;
                                        }
                                        <span class="fw-semibold d-inline-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(pAdvLogo))
                                            {
                                                <img src="@pAdvLogo" alt="" style="width:24px;height:24px;object-fit:contain;" />
                                            }
                                            @m.Adversaire
                                        </span>
                                        @if (m.EstDomicile)
                                        { <span class="badge bg-info text-dark ms-1 small">Domicile</span> }
                                    </td>
                                    <td class="text-muted small d-none d-md-table-cell">@m.Lieu</td>
                                    <td class="text-center">
                                        @if (m.AResultat)
                                        {
                                            var cls = m.Resultat switch { "V" => "bg-success", "D" => "bg-danger", _ => "bg-secondary" };
                                            <span class="badge @cls me-1">@m.Resultat</span>
                                            <span class="fw-semibold">@m.ScoreEquipe – @m.ScoreAdversaire</span>
                                        }
                                        else
                                        { <span class="text-muted small">—</span> }
                                    </td>
                                    <td class="text-center">
                                        @if (photoCount > 0)
                                        {
                                            <span class="badge rounded-pill me-1" style="background-color:var(--couleur-secondaire);">
                                                <i class="bi bi-camera me-1"></i>@photoCount
                                            </span>
                                        }
                                        @if (videoCount > 0)
                                        {
                                            <span class="badge rounded-pill bg-danger">
                                                <i class="bi bi-camera-video me-1"></i>@videoCount
                                            </span>
                                        }
                                        @if (!hasMedia)
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Galerie dynamique *@
                <div id="galerieSection" class="mt-3" style="display:none;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h3 class="h6 section-title mb-0" id="galerieTitre"></h3>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="fermerGalerie()">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                    <div class="row g-2" id="galeriePhotos"></div>
                </div>
            }

            @if (!Model.Matchs.Any())
            {
                <p class="text-muted text-center py-4">Aucun match au calendrier.</p>
            }

        </div>

        @* ── Onglet Calendrier ───────────────────────────────────────────────── *@
        <div class="tab-pane fade" id="tab-calendrier">
            @{
                var pubCalItems = new List<(DateTime Date, DateTime? DateFin, string Titre, string SousTexte, string Lieu, string IconClass, string IconColor, string Heure, string HeureArrivee, string HeureDepart, bool EstMatch, string? AdvLogo)>();
                foreach (var m in Model.Matchs)
                {
                    var resultColor = m.AResultat ? (m.Resultat switch { "V" => "#198754", "D" => "#dc3545", _ => "#6c757d" }) : "#6c757d";
                    var adversaire = m.Adversaire;
                    var sous = m.AResultat ? $"{m.ScoreEquipe}\u2013{m.ScoreAdversaire}" : (m.EstDomicile ? "Domicile" : "Extérieur");
                    var heure = m.HeureDebutMatch ?? "";
                    var pcLogo = m.AdversaireId.HasValue && Model.AdversaireLogos.TryGetValue(m.AdversaireId.Value, out var pcLp) ? pcLp : null;
                    pubCalItems.Add((m.DateMatch, null, adversaire, sous, m.Lieu ?? "", "bi-flag-fill", resultColor, heure, m.HeureArriveeVestiaire ?? "", m.HeureDepartAutobus ?? "", true, pcLogo));
                }
                foreach (var ev in Model.Evenements)
                {
                    var (icon, color) = ev.Type switch
                    {
                        TypeEvenement.Pratique => ("bi-stopwatch-fill", "#0d6efd"),
                        TypeEvenement.ReunionParents => ("bi-people-fill", "#6f42c1"),
                        TypeEvenement.Tournoi => ("bi-trophy-fill", "#ffc107"),
                        TypeEvenement.Jamboree => ("bi-flag-fill", "#20c997"),
                        TypeEvenement.Evaluation => ("bi-clipboard-check-fill", "#fd7e14"),
                        TypeEvenement.ActiviteEquipe => ("bi-star-fill", "#198754"),
                        _ => ("bi-calendar-event", "#6c757d")
                    };
                    var typeLabel = ev.Type switch
                    {
                        TypeEvenement.Pratique => "Pratique",
                        TypeEvenement.ReunionParents => "Réunion de parents",
                        TypeEvenement.Tournoi => "Tournoi",
                        TypeEvenement.Jamboree => "Jamborée",
                        TypeEvenement.Evaluation => "Évaluation / Tryout",
                        TypeEvenement.ActiviteEquipe => "Activité d'équipe",
                        _ => "Autre"
                    };
                    var heure = ev.DateDebut.ToString("HH:mm");
                    pubCalItems.Add((ev.DateDebut, ev.DateFin, ev.Titre, typeLabel, ev.Lieu ?? "", icon, color, heure, "", "", false, null));
                }
                var pubGrouped = pubCalItems.OrderBy(x => x.Date).GroupBy(x => new DateTime(x.Date.Year, x.Date.Month, 1)).ToList();
            }

            @* Toggle liste / grille *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 section-title mb-0"><i class="bi bi-calendar3 me-2"></i>Calendrier</h2>
                <div class="btn-group btn-group-sm" role="group" id="calViewToggle">
                    <button type="button" class="btn btn-outline-secondary" id="btnListe">
                        <i class="bi bi-list-ul me-1"></i>Liste
                    </button>
                    <button type="button" class="btn btn-outline-secondary active" id="btnGrille">
                        <i class="bi bi-grid-3x3-gap me-1"></i>Calendrier
                    </button>
                </div>
            </div>

            @* ── Vue Liste ──────────────────────────────────────────────── *@
            <div id="calVueListe" style="display:none;">
                @if (!pubCalItems.Any())
                {
                    <p class="text-muted text-center py-4"><i class="bi bi-calendar-x me-2"></i>Aucun événement au calendrier.</p>
                }
                else
                {
                    @foreach (var grp in pubGrouped)
                    {
                        <div class="mb-4">
                            <h3 class="h6 text-uppercase fw-bold text-muted mb-2">@grp.Key.ToString("MMMM yyyy", frCA)</h3>
                            <div class="list-group shadow-sm">
                                @foreach (var item in grp)
                                {
                                    <div class="list-group-item border-0 py-3">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="text-center flex-shrink-0" style="min-width:42px;">
                                                <div class="fw-bold fs-4 lh-1" style="color:var(--couleur-primaire);">@item.Date.Day</div>
                                                <div class="text-muted" style="font-size:.68rem;text-transform:uppercase;">@item.Date.ToString("ddd", frCA)</div>
                                            </div>
                                            <div style="width:3px;border-radius:2px;background:@item.IconColor;align-self:stretch;flex-shrink:0;"></div>
                                            <div class="flex-grow-1">
                                                <div class="d-flex align-items-center gap-2 fw-semibold small">
                                                    @if (!string.IsNullOrEmpty(item.AdvLogo))
                                                    {
                                                        <img src="@item.AdvLogo" alt="" style="width:22px;height:22px;object-fit:contain;flex-shrink:0;" />
                                                    }
                                                    else
                                                    {
                                                        <i class="bi @item.IconClass text-muted"></i>
                                                    }
                                                    @item.Titre
                                                </div>
                                                <div class="small text-muted">@item.SousTexte</div>
                                                @if (!string.IsNullOrEmpty(item.Lieu))
                                                {
                                                    <div class="small text-muted mt-1"><i class="bi bi-geo-alt me-1"></i>@item.Lieu</div>
                                                }
                                                @if (!string.IsNullOrEmpty(item.HeureArrivee) || !string.IsNullOrEmpty(item.HeureDepart) || !string.IsNullOrEmpty(item.Heure))
                                                {
                                                    <div class="d-flex flex-wrap gap-3 mt-1">
                                                        @if (!string.IsNullOrEmpty(item.HeureArrivee))
                                                        {
                                                            <span class="small text-muted"><i class="bi bi-door-open me-1"></i>Vestiaire <strong>@item.HeureArrivee</strong></span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(item.HeureDepart))
                                                        {
                                                            <span class="small text-muted"><i class="bi bi-bus-front me-1"></i>Autobus <strong>@item.HeureDepart</strong></span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(item.Heure))
                                                        {
                                                            <span class="small text-muted"><i class="bi bi-play-circle me-1"></i>Début du match <strong>@item.Heure@(item.DateFin.HasValue ? " – " + item.DateFin.Value.ToString("HH:mm") : "")</strong></span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            @* ── Vue Grille ─────────────────────────────────────────────── *@
            <div id="calVueGrille">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <button type="button" id="calPrevMois" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span id="calMoisTitre" class="fw-bold fs-5"></span>
                    <button type="button" id="calNextMois" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
                <div id="calGrille"></div>
            </div>
        </div>

        @* ── Onglet Entraineurs ───────────────────────────────────────────────── *@
        @if (Model.Staff.Any())
        {
            <div class="tab-pane fade" id="tab-coachs">
                <div class="row g-2">
                    @foreach (var s in Model.Staff.OrderBy(s => s.Titre).ThenBy(s => s.Nom))
                    {
                        <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                            <div class="mini-staff-card staff-card"
                                 data-fullnom="@s.Prenom @s.Nom"
                                 data-photo="@s.PhotoPath"
                                 data-titre="@s.Titre"
                                 data-description="@s.Description">
                                @if (!string.IsNullOrEmpty(s.PhotoPath))
                                {
                                    <img src="@s.PhotoPath" alt="@s.Prenom @s.Nom" class="mini-photo" />
                                }
                                else
                                {
                                    <div class="mini-no-photo">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                }
                                <div class="mini-gradient"></div>
                                <div class="mini-info">
                                    <div class="mini-nom">@s.Prenom @s.Nom</div>
                                    <div class="mini-pos">@s.Titre</div>
                                </div>
                                <div class="mini-bande"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Onglet Joueurs ─────────────────────────────────────────────────── *@
        @if (Model.Joueurs.Any())
        {
            <div class="tab-pane fade" id="tab-joueurs">
                @* Barre de recherche *@
                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="rechercheJoueur" class="form-control border-start-0"
                               placeholder="Rechercher par nom, prénom ou numéro..." />
                    </div>
                </div>

                @* Joueurs groupés par position principale — chaque joueur apparaît une seule fois *@
                @{
                    var groupesPosition = Model.Joueurs
                        .GroupBy(j => j.Position)
                        .OrderBy(g => g.Key)
                        .Select(g => new { Key = g.Key, Items = g.OrderBy(j => j.Numero).ToList() })
                        .ToList();
                }
                @foreach (var groupe in groupesPosition)
                {
                    <div class="position-group mb-4" data-position="@groupe.Key.ToLower()">
                        <h3 class="h6 section-title text-uppercase fw-bold mb-3">
                            @groupe.Key
                            <span class="badge bg-secondary ms-1 text-lowercase fw-normal">@groupe.Items.Count</span>
                        </h3>
                        <div class="row g-2">
                            @foreach (var j in groupe.Items)
                            {
                                <div class="col-6 col-sm-4 col-md-3 col-lg-2 joueur-card"
                                     data-nom="@(j.Joueur?.Nom ?? "").ToLower()"
                                     data-prenom="@(j.Joueur?.Prenom ?? "").ToLower()"
                                     data-numero="@j.Numero.ToLower()"
                                     data-fullnom="@j.Joueur?.Prenom @j.Joueur?.Nom"
                                     data-photo="@j.PhotoPath"
                                     data-position="@j.Position"
                                     data-pairs="@j.PositionSpecifique"
                                     data-description="@j.Description"
                                     data-joueur-id="@j.JoueurId"
                                     data-nofiche="@j.Joueur?.NoFiche"
                                     data-consentement="@(j.Joueur?.ConsentementPhoto.ToString().ToLower() ?? "true")"
                                     style="cursor:pointer;">
                                    <div class="mini-trading-card">
                                        @{
                                            var photoMini = (string?)null;
                                            if (j.Joueur?.ConsentementPhoto == true)
                                            {
                                                if (!string.IsNullOrEmpty(j.PhotoPath))
                                                    photoMini = j.PhotoPath;
                                                else if (Model.JoueurMedias.TryGetValue(j.JoueurId, out var mediasJMini))
                                                    photoMini = mediasJMini.OrderByDescending(m => m.DateAjout).FirstOrDefault()?.CheminFichier;
                                            }
                                        }
                                        @if (photoMini != null)
                                        {
                                            <img src="@photoMini" alt="@j.Joueur?.Prenom @j.Joueur?.Nom" class="mini-photo" />
                                        }
                                        else if (!string.IsNullOrEmpty(Model.LogoPath))
                                        {
                                            <img src="@Model.LogoPath" alt="Logo" class="mini-photo" style="opacity:.45;object-fit:contain;padding:12px;" />
                                        }
                                        else
                                        {
                                            <div class="mini-no-photo">#@j.Numero</div>
                                        }
                                        <div class="mini-gradient"></div>
                                        <div class="mini-numero">#@j.Numero</div>
                                        <div class="mini-info">
                                            <div class="mini-nom">@j.Joueur?.Prenom @j.Joueur?.Nom</div>
                                            <div class="mini-pos">
                                                @{
                                                    var firstPair = j.PositionPairs.FirstOrDefault();
                                                    var labelPos = firstPair != default ? (string.IsNullOrEmpty(firstPair.Spec) ? firstPair.Pos : firstPair.Spec) : j.Position;
                                                    var extraCount = j.PositionPairs.Count - 1;
                                                }
                                                @if (!string.IsNullOrEmpty(labelPos))
                                                {
                                                    <span class="mini-pos-badge">@labelPos</span>
                                                }
                                                @if (extraCount > 0)
                                                {
                                                    <span class="mini-pos-more">+@extraCount</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="mini-bande"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <p id="aucunResultat" class="text-muted text-center py-3" style="display:none;">
                    Aucun joueur trouvé.
                </p>
            </div>
        }

    </div>
</div>

@* ── Données JSON pour galeries ───────────────────────────────────────────── *@
@{
    var galeriesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.MatchesMedias.ToDictionary(
            kvp => kvp.Key.ToString(),
            kvp => kvp.Value.Select(p => new {
                chemin = p.CheminFichier,
                description = p.Description ?? "",
                type = p.TypeMedia == GestionEquipeSportive.Models.TypeMedia.Video ? "video" : "photo"
            }).ToList()
        )
    );
    var titresJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Matchs
            .Where(m => m.AResultat)
            .ToDictionary(
                m => m.Id.ToString(),
                m => m.Adversaire + " \u2014 " + m.DateMatch.ToString("d MMM yyyy", frCA)
            )
    );
}
<script id="galeries-json" type="application/json">@Html.Raw(galeriesJson)</script>
<script id="titres-json" type="application/json">@Html.Raw(titresJson)</script>
@{
    var joueurPhotosJson = System.Text.Json.JsonSerializer.Serialize(
        Model.JoueurMedias.ToDictionary(
            kvp => kvp.Key.ToString(),
            kvp => kvp.Value.Select(p => new { chemin = p.CheminFichier, description = p.Description ?? "" }).ToList()
        )
    );
}
<script id="joueur-photos-json" type="application/json">@Html.Raw(joueurPhotosJson)</script>
@{
    var statsJoueursJson = System.Text.Json.JsonSerializer.Serialize(
