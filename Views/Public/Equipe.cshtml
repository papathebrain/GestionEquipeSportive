@* ── Lightbox galerie ─────────────────────────────────────────────────────── *@
<div id="lightbox" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.92);align-items:center;justify-content:center;touch-action:pan-y;">
    <button id="lbClose" style="position:absolute;top:18px;right:22px;background:none;border:none;color:#fff;font-size:2rem;cursor:pointer;z-index:2;">&#x2715;</button>
    @if (!string.IsNullOrEmpty(Model.LogoPath))
    {
        <img src="@Model.LogoPath" alt="Logo"
             style="position:absolute;top:14px;right:65px;height:100px;object-fit:contain;opacity:.85;pointer-events:none;z-index:2;filter:drop-shadow(0 2px 8px rgba(0,0,0,.7));" />
    }
    <button id="lbPrev" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.12);border:none;color:#fff;font-size:2.5rem;width:48px;height:64px;border-radius:8px;cursor:pointer;">&#8249;</button>
    <button id="lbNext" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.12);border:none;color:#fff;font-size:2.5rem;width:48px;height:64px;border-radius:8px;cursor:pointer;">&#8250;</button>
    <img id="lbImg" src="" alt="" style="max-width:92vw;max-height:88vh;border-radius:6px;object-fit:contain;user-select:none;display:block;" />
    <div id="lbCounter" style="position:absolute;bottom:18px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.65);font-size:.9rem;"></div>
</div>

@section Scripts {
<script>
    // ── Musique bannière (prochain match) ────────────────────────────────────
    (function () {
        if (!document.getElementById('pubBanniere')) return;
        var url   = '@Html.Raw(Model.Theme?.MusiqueProchainMatchPath ?? "")';
        if (!url) url = "/music/Les Aigles de l\u2019Amiti\u00e9.mp3";
        var DEBUT = @(Model.Theme?.MusiqueProchainMatchDebut ?? 0);
        var DUREE = @(Model.Theme?.MusiqueProchainMatchDuree ?? 10);
        var FADE  = 2;

        var audio = new Audio(url);
        audio.loop   = false;
        audio.volume = 0.72;

        function demarrerFade() {
            var steps    = 40;
            var interval = (FADE * 1000) / steps;
            var decrement = audio.volume / steps;
            var fadeTimer = setInterval(function () {
                if (audio.volume > decrement) {
                    audio.volume = Math.max(0, audio.volume - decrement);
                } else {
                    audio.volume = 0;
                    audio.pause();
                    clearInterval(fadeTimer);
                }
            }, interval);
        }

        function jouer() {
            audio.currentTime = DEBUT;
            audio.play().then(function () {
                setTimeout(demarrerFade, Math.max(0, DUREE - FADE) * 1000);
            }).catch(function(){});
        }

        setTimeout(jouer, 100);
        var done = false;
        function tentative() { if (done) return; done = true; jouer(); }
        document.addEventListener('click',      tentative, { once: true });
        document.addEventListener('touchstart', tentative, { once: true });
    })();

    // ── Effets de choc bannière ───────────────────────────────────────────────
    (function () {
        var banner = document.getElementById('pubBanniere');
        if (!banner) return;

        // Moments de choc calés sur les keyframes (ms)
        var chocs = [
            { t: 1200, big: false },   // choc 1
            { t: 2600, big: false },   // choc 2
            { t: 4000, big: true  }    // choc final + VS
        ];

        function spark(big) {
            var n = big ? 14 : 7;
            for (var i = 0; i < n; i++) {
                var el = document.createElement('div');
                var angle = Math.random() * 360;
                var dist  = big ? (55 + Math.random() * 90) : (25 + Math.random() * 55);
                var size  = big ? (3 + Math.random() * 6)   : (2 + Math.random() * 4);
                var col   = Math.random() > .4 ? '#fff' : '@Html.Raw(Model.CouleurSecondaire)';
                el.style.cssText =
                    'position:absolute;top:50%;left:50%;width:' + size + 'px;height:' + size + 'px;' +
                    'border-radius:50%;background:' + col + ';pointer-events:none;z-index:16;' +
                    '--a:' + angle + 'deg;--d:' + dist + 'px;' +
                    'animation:pubSparkFly ' + (.38 + Math.random()*.25) + 's ease-out forwards;';
                banner.appendChild(el);
                setTimeout(function(e){ if(e.parentNode) e.parentNode.removeChild(e); }, 700, el);
            }
        }

        function flash() {
            var el = document.createElement('div');
            el.className = 'pub-clash-flash';
            banner.appendChild(el);
            setTimeout(function(e){ if(e.parentNode) e.parentNode.removeChild(e); }, 350, el);
        }

        function shake(inner) {
            inner.style.animation = 'none';
            inner.offsetHeight; // reflow
            inner.style.animation = 'pubShakeEl .35s ease both';
            setTimeout(function(){ inner.style.animation = ''; }, 400);
        }

        var inner = banner.querySelector('.pub-inner');
        chocs.forEach(function(c) {
            setTimeout(function() {
                flash();
                spark(c.big);
                if (inner) shake(inner);
            }, c.t);
        });
    })();

    // ── Données JSON ──────────────────────────────────────────────────────────
    var galeriesData     = JSON.parse(document.getElementById('galeries-json').textContent);
    var matchTitres      = JSON.parse(document.getElementById('titres-json').textContent);
    var joueurPhotos     = JSON.parse(document.getElementById('joueur-photos-json').textContent);
    var statsJoueursData = JSON.parse(document.getElementById('stats-joueurs-json').textContent);
    var dernierMatchPhotosId = JSON.parse(document.getElementById('dernier-match-photos-id').textContent);
    var logoEcole  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LogoPath ?? ""));
    var nomEquipe  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Equipe.Nom));

    // ── Galerie matchs ────────────────────────────────────────────────────────
    var matchActif = null;
    var galeriePhotosActuelles = [];

    function afficherGalerie(matchId, row) {
        var allMedia = galeriesData[matchId];
        if (!allMedia || allMedia.length === 0) return;
        document.querySelectorAll('.match-row-galerie').forEach(function(r) { r.classList.remove('table-active'); });
        if (row) row.classList.add('table-active');
        document.getElementById('galerieTitre').innerHTML = '<i class="bi bi-images me-2"></i>' + (matchTitres[matchId] || '');

        var photos = allMedia.filter(function(m) { return m.type !== 'video'; });
        var videos = allMedia.filter(function(m) { return m.type === 'video'; });

        // Garder seulement les photos pour le lightbox
        galeriePhotosActuelles = photos;

        var photoHtml = photos.map(function(p, i) {
            var delay = (i * 55) + 'ms';
            return '<div class="col-6 col-md-3 galerie-item-anim" style="animation-delay:' + delay + ';">'
                 + '<img src="' + p.chemin + '" alt="' + p.description + '" loading="lazy"'
                 + ' class="galerie-img galerie-photo" data-index="' + i + '" />'
                 + '</div>';
        }).join('');

        var videoHtml = '';
        if (videos.length > 0) {
            var baseDelay = photos.length * 55;
            videoHtml = '<div class="col-12 mt-2 galerie-item-anim" style="animation-delay:' + baseDelay + 'ms;">'
                + '<div class="small text-muted mb-2 fw-semibold">'
                + '<i class="bi bi-camera-video me-1"></i>Vidéos (' + videos.length + ')</div></div>'
                + videos.map(function(v, vi) {
                    var vDelay = (baseDelay + (vi + 1) * 55) + 'ms';
                    return '<div class="col-12 col-md-6 galerie-item-anim" style="animation-delay:' + vDelay + ';">'
                        + '<video src="' + v.chemin + '" controls preload="metadata"'
                        + ' class="w-100 rounded shadow-sm" style="max-height:280px;background:#000;">'
                        + '</video>'
                        + (v.description ? '<div class="small text-muted mt-1">' + v.description + '</div>' : '')
                        + '</div>';
                }).join('');
        }

        document.getElementById('galeriePhotos').innerHTML = photoHtml + videoHtml;
        var section = document.getElementById('galerieSection');
        section.style.display = '';
        matchActif = matchId;
    }

    function fermerGalerie() {
        // Pauser toutes les vidéos avant de fermer
        document.querySelectorAll('#galeriePhotos video').forEach(function(v) { v.pause(); });
        document.getElementById('galerieSection').style.display = 'none';
        document.querySelectorAll('.match-row-galerie').forEach(function(r) { r.classList.remove('table-active'); });
        matchActif = null;
    }

    // ── Lightbox ──────────────────────────────────────────────────────────────
    var lbIndex = 0;
    var lbPhotos = [];
    var lb = document.getElementById('lightbox');
    var lbImg = document.getElementById('lbImg');
    var lbCounter = document.getElementById('lbCounter');

    function ouvrirLightbox(photos, index) {
        lbPhotos = photos;
        lbIndex = index;
        lbImg.src = lbPhotos[lbIndex].chemin;
        lbCounter.textContent = (lbIndex + 1) + ' / ' + lbPhotos.length;
        lb.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function fermerLightbox() {
        lb.style.display = 'none';
        document.body.style.overflow = '';
    }
    function lbNaviguer(delta) {
        lbIndex = (lbIndex + delta + lbPhotos.length) % lbPhotos.length;
        lbImg.src = lbPhotos[lbIndex].chemin;
        lbCounter.textContent = (lbIndex + 1) + ' / ' + lbPhotos.length;
    }
    document.getElementById('lbClose').addEventListener('click', fermerLightbox);
    document.getElementById('lbPrev').addEventListener('click', function() { lbNaviguer(-1); });
    document.getElementById('lbNext').addEventListener('click', function() { lbNaviguer(1); });
    lb.addEventListener('click', function(e) { if (e.target === lb) fermerLightbox(); });
    document.addEventListener('keydown', function(e) {
        if (lb.style.display === 'none') return;
        if (e.key === 'Escape') fermerLightbox();
        if (e.key === 'ArrowLeft') lbNaviguer(-1);
        if (e.key === 'ArrowRight') lbNaviguer(1);
    });
    // Swipe tactile
    var lbTouchStartX = 0;
    lb.addEventListener('touchstart', function(e) { lbTouchStartX = e.changedTouches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - lbTouchStartX;
        if (Math.abs(dx) > 50) lbNaviguer(dx < 0 ? 1 : -1);
    }, { passive: true });

    // ── Carte MUT joueur ──────────────────────────────────────────────────────
    var mutPhotos = [];
    var mutPhotoIdx = 0;

    function mutRenderPhotos(logoSrc) {
        var container = document.getElementById('mutImageContainer');
        container.querySelectorAll('img.mut-photo-img').forEach(function(i){ i.remove(); });
        container.querySelectorAll('.mut-no-photo').forEach(function(d){ d.remove(); });
        var overlay = container.querySelector('.mut-overlay');

        if (!mutPhotos.length) {
            var ph = document.createElement('div');
            ph.className = 'mut-no-photo';
            if (logoSrc) {
                var logoImg = document.createElement('img');
                logoImg.src = logoSrc;
                logoImg.style.cssText = 'width:180px;height:180px;object-fit:contain;opacity:.85;pointer-events:none;user-select:none;';
                ph.appendChild(logoImg);
            }
            container.insertBefore(ph, overlay);
            document.getElementById('mutPrev').style.display = 'none';
            document.getElementById('mutNext').style.display = 'none';
            return;
        }

        mutPhotos.forEach(function(src, i) {
            var img = document.createElement('img');
            img.src = src;
            img.className = 'mut-photo-img' + (i === mutPhotoIdx ? ' active' : '');
            container.insertBefore(img, overlay);
        });
        var multi = mutPhotos.length > 1;
        document.getElementById('mutPrev').style.display = multi ? '' : 'none';
        document.getElementById('mutNext').style.display = multi ? '' : 'none';
    }

    function mutNavPhoto(delta) {
        var imgs = document.getElementById('mutImageContainer').querySelectorAll('img.mut-photo-img');
        if (!imgs.length) return;
        imgs[mutPhotoIdx].classList.remove('active');
        mutPhotoIdx = (mutPhotoIdx + delta + imgs.length) % imgs.length;
        imgs[mutPhotoIdx].classList.add('active');
    }

    function parsePairs(raw) {
        // "Attaque|QB,Défense|Defensive Tackle" → [{pos,spec}, ...]
        if (!raw) return [];
        return raw.split(',').map(function(p) {
            var parts = p.split('|');
            return { pos: parts[0] ? parts[0].trim() : '', spec: parts[1] ? parts[1].trim() : '' };
        }).filter(function(p){ return p.pos; });
    }

    function ouvrirJoueur(el) {
        var joueurId     = el.dataset.joueurId || '';
        var nom          = el.dataset.fullnom  || '';
        var numero       = el.dataset.numero   || '';
        var photo        = el.dataset.photo    || '';
        var position     = el.dataset.position || '';
        var pairsRaw     = el.dataset.pairs    || '';
        var desc         = el.dataset.description || '';
        var consentement = el.dataset.consentement !== 'false';
        var pairs        = parsePairs(pairsRaw);

        // Construire la liste de photos
        var extras = joueurPhotos[joueurId] || [];
        mutPhotos = [];
        mutPhotoIdx = 0;
        if (consentement) {
            if (photo) mutPhotos.push(photo);
            extras.forEach(function(p){ if (p.chemin) mutPhotos.push(p.chemin); });
        }

        // Reset flip → recto
        document.getElementById('mutFlipInner').classList.remove('flipped');

        // Rating interne
        document.getElementById('mutRating').textContent = numero;

        // Logo à droite du nom (recto)
        document.getElementById('mutLogoWrap').innerHTML = '';
        var nameLogo = document.getElementById('mutNameLogo');
        if (logoEcole) {
            nameLogo.innerHTML = '<img class="mut-name-logo" src="' + logoEcole + '" alt="">';
        } else {
            nameLogo.innerHTML = '<div class="mut-name-logo-placeholder"><i class="bi bi-shield-fill"></i></div>';
        }

        // Recto — nom, position principale + indicateur, numéro
        document.getElementById('mutName').textContent = nom;
        var posEl = document.getElementById('mutPosition');
        posEl.innerHTML = '';
        var firstPair = pairs.length ? pairs[0] : null;
        var mainLabel = firstPair ? (firstPair.spec || firstPair.pos) : position;
        if (mainLabel) {
            var pill = document.createElement('span');
            pill.className = 'mut-pos-pill';
            pill.textContent = mainLabel;
            posEl.appendChild(pill);
        }
        if (pairs.length > 1) {
            var more = document.createElement('span');
            more.className = 'mut-pos-more';
            more.textContent = '+' + (pairs.length - 1);
            posEl.appendChild(more);
        }
        document.getElementById('mutNumber').textContent = numero ? '#' + numero : '';

        // Recto — stats
        var statsEl = document.getElementById('mutStats');
        var sj = statsJoueursData[joueurId];
        if (sj && sj.matchsJoues > 0) {
            var presences = sj.matchsJoues - sj.absences;
            statsEl.innerHTML =
                '<div class="mut-stat">Joués<span>' + sj.matchsJoues + '</span></div>'
              + '<div class="mut-stat">Présences<span>' + presences + '</span></div>'
              + '<div class="mut-stat">Absences<span>' + sj.absences + '</span></div>';
        } else {
            statsEl.innerHTML = '';
        }

        // Verso — avatar
        var avatarEl = document.getElementById('mutBackAvatar');
        if (consentement && (photo || mutPhotos.length)) {
            var avatarSrc = mutPhotos.length ? mutPhotos[0] : photo;
            avatarEl.innerHTML = '<img class="mut-back-avatar" src="' + avatarSrc + '" alt="">';
        } else if (logoEcole) {
            avatarEl.innerHTML = '<img class="mut-back-avatar" src="' + logoEcole + '" alt="" style="object-fit:contain;background:rgba(255,255,255,.1);padding:8px;">';
        } else {
            avatarEl.innerHTML = '<div class="mut-back-avatar-ph"><i class="bi bi-person-fill"></i></div>';
        }

        // Verso — nom + badges
        document.getElementById('mutBackNom').textContent = nom;
        var badgesEl = document.getElementById('mutBackBadges');
        badgesEl.innerHTML = '';
        if (numero) badgesEl.innerHTML += '<span class="badge bg-dark" style="font-size:.7rem;">#' + numero + '</span>';

        // Verso — liste complète des positions
        var posWrap = document.getElementById('mutBackPositionsWrap');
        var posListEl = document.getElementById('mutBackPositions');
        if (pairs.length) {
            // Grouper par position parente
            var grouped = {};
            pairs.forEach(function(p) {
                if (!grouped[p.pos]) grouped[p.pos] = [];
                if (p.spec) grouped[p.pos].push(p.spec);
            });
            var html = '';
            Object.keys(grouped).forEach(function(pos) {
                html += '<div style="color:rgba(255,255,255,.9);font-weight:700;margin-bottom:2px;">' + pos + '</div>';
                grouped[pos].forEach(function(spec) {
                    html += '<div style="color:rgba(255,255,255,.6);padding-left:10px;margin-bottom:1px;">— ' + spec + '</div>';
                });
            });
            posListEl.innerHTML = html;
            posWrap.style.display = '';
        } else if (position) {
            posListEl.innerHTML = '<div style="color:rgba(255,255,255,.9);font-weight:700;">' + position + '</div>';
            posWrap.style.display = '';
        } else {
            posWrap.style.display = 'none';
        }

        // Verso — stats tableau
        var backStats = document.getElementById('mutBackStats');
        backStats.innerHTML = '';
        if (sj && sj.matchsJoues > 0) {
            var pr = sj.matchsJoues - sj.absences;
            backStats.innerHTML =
                '<tr><td>Matchs joués</td><td>' + sj.matchsJoues + '</td></tr>'
              + '<tr><td>Présences</td><td>' + pr + '</td></tr>'
              + '<tr><td>Absences</td><td>' + sj.absences + '</td></tr>';
        }

        // Verso — description
        var descWrap = document.getElementById('mutBackDescWrap');
        if (desc) {
            document.getElementById('mutBackDesc').textContent = desc;
            descWrap.style.display = '';
        } else {
            descWrap.style.display = 'none';
        }

        // Photos recto (passe le logo si pas de consentement)
        mutRenderPhotos(!mutPhotos.length ? logoEcole : null);

        new bootstrap.Modal(document.getElementById('modalJoueur')).show();
    }

    // ── Flip card handlers ────────────────────────────────────────────────────
    document.getElementById('mutBtnFlip').addEventListener('click', function() {
        document.getElementById('mutFlipInner').classList.add('flipped');
    });
    document.getElementById('mutBtnUnflip').addEventListener('click', function() {
        document.getElementById('mutFlipInner').classList.remove('flipped');
    });

    // ── Carte entraineur (MUT, pas de flip) ──────────────────────────────────
    function ouvrirStaff(el) {
        var nom   = el.dataset.fullnom     || '';
        var photo = el.dataset.photo       || '';
        var titre = el.dataset.titre       || '';
        var desc  = el.dataset.description || '';

        // Zone photo
        var container = document.getElementById('staffImageContainer');
        container.querySelectorAll('img.mut-photo-img, .mut-no-photo').forEach(function(n){ n.remove(); });
        var overlay = container.querySelector('.mut-overlay');
        if (photo) {
            var img = document.createElement('img');
            img.src = photo; img.className = 'mut-photo-img active';
            container.insertBefore(img, overlay);
        } else {
            var ph = document.createElement('div');
            ph.className = 'mut-no-photo';
            if (logoEcole) {
                var li = document.createElement('img');
                li.src = logoEcole;
                li.style.cssText = 'width:80px;height:80px;object-fit:contain;opacity:.75;filter:drop-shadow(0 4px 14px rgba(0,0,0,.5));';
                ph.appendChild(li);
            }
            container.insertBefore(ph, overlay);
        }

        // Nom + logo
        document.getElementById('staffMutName').textContent = nom;
        var logoEl = document.getElementById('staffMutLogo');
        if (logoEcole) {
            logoEl.innerHTML = '<img class="mut-name-logo" src="' + logoEcole + '" alt="">';
        } else {
            logoEl.innerHTML = '<div class="mut-name-logo-placeholder"><i class="bi bi-shield-fill"></i></div>';
        }

        // Titre
        document.getElementById('staffMutTitre').textContent = titre;

        // Description
        var respoWrap = document.getElementById('staffMutRespoWrap');
        if (desc) {
            document.getElementById('staffMutRespo').textContent = desc;
            respoWrap.style.display = '';
        } else {
            respoWrap.style.display = 'none';
        }

        new bootstrap.Modal(document.getElementById('modalStaff')).show();
    }

    // ── Event delegation ──────────────────────────────────────────────────────
    document.addEventListener('click', function(e) {
        if (e.target.closest('#mutPrev') || e.target.closest('#mutNext')) return; // géré en inline
        var lbTrigger = e.target.closest('.galerie-photo');
        if (lbTrigger) { ouvrirLightbox(galeriePhotosActuelles, parseInt(lbTrigger.dataset.index, 10)); return; }
        var joueurCard = e.target.closest('.joueur-card');
        if (joueurCard) { ouvrirJoueur(joueurCard); return; }
        var staffCard = e.target.closest('.staff-card');
        if (staffCard) { ouvrirStaff(staffCard); return; }
        var matchRow = e.target.closest('.match-row-galerie');
        if (matchRow) afficherGalerie(matchRow.dataset.matchId, matchRow);
    });

    // ── Sélection auto galerie du dernier match avec photos ───────────────────
    function initAutoGalerie() {
        if (dernierMatchPhotosId !== null) {
            var row = document.querySelector('.match-row-galerie[data-match-id="' + dernierMatchPhotosId + '"]');
            afficherGalerie(String(dernierMatchPhotosId), row);
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAutoGalerie);
    } else {
        initAutoGalerie();
    }

    // ── Calendrier grille ────────────────────────────────────────────────────
    var calEvents = JSON.parse(document.getElementById('cal-events-json').textContent);
    var calMois   = new Date(); calMois.setDate(1); calMois.setHours(0,0,0,0);
    var moisFR    = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
    var joursAbreges = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];

    function renderCalGrille() {
        var y = calMois.getFullYear(), m = calMois.getMonth();
        document.getElementById('calMoisTitre').textContent = moisFR[m] + ' ' + y;

        var premierJour = new Date(y, m, 1).getDay(); // 0=dim
        var nbJours = new Date(y, m + 1, 0).getDate();
        var aujourd = new Date(); aujourd.setHours(0,0,0,0);

        // Events du mois indexés par jour
        var evtDuMois = {};
        var prefixe = y + '-' + String(m + 1).padStart(2, '0') + '-';
        calEvents.forEach(function(ev) {
            if (ev.date.startsWith(prefixe)) {
                var j = parseInt(ev.date.slice(8, 10), 10);
                if (!evtDuMois[j]) evtDuMois[j] = [];
                evtDuMois[j].push(ev);
            }
        });

        var html = '<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;">';
        // En-têtes jours
        joursAbreges.forEach(function(j) {
            html += '<div class="text-center small fw-bold py-1 text-muted">' + j + '</div>';
        });
        // Cases vides avant le 1er
        for (var i = 0; i < premierJour; i++) html += '<div></div>';
        // Jours du mois
        for (var d = 1; d <= nbJours; d++) {
            var dateD = new Date(y, m, d);
            var isToday = dateD.getTime() === aujourd.getTime();
            var evts = evtDuMois[d] || [];
            var cellBg = isToday ? 'background:rgba(var(--bs-primary-rgb),.07);outline:2px solid var(--couleur-primaire);' : 'background:#f8f9fa;';
            html += '<div style="min-height:130px;border-radius:8px;padding:6px;' + cellBg + '">';
            html += '<div class="fw-bold mb-1 ' + (isToday ? 'text-primary' : 'text-muted') + '" style="font-size:.8rem;">' + d + '</div>';
            evts.forEach(function(ev) {
                // Tooltip
                var tip = ev.titre;
                if (ev.lieu)         tip += '\nLieu : '             + ev.lieu;
                if (ev.heureArrivee) tip += '\nVestiaire : '        + ev.heureArrivee;
                if (ev.heureDepart)  tip += '\nAutobus : '          + ev.heureDepart;
                if (ev.heure)        tip += '\nD\u00e9but du match : ' + ev.heure + (ev.heureFin ? '\u2013' + ev.heureFin : '');

                var logoHtml = ev.logo
                    ? '<img src="' + ev.logo + '" alt="" style="width:16px;height:16px;object-fit:contain;margin-right:4px;vertical-align:middle;" />'
                    : '<i class="bi ' + ev.icon + '" style="color:' + ev.color + ';margin-right:4px;font-size:.75rem;vertical-align:middle;"></i>';
                html += '<div style="background:' + ev.color + '14;border-left:3px solid ' + ev.color + ';border-radius:4px;padding:4px 6px;margin-bottom:4px;font-size:.72rem;line-height:1.4;" title="' + tip.replace(/"/g, '&quot;') + '">'
                    + '<div class="fw-semibold">' + logoHtml + ev.titre.substring(0, 22) + (ev.titre.length > 22 ? '\u2026' : '') + '</div>';
                if (ev.lieu)         html += '<div class="text-muted"><i class="bi bi-geo-alt me-1"></i>' + ev.lieu + '</div>';
                if (ev.heureArrivee) html += '<div class="text-muted"><i class="bi bi-door-open me-1"></i>Vestiaire ' + ev.heureArrivee + '</div>';
                if (ev.heureDepart)  html += '<div class="text-muted"><i class="bi bi-bus-front me-1"></i>Autobus ' + ev.heureDepart + '</div>';
                if (ev.heure)        html += '<div class="text-muted"><i class="bi bi-play-circle me-1"></i>D\u00e9but ' + ev.heure + (ev.heureFin ? '\u2013' + ev.heureFin : '') + '</div>';
                html += '</div>';
            });
            html += '</div>';
        }
        html += '</div>';
        document.getElementById('calGrille').innerHTML = html;
    }

    document.getElementById('btnListe').addEventListener('click', function() {
        document.getElementById('calVueListe').style.display = '';
        document.getElementById('calVueGrille').style.display = 'none';
        this.classList.add('active');
        document.getElementById('btnGrille').classList.remove('active');
    });
    document.getElementById('btnGrille').addEventListener('click', function() {
        document.getElementById('calVueListe').style.display = 'none';
        document.getElementById('calVueGrille').style.display = '';
        this.classList.add('active');
        document.getElementById('btnListe').classList.remove('active');
        renderCalGrille();
    });
    document.getElementById('calPrevMois').addEventListener('click', function() {
        calMois.setMonth(calMois.getMonth() - 1);
        renderCalGrille();
    });
    document.getElementById('calNextMois').addEventListener('click', function() {
        calMois.setMonth(calMois.getMonth() + 1);
        renderCalGrille();
    });

    // Render initial du calendrier
    renderCalGrille();

    // ── Recherche joueurs ─────────────────────────────────────────────────────
    var rechercheEl = document.getElementById('rechercheJoueur');
    if (rechercheEl) rechercheEl.addEventListener('input', function() {
        var q = this.value.toLowerCase().trim(), total = 0;
        document.querySelectorAll('.position-group').forEach(function(grp) {
            var vis = 0;
            grp.querySelectorAll('.joueur-card').forEach(function(c) {
                var show = !q || c.dataset.nom.includes(q) || c.dataset.prenom.includes(q) || c.dataset.numero.includes(q);
                c.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            grp.style.display = vis > 0 ? '' : 'none';
            total += vis;
        });
        document.getElementById('aucunResultat').style.display = total === 0 ? '' : 'none';
    });
</script>
}
