@section Scripts {
<script>
    // ── Données JSON ──────────────────────────────────────────────────────────
    var galeriesData     = JSON.parse(document.getElementById('galeries-json').textContent);
    var matchTitres      = JSON.parse(document.getElementById('titres-json').textContent);
    var joueurPhotos     = JSON.parse(document.getElementById('joueur-photos-json').textContent);
    var statsJoueursData = JSON.parse(document.getElementById('stats-joueurs-json').textContent);
    var dernierMatchPhotosId = JSON.parse(document.getElementById('dernier-match-photos-id').textContent);

    // ── Galerie matchs ────────────────────────────────────────────────────────
    var matchActif = null;
    var galeriePhotosActuelles = [];

    function afficherGalerie(matchId, row) {
        var photos = galeriesData[matchId];
        if (!photos || photos.length === 0) return;
        document.querySelectorAll('.match-row-galerie').forEach(function(r) { r.classList.remove('table-active'); });
        if (row) row.classList.add('table-active');
        document.getElementById('galerieTitre').innerHTML = '<i class="bi bi-images me-2"></i>' + (matchTitres[matchId] || '');
        galeriePhotosActuelles = photos;
        var container = document.getElementById('galeriePhotos');
        container.innerHTML = photos.map(function(p, i) {
            return '<div class="col-6 col-md-3">'
                 + '<img src="' + p.chemin + '" alt="' + p.description + '" class="img-fluid rounded shadow-sm galerie-photo"'
                 + ' data-index="' + i + '"'
                 + ' style="width:100%;height:160px;object-fit:cover;cursor:pointer;" />'
                 + '</div>';
        }).join('');
        var section = document.getElementById('galerieSection');
        section.style.display = '';
        if (matchActif !== matchId) section.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        matchActif = matchId;
    }

    function fermerGalerie() {
        document.getElementById('galerieSection').style.display = 'none';
        document.querySelectorAll('.match-row-galerie').forEach(function(r) { r.classList.remove('table-active'); });
        matchActif = null;
    }

    // ── Lightbox ──────────────────────────────────────────────────────────────
    var lbIndex = 0;
    var lbPhotos = [];
    var lb = document.getElementById('lightbox');
    var lbImg = document.getElementById('lbImg');
    var lbCounter = document.getElementById('lbCounter');

    function ouvrirLightbox(photos, index) {
        lbPhotos = photos;
        lbIndex = index;
        lbImg.src = lbPhotos[lbIndex].chemin;
        lbCounter.textContent = (lbIndex + 1) + ' / ' + lbPhotos.length;
        lb.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function fermerLightbox() {
        lb.style.display = 'none';
        document.body.style.overflow = '';
    }
    function lbNaviguer(delta) {
        lbIndex = (lbIndex + delta + lbPhotos.length) % lbPhotos.length;
        lbImg.src = lbPhotos[lbIndex].chemin;
        lbCounter.textContent = (lbIndex + 1) + ' / ' + lbPhotos.length;
    }
    document.getElementById('lbClose').addEventListener('click', fermerLightbox);
    document.getElementById('lbPrev').addEventListener('click', function() { lbNaviguer(-1); });
    document.getElementById('lbNext').addEventListener('click', function() { lbNaviguer(1); });
    lb.addEventListener('click', function(e) { if (e.target === lb) fermerLightbox(); });
    document.addEventListener('keydown', function(e) {
        if (lb.style.display === 'none') return;
        if (e.key === 'Escape') fermerLightbox();
        if (e.key === 'ArrowLeft') lbNaviguer(-1);
        if (e.key === 'ArrowRight') lbNaviguer(1);
    });
    // Swipe tactile
    var lbTouchStartX = 0;
    lb.addEventListener('touchstart', function(e) { lbTouchStartX = e.changedTouches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - lbTouchStartX;
        if (Math.abs(dx) > 50) lbNaviguer(dx < 0 ? 1 : -1);
    }, { passive: true });

    // ── Carte de trading ──────────────────────────────────────────────────────
    var currentCardPhotos = [];
    var currentPhotoIndex = 0;
    var carouselAutoTimer = null;

    function stopCarouselAuto() {
        if (carouselAutoTimer) { clearInterval(carouselAutoTimer); carouselAutoTimer = null; }
    }
    function startCarouselAuto() {
        stopCarouselAuto();
        if (currentCardPhotos.length < 2) return;
        carouselAutoTimer = setInterval(function() {
            currentPhotoIndex = (currentPhotoIndex + 1) % currentCardPhotos.length;
            renderCarousel(true);
        }, 2500);
    }

    var _carouselInitialized = false;

    function renderCarousel(animate) {
        var track = document.getElementById('cardPhotoTrack');
        var dots  = document.getElementById('carouselDots');
        var prev  = document.getElementById('carouselPrev');
        var next  = document.getElementById('carouselNext');

        // Update dots always
        var multiple = currentCardPhotos.length > 1;
        prev.style.display = next.style.display = multiple ? '' : 'none';
        dots.innerHTML = multiple ? currentCardPhotos.map(function(_, i) {
            return '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;margin:0 3px;background:'
                 + (i === currentPhotoIndex ? '#fff' : 'rgba(255,255,255,.4)') + ';transition:background .2s;"></span>';
        }).join('') : '';

        if (!currentCardPhotos.length) {
            track.innerHTML = '<div style="width:100%;height:100%;background:var(--couleur-primaire);display:flex;align-items:center;justify-content:center;">'
                + '<span style="font-size:7rem;font-weight:900;color:rgba(255,255,255,.18);font-family:Impact,Arial Black,sans-serif;">'
                + document.getElementById('cardFrontNumero').textContent + '</span></div>';
            _carouselInitialized = false;
            return;
        }

        var existingImg = track.querySelector('img.card-photo-img');
        var newSrc = currentCardPhotos[currentPhotoIndex];

        if (!existingImg || !animate) {
            // First render or no animation
            track.innerHTML = '<img src="' + newSrc + '" class="card-photo-img" style="width:100%;height:100%;object-fit:cover;display:block;" alt="">';
            _carouselInitialized = true;
            return;
        }

        // Fade out → swap → fade in
        existingImg.style.opacity = '0';
        setTimeout(function() {
            existingImg.src = newSrc;
            existingImg.style.opacity = '1';
        }, 200);
    }

    function ouvrirJoueur(el) {
        var joueurId    = el.dataset.joueurId || '';
        var nom         = el.dataset.fullnom  || '';
        var numero      = el.dataset.numero   || '';
        var photo       = el.dataset.photo    || '';
        var position    = el.dataset.position || '';
        var posSpec     = el.dataset.positionSpecifique || '';
        var desc        = el.dataset.description || '';
        var consentement = el.dataset.consentement !== 'false';

        var extras = joueurPhotos[joueurId] || [];
        currentCardPhotos = [];
        if (consentement) {
            if (photo) currentCardPhotos.push(photo);
            extras.forEach(function(p) { if (p.chemin) currentCardPhotos.push(p.chemin); });
        }
        currentPhotoIndex = 0;

        // Face avant
        document.getElementById('cardFrontNumero').textContent   = '#' + numero;
        document.getElementById('cardFrontNom').textContent      = nom;
        document.getElementById('cardFrontPosition').textContent = posSpec || position;
        document.getElementById('cardFrontBadge').innerHTML = posSpec
            ? '<span class="badge" style="background-color:var(--couleur-secondaire);font-size:.75rem;">' + posSpec + '</span>' : '';

        // Face arrière — en-tête
        document.getElementById('cardBackNumeroWm').textContent = '#' + numero;
        document.getElementById('cardBackNom').textContent = nom;
        document.getElementById('cardBackAvatar').innerHTML = (consentement && currentCardPhotos.length)
            ? '<img src="' + currentCardPhotos[0] + '" class="rounded-circle" style="width:72px;height:72px;object-fit:cover;border:3px solid rgba(255,255,255,.35);" alt="">'
            : '<div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:72px;height:72px;background:rgba(255,255,255,.15);color:#fff;font-size:1.8rem;"><i class="bi bi-person-fill"></i></div>';
        var badges = document.getElementById('cardBackBadges');
        badges.innerHTML = '';
        if (position) badges.innerHTML += '<span class="badge bg-light text-dark small">' + position + '</span>';
        if (posSpec)  badges.innerHTML += '<span class="badge small" style="background-color:var(--couleur-secondaire);">' + posSpec + '</span>';

        // Face arrière — stats joueur
        var stats = document.getElementById('cardBackStats');
        stats.innerHTML = '';
        if (numero)   stats.innerHTML += '<tr><td class="text-muted small py-1 pe-3">Numéro</td><td class="fw-semibold small py-1">#' + numero + '</td></tr>';
        if (position) stats.innerHTML += '<tr><td class="text-muted small py-1 pe-3">Position</td><td class="fw-semibold small py-1">' + position + '</td></tr>';
        if (posSpec)  stats.innerHTML += '<tr><td class="text-muted small py-1 pe-3">Spécialité</td><td class="fw-semibold small py-1">' + posSpec + '</td></tr>';
        var sj = statsJoueursData[joueurId];
        if (sj) {
            stats.innerHTML += '<tr><td colspan="2"><hr class="my-1"></td></tr>';
            stats.innerHTML += '<tr><td class="text-muted small py-1 pe-3">Matchs joués</td><td class="fw-semibold small py-1">' + sj.matchsJoues + '</td></tr>';
            var presences = sj.matchsJoues - sj.absences;
            stats.innerHTML += '<tr><td class="text-muted small py-1 pe-3">Présences</td><td class="fw-semibold small py-1 text-success">' + presences + '</td></tr>';
            stats.innerHTML += '<tr><td class="text-muted small py-1 pe-3">Absences</td><td class="fw-semibold small py-1 ' + (sj.absences > 0 ? 'text-danger' : '') + '">' + sj.absences + '</td></tr>';
        }

        // Description
        var descSection = document.getElementById('cardBackDescription');
        document.getElementById('cardBackDescriptionText').textContent = desc;
        descSection.style.display = desc ? '' : 'none';

        // Reset flip (toujours face avant à l'ouverture)
        document.getElementById('tradingCard').classList.remove('flipped');
        renderCarousel(false);
        startCarouselAuto();
        var modal = new bootstrap.Modal(document.getElementById('modalJoueur'));
        document.getElementById('modalJoueur').addEventListener('hidden.bs.modal', stopCarouselAuto, { once: true });
        modal.show();
    }

    // ── Carte entraineur ──────────────────────────────────────────────────────
    function ouvrirStaff(el) {
        var nom    = el.dataset.fullnom     || '';
        var photo  = el.dataset.photo       || '';
        var titre  = el.dataset.titre       || '';
        var respo  = el.dataset.responsable || '';

        var track = document.getElementById('staffPhotoTrack');
        if (photo) {
            track.innerHTML = '<img src="' + photo + '" style="width:100%;height:100%;object-fit:cover;display:block;" alt="">';
        } else {
            track.innerHTML = '<div style="width:100%;height:100%;background:var(--couleur-primaire);display:flex;align-items:center;justify-content:center;">'
                + '<i class="bi bi-person-fill" style="font-size:6rem;color:rgba(255,255,255,.18);"></i></div>';
        }
        document.getElementById('staffFrontNom').textContent   = nom;
        document.getElementById('staffFrontTitre').textContent = respo || titre;
        document.getElementById('staffFrontBadge').innerHTML   = titre
            ? '<span class="badge" style="background-color:var(--couleur-secondaire);font-size:.75rem;">' + titre + '</span>' : '';

        new bootstrap.Modal(document.getElementById('modalStaff')).show();
    }

    // ── Event delegation ──────────────────────────────────────────────────────
    document.addEventListener('click', function(e) {
        if (e.target.closest('#btnFlip'))     { document.getElementById('tradingCard').classList.add('flipped');    return; }
        if (e.target.closest('#btnFlipBack')) { document.getElementById('tradingCard').classList.remove('flipped'); return; }
        if (e.target.closest('#carouselPrev')) {
            stopCarouselAuto();
            currentPhotoIndex = (currentPhotoIndex - 1 + currentCardPhotos.length) % currentCardPhotos.length;
            renderCarousel(true); return;
        }
        if (e.target.closest('#carouselNext')) {
            stopCarouselAuto();
            currentPhotoIndex = (currentPhotoIndex + 1) % currentCardPhotos.length;
            renderCarousel(true); return;
        }
        var lbTrigger = e.target.closest('.galerie-photo');
        if (lbTrigger) { ouvrirLightbox(galeriePhotosActuelles, parseInt(lbTrigger.dataset.index, 10)); return; }
        var joueurCard = e.target.closest('.joueur-card');
        if (joueurCard) { ouvrirJoueur(joueurCard); return; }
        var staffCard = e.target.closest('.staff-card');
        if (staffCard) { ouvrirStaff(staffCard); return; }
        var matchRow = e.target.closest('.match-row-galerie');
        if (matchRow) afficherGalerie(matchRow.dataset.matchId, matchRow);
    });

    // ── Sélection auto galerie du dernier match avec photos ───────────────────
    function initAutoGalerie() {
        if (dernierMatchPhotosId !== null) {
            var row = document.querySelector('.match-row-galerie[data-match-id="' + dernierMatchPhotosId + '"]');
            afficherGalerie(String(dernierMatchPhotosId), row);
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAutoGalerie);
    } else {
        initAutoGalerie();
    }

    // ── Calendrier grille ────────────────────────────────────────────────────
    var calEvents = JSON.parse(document.getElementById('cal-events-json').textContent);
    var calMois   = new Date(); calMois.setDate(1); calMois.setHours(0,0,0,0);
    var moisFR    = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
    var joursAbreges = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];

    function renderCalGrille() {
        var y = calMois.getFullYear(), m = calMois.getMonth();
        document.getElementById('calMoisTitre').textContent = moisFR[m] + ' ' + y;

        var premierJour = new Date(y, m, 1).getDay(); // 0=dim
        var nbJours = new Date(y, m + 1, 0).getDate();
        var aujourd = new Date(); aujourd.setHours(0,0,0,0);

        // Events du mois indexés par jour
        var evtDuMois = {};
        var prefixe = y + '-' + String(m + 1).padStart(2, '0') + '-';
        calEvents.forEach(function(ev) {
            if (ev.date.startsWith(prefixe)) {
                var j = parseInt(ev.date.slice(8, 10), 10);
                if (!evtDuMois[j]) evtDuMois[j] = [];
                evtDuMois[j].push(ev);
            }
        });

        var html = '<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;">';
        // En-têtes jours
        joursAbreges.forEach(function(j) {
            html += '<div class="text-center small fw-bold py-1 text-muted">' + j + '</div>';
        });
        // Cases vides avant le 1er
        for (var i = 0; i < premierJour; i++) html += '<div></div>';
        // Jours du mois
        for (var d = 1; d <= nbJours; d++) {
            var dateD = new Date(y, m, d);
            var isToday = dateD.getTime() === aujourd.getTime();
            var evts = evtDuMois[d] || [];
            var cellBg = isToday ? 'background:rgba(var(--bs-primary-rgb),.07);outline:2px solid var(--couleur-primaire);' : 'background:#f8f9fa;';
            html += '<div style="min-height:80px;border-radius:6px;padding:4px;' + cellBg + '">';
            html += '<div class="fw-bold small mb-1 ' + (isToday ? 'text-primary' : 'text-muted') + '">' + d + '</div>';
            evts.forEach(function(ev) {
                html += '<div style="background:' + ev.color + '18;border-left:3px solid ' + ev.color + ';border-radius:3px;padding:2px 4px;margin-bottom:2px;font-size:.65rem;line-height:1.3;cursor:default;" title="' + ev.titre + (ev.heure ? ' \u2014 ' + ev.heure : '') + (ev.lieu ? '\n' + ev.lieu : '') + '">'
                    + '<i class="bi ' + ev.icon + '" style="color:' + ev.color + ';font-size:.6rem;"></i> '
                    + '<span class="fw-semibold">' + ev.titre.substring(0, 18) + (ev.titre.length > 18 ? '\u2026' : '') + '</span>';
                if (ev.heure) html += '<br><span style="color:#666;">' + ev.heure + (ev.heureFin ? '\u2013' + ev.heureFin : '') + '</span>';
                html += '</div>';
            });
            html += '</div>';
        }
        html += '</div>';
        document.getElementById('calGrille').innerHTML = html;
    }

    document.getElementById('btnListe').addEventListener('click', function() {
        document.getElementById('calVueListe').style.display = '';
        document.getElementById('calVueGrille').style.display = 'none';
        this.classList.add('active');
        document.getElementById('btnGrille').classList.remove('active');
    });
    document.getElementById('btnGrille').addEventListener('click', function() {
        document.getElementById('calVueListe').style.display = 'none';
        document.getElementById('calVueGrille').style.display = '';
        this.classList.add('active');
        document.getElementById('btnListe').classList.remove('active');
        renderCalGrille();
    });
    document.getElementById('calPrevMois').addEventListener('click', function() {
        calMois.setMonth(calMois.getMonth() - 1);
        renderCalGrille();
    });
    document.getElementById('calNextMois').addEventListener('click', function() {
        calMois.setMonth(calMois.getMonth() + 1);
        renderCalGrille();
    });

    // ── Recherche joueurs ─────────────────────────────────────────────────────
    var rechercheEl = document.getElementById('rechercheJoueur');
    if (rechercheEl) rechercheEl.addEventListener('input', function() {
        var q = this.value.toLowerCase().trim(), total = 0;
        document.querySelectorAll('.position-group').forEach(function(grp) {
            var vis = 0;
            grp.querySelectorAll('.joueur-card').forEach(function(c) {
                var show = !q || c.dataset.nom.includes(q) || c.dataset.prenom.includes(q) || c.dataset.numero.includes(q);
                c.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            grp.style.display = vis > 0 ? '' : 'none';
            total += vis;
        });
        document.getElementById('aucunResultat').style.display = total === 0 ? '' : 'none';
    });
</script>
}
