@model GestionEquipeSportive.ViewModels.JoueurViewModel
@{
    ViewData["Title"] = "Ajouter un joueur";
    var ecole = ViewBag.Ecole as GestionEquipeSportive.Models.Ecole;
    var equipeId = ViewBag.EquipeId as int?;
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            @if (ecole != null)
            {
                <li class="breadcrumb-item"><a asp-controller="Ecole" asp-action="Edit" asp-route-id="@ecole.Id">@ecole.Nom</a></li>
            }
            <li class="breadcrumb-item active">Ajouter un joueur</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-person-plus me-2 text-primary"></i>Ajouter un joueur</h1>
    @if (ecole != null)
    {
        <p class="text-muted mb-0">École : <strong>@ecole.Nom</strong></p>
    }
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person me-2"></i>Informations du joueur</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" asp-route-equipeId="@equipeId" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="EcoleId" type="hidden" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Prenom" class="form-label fw-semibold"></label>
                            <input asp-for="Prenom" class="form-control" placeholder="Prénom" />
                            <span asp-validation-for="Prenom" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Nom" class="form-label fw-semibold"></label>
                            <input asp-for="Nom" class="form-control" placeholder="Nom de famille" />
                            <span asp-validation-for="Nom" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NoFiche" class="form-label fw-semibold"></label>
                            <input asp-for="NoFiche" class="form-control" placeholder="Ex: 123456" />
                            <div class="form-text">Identifiant GPI du joueur (optionnel)</div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="ConsentementPhoto" class="form-check-input" role="switch" />
                                <label asp-for="ConsentementPhoto" class="form-check-label fw-semibold">
                                    Consentement parental — diffusion des photos autorisée
                                </label>
                            </div>
                            <div class="form-text text-muted">
                                Si désactivé, les photos de ce joueur ne seront pas affichées sur la page publique.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Créer le joueur
                        </button>
                        @if (equipeId.HasValue)
                        {
                            <a asp-controller="Equipe" asp-action="Details" asp-route-id="@equipeId" asp-route-tab="joueurs" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Annuler
                            </a>
                        }
                        else if (ecole != null)
                        {
                            <a asp-controller="Ecole" asp-action="Edit" asp-route-id="@ecole.Id" asp-route-tab="joueurs" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Annuler
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
