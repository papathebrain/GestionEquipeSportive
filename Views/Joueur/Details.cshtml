@model GestionEquipeSportive.Models.Joueur
@{
    ViewData["Title"] = $"{Model.Prenom} {Model.Nom}";
    var equipe = Model.Equipe;
    var ecole = equipe?.Ecole;
    var historique = ViewBag.Historique as List<GestionEquipeSportive.Models.Joueur> ?? new();
}

@section BannerContent {
    <div class="text-white">
        <small class="opacity-75">@ecole?.Nom — @equipe?.Nom</small>
        <h2 class="mb-0 fw-bold">@Model.Prenom @Model.Nom</h2>
        <div class="mt-1">
            <span class="badge bg-white text-dark fs-6">#@Model.Numero</span>
            <span class="badge bg-white text-dark ms-2">@Model.Position</span>
        </div>
    </div>
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@ecole?.Id">@ecole?.Nom</a></li>
            <li class="breadcrumb-item"><a asp-controller="Joueur" asp-action="Index" asp-route-equipeId="@equipe?.Id">@equipe?.Nom</a></li>
            <li class="breadcrumb-item active">@Model.Prenom @Model.Nom</li>
        </ol>
    </nav>
</div>

<div class="row g-4">
    <div class="col-md-4 text-center">
        <div class="card shadow-sm">
            <div class="card-body py-4">
                @if (!string.IsNullOrEmpty(Model.PhotoPath))
                {
                    <img src="@Model.PhotoPath" alt="@Model.Prenom @Model.Nom"
                         class="rounded-circle mb-3" style="width: 150px; height: 150px; object-fit: cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 150px; height: 150px;">
                        <i class="bi bi-person-fill text-white" style="font-size: 4rem;"></i>
                    </div>
                }
                <h4 class="fw-bold mb-1">@Model.Prenom @Model.Nom</h4>
                <div class="player-number-display mb-2">#@Model.Numero</div>
                <span class="badge bg-secondary fs-6">@Model.Position</span>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Informations du joueur</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Nom complet</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Prenom @Model.Nom</dd>
                    <dt class="col-sm-4">Numéro</dt>
                    <dd class="col-sm-8"><span class="badge bg-dark fs-6">#@Model.Numero</span></dd>
                    <dt class="col-sm-4">Position</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@Model.Position</span>
                        @if (!string.IsNullOrEmpty(Model.PositionSpecifique))
                        {
                            <span class="badge bg-primary ms-1">@Model.PositionSpecifique</span>
                        }
                    </dd>
                    <dt class="col-sm-4">Équipe</dt>
                    <dd class="col-sm-8">@equipe?.Nom</dd>
                    <dt class="col-sm-4">Sport</dt>
                    <dd class="col-sm-8">@equipe?.TypeSport</dd>
                    <dt class="col-sm-4">Niveau</dt>
                    <dd class="col-sm-8">@equipe?.Niveau</dd>
                    <dt class="col-sm-4">Année</dt>
                    <dd class="col-sm-8">@equipe?.AnneeScolaire</dd>
                    <dt class="col-sm-4">École</dt>
                    <dd class="col-sm-8">@ecole?.Nom</dd>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                    }
                </dl>
            </div>
            <div class="card-footer bg-transparent">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil me-2"></i>Modifier
                    </a>
                    <a asp-action="Index" asp-route-equipeId="@equipe?.Id" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Retour à l'équipe
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@* Historique des équipes *@
@if (historique.Count > 1)
{
    <div class="card shadow-sm mt-4">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-clock-history me-2"></i>Historique des équipes
                <span class="badge bg-secondary ms-1">@historique.Count saison@(historique.Count > 1 ? "s" : "")</span>
                @if (!string.IsNullOrEmpty(Model.NoFiche))
                {
                    <span class="badge bg-outline-secondary border ms-2 fw-normal small">Fiche @Model.NoFiche</span>
                }
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Année</th>
                            <th>École</th>
                            <th>Équipe</th>
                            <th>Sport</th>
                            <th>Niveau</th>
                            <th>#</th>
                            <th>Position</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var j in historique.OrderByDescending(j => j.Equipe?.AnneeScolaire))
                        {
                            bool estActuel = j.Id == Model.Id;
                            <tr class="@(estActuel ? "table-primary fw-semibold" : "")">
                                <td>@j.Equipe?.AnneeScolaire</td>
                                <td>@j.Equipe?.Ecole?.Nom</td>
                                <td>@j.Equipe?.Nom</td>
                                <td>
                                    @{
                                        var sportDisplay = j.Equipe?.TypeSport switch
                                        {
                                            GestionEquipeSportive.Models.TypeSport.FootballAmericain => "Football",
                                            GestionEquipeSportive.Models.TypeSport.Soccer => "Soccer",
                                            GestionEquipeSportive.Models.TypeSport.Hockey => "Hockey",
                                            _ => j.Equipe?.TypeSport.ToString()
                                        };
                                    }
                                    @sportDisplay
                                </td>
                                <td>
                                    @{
                                        var niveauDisplay = j.Equipe?.Niveau switch
                                        {
                                            GestionEquipeSportive.Models.NiveauEquipe.Juvenil => "Juvénile",
                                            GestionEquipeSportive.Models.NiveauEquipe.PeeWee => "Pee-Wee",
                                            _ => j.Equipe?.Niveau.ToString()
                                        };
                                    }
                                    @niveauDisplay
                                </td>
                                <td><span class="badge bg-dark">#@j.Numero</span></td>
                                <td>
                                    <span class="badge bg-secondary">@j.Position</span>
                                    @if (!string.IsNullOrEmpty(j.PositionSpecifique))
                                    {
                                        <span class="badge bg-primary ms-1">@j.PositionSpecifique</span>
                                    }
                                </td>
                                <td>
                                    @if (!estActuel)
                                    {
                                        <a asp-action="Details" asp-route-id="@j.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-arrow-right"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">Actuel</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
