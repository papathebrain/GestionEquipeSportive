@model List<GestionEquipeSportive.Models.Joueur>
@{
    ViewData["Title"] = "Joueurs";
    var equipe = ViewBag.Equipe as GestionEquipeSportive.Models.Equipe;
    var ecole = equipe?.Ecole;
}

@section BannerContent {
    <div class="d-flex align-items-center justify-content-between text-white">
        <div>
            <small class="opacity-75">@ecole?.Nom — @equipe?.AnneeScolaire</small>
            <h2 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>@equipe?.Nom</h2>
        </div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
                <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@ecole?.Id">@ecole?.Nom</a></li>
                <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Details" asp-route-id="@equipe?.Id">@equipe?.Nom</a></li>
                <li class="breadcrumb-item active">Joueurs</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0">
            <i class="bi bi-person-lines-fill me-2 text-primary"></i>Joueurs
            <span class="badge bg-secondary">@Model.Count</span>
        </h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Galerie" asp-action="Index" asp-route-equipeId="@equipe?.Id"
           class="btn btn-outline-success">
            <i class="bi bi-images me-1"></i>Galerie
        </a>
        <a asp-action="Create" asp-route-equipeId="@equipe?.Id" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Ajouter un joueur
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-person-plus text-muted" style="font-size: 4rem;"></i>
        <h3 class="mt-3 text-muted">Aucun joueur</h3>
        <a asp-action="Create" asp-route-equipeId="@equipe?.Id" class="btn btn-primary mt-3">
            <i class="bi bi-plus-circle me-2"></i>Ajouter le premier joueur
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
        @foreach (var joueur in Model.OrderBy(j => j.Numero))
        {
            <div class="col">
                <div class="card h-100 shadow-sm player-card">
                    <div class="player-photo-container">
                        @if (!string.IsNullOrEmpty(joueur.PhotoPath))
                        {
                            <img src="@joueur.PhotoPath" alt="@joueur.Prenom @joueur.Nom" class="player-photo" />
                        }
                        else
                        {
                            <div class="player-photo-placeholder">
                                <i class="bi bi-person-fill"></i>
                            </div>
                        }
                        <div class="player-number-badge">#@joueur.Numero</div>
                    </div>
                    <div class="card-body text-center pt-2">
                        <h6 class="card-title mb-0 fw-bold">@joueur.Prenom @joueur.Nom</h6>
                        <span class="badge bg-secondary mt-1">@joueur.Position</span>
                    </div>
                    <div class="card-footer bg-transparent py-2">
                        <div class="d-flex gap-1 justify-content-center">
                            <a asp-action="Details" asp-route-id="@joueur.Id"
                               class="btn btn-sm btn-outline-info" title="Détails">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@joueur.Id"
                               class="btn btn-sm btn-outline-warning" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" title="Supprimer"
                                    onclick="confirmDelete(@joueur.Id, '@joueur.Prenom @joueur.Nom', @equipe!.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Supprimer le joueur <strong id="deleteJoueurName"></strong> ?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteEquipeId" name="equipeId" value="" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, nom, equipeId) {
            document.getElementById('deleteJoueurName').textContent = nom;
            document.getElementById('deleteEquipeId').value = equipeId;
            document.getElementById('deleteForm').action = '/Joueur/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
