@model IEnumerable<GestionEquipeSportive.Models.ApplicationUser>
@using GestionEquipeSportive.Models
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people me-2"></i>Utilisateurs</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Nouvel utilisateur
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nom d'utilisateur</th>
                    <th>Nom complet</th>
                    <th>Rôle</th>
                    <th>Statut</th>
                    <th>Dernière connexion</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <i class="bi bi-person-circle me-1 text-muted"></i>
                            @user.NomUtilisateur
                            @if (user.ChangerMotDePasse)
                            {
                                <span class="badge bg-warning text-dark ms-1" title="Doit changer son mot de passe">
                                    <i class="bi bi-key"></i>
                                </span>
                            }
                        </td>
                        <td>@user.NomComplet</td>
                        <td>
                            @if (user.Role == Roles.Admin)
                            {
                                <span class="badge bg-danger"><i class="bi bi-shield-fill me-1"></i>Admin global</span>
                            }
                            else if (user.Role == Roles.AdminEcole)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-shield-half me-1"></i>Admin école</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-person me-1"></i>Utilisateur</span>
                            }
                        </td>
                        <td>
                            @if (user.EstActif)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Actif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Inactif</span>
                            }
                        </td>
                        <td class="text-muted small">
                            @(user.DerniereConnexion.HasValue
                                ? user.DerniereConnexion.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                : "Jamais")
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal" data-bs-target="#modalSupprimer-@user.Id">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>

                    <!-- Modal suppression -->
                    <div class="modal fade" id="modalSupprimer-@user.Id" tabindex="-1">
                        <div class="modal-dialog modal-sm">
                            <div class="modal-content">
                                <div class="modal-header bg-danger text-white">
                                    <h6 class="modal-title">Supprimer l'utilisateur</h6>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    Supprimer <strong>@user.NomUtilisateur</strong> ?
                                </div>
                                <div class="modal-footer">
                                    <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
                                    <form asp-action="Supprimer" method="post">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>
