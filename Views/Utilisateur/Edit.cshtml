@model GestionEquipeSportive.ViewModels.UtilisateurEditViewModel
@using GestionEquipeSportive.Models
@{
    ViewData["Title"] = "Modifier l'utilisateur";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex align-items-center mb-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0"><i class="bi bi-person-gear me-2"></i>Modifier — @Model.NomUtilisateur</h2>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NomUtilisateur" class="form-label fw-semibold"></label>
                            <input asp-for="NomUtilisateur" class="form-control" />
                            <span asp-validation-for="NomUtilisateur" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NomComplet" class="form-label fw-semibold"></label>
                            <input asp-for="NomComplet" class="form-control" />
                            <span asp-validation-for="NomComplet" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Role" class="form-label fw-semibold"></label>
                            <select asp-for="Role" class="form-select" id="roleSelect">
                                <option value="@Roles.Utilisateur">Utilisateur</option>
                                <option value="@Roles.Admin">Administrateur</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="EstActif" class="form-check-input" />
                                <label asp-for="EstActif" class="form-check-label"></label>
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="ChangerMotDePasse" class="form-check-input" />
                                <label asp-for="ChangerMotDePasse" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>

                    <div id="ecolesSection" class="mt-3" style="@(Model.Role == Roles.Admin ? "display:none" : "")">
                        <hr />
                        <h6 class="fw-semibold mb-3"><i class="bi bi-shield-lock me-2"></i>Accès aux écoles et équipes</h6>
                        @await Html.PartialAsync("_AccesEcoles", Model.Ecoles)
                    </div>

                    <hr class="my-4" />
                    <h6 class="text-muted mb-3"><i class="bi bi-key me-1"></i>Changer le mot de passe (optionnel)</h6>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NouveauMotDePasse" class="form-label fw-semibold"></label>
                            <input asp-for="NouveauMotDePasse" class="form-control" autocomplete="new-password"
                                   placeholder="Laisser vide pour conserver" />
                            <span asp-validation-for="NouveauMotDePasse" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmerMotDePasse" class="form-label fw-semibold"></label>
                            <input asp-for="ConfirmerMotDePasse" class="form-control" autocomplete="new-password"
                                   placeholder="Confirmer si changement" />
                            <span asp-validation-for="ConfirmerMotDePasse" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Enregistrer
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('roleSelect').addEventListener('change', function() {
    document.getElementById('ecolesSection').style.display =
        this.value === '@Roles.Admin' ? 'none' : '';
});
</script>
}
