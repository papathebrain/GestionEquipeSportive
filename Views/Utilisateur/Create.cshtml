@model GestionEquipeSportive.ViewModels.UtilisateurCreateViewModel
@using GestionEquipeSportive.Models
@{
    ViewData["Title"] = "Nouvel utilisateur";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex align-items-center mb-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0"><i class="bi bi-person-plus me-2"></i>Nouvel utilisateur</h2>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="NomUtilisateur" class="form-label fw-semibold"></label>
                            <input asp-for="NomUtilisateur" class="form-control" autocomplete="off" />
                            <span asp-validation-for="NomUtilisateur" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NomComplet" class="form-label fw-semibold"></label>
                            <input asp-for="NomComplet" class="form-control" />
                            <span asp-validation-for="NomComplet" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Role" class="form-label fw-semibold"></label>
                            <select asp-for="Role" class="form-select" id="roleSelect">
                                <option value="@Roles.Utilisateur">Utilisateur</option>
                                <option value="@Roles.Admin">Administrateur</option>
                            </select>
                        </div>
                        <div class="col-md-8 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="ChangerMotDePasse" class="form-check-input" />
                                <label asp-for="ChangerMotDePasse" class="form-check-label"></label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MotDePasse" class="form-label fw-semibold"></label>
                            <input asp-for="MotDePasse" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="MotDePasse" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmerMotDePasse" class="form-label fw-semibold"></label>
                            <input asp-for="ConfirmerMotDePasse" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmerMotDePasse" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-info small">
                        <strong>Exigences :</strong> 8+ caractères, majuscule, minuscule, chiffre, caractère spécial (@@ # $ % ! &amp; *)
                    </div>

                    <div id="ecolesSection" style="@(Model.Role == Roles.Admin ? "display:none" : "")">
                        <hr />
                        <h6 class="fw-semibold mb-3"><i class="bi bi-shield-lock me-2"></i>Accès aux écoles et équipes</h6>

                        @if (!Model.Ecoles.Any())
                        {
                            <p class="text-muted small">Aucune école disponible. Créez d'abord des écoles.</p>
                        }
                        else
                        {
                            <div class="alert alert-secondary small py-2">
                                <i class="bi bi-info-circle me-1"></i>
                                Cochez <strong>l'école</strong> pour accès complet à toutes ses équipes, ou cochez des <strong>équipes spécifiques</strong> si vous voulez limiter l'accès.
                            </div>

                            @for (int i = 0; i < Model.Ecoles.Count; i++)
                            {
                                <input type="hidden" name="Ecoles[@i].Id" value="@Model.Ecoles[i].Id" />
                                <input type="hidden" name="Ecoles[@i].Nom" value="@Model.Ecoles[i].Nom" />

                                <div class="card mb-2 border-secondary">
                                    <div class="card-header py-2 bg-light">
                                        <div class="form-check mb-0">
                                            <input type="checkbox" class="form-check-input ecole-check"
                                                   name="Ecoles[@i].AccesComplet" value="true"
                                                   id="ecole_@Model.Ecoles[i].Id"
                                                   data-equipes="equipes_@Model.Ecoles[i].Id"
                                                   @(Model.Ecoles[i].AccesComplet ? "checked" : "") />
                                            <label class="form-check-label fw-semibold" for="ecole_@Model.Ecoles[i].Id">
                                                <i class="bi bi-building me-1"></i>@Model.Ecoles[i].Nom
                                                <span class="badge bg-primary ms-1">Accès complet</span>
                                            </label>
                                        </div>
                                    </div>

                                    @if (Model.Ecoles[i].Equipes.Any())
                                    {
                                        <div class="card-body py-2 ps-4" id="equipes_@Model.Ecoles[i].Id"
                                             style="@(Model.Ecoles[i].AccesComplet ? "display:none" : "")">
                                            <small class="text-muted d-block mb-1">Équipes spécifiques :</small>
                                            <div class="row">
                                                @for (int j = 0; j < Model.Ecoles[i].Equipes.Count; j++)
                                                {
                                                    <div class="col-md-6">
                                                        <input type="hidden" name="Ecoles[@i].Equipes[@j].Id" value="@Model.Ecoles[i].Equipes[j].Id" />
                                                        <input type="hidden" name="Ecoles[@i].Equipes[@j].Nom" value="@Model.Ecoles[i].Equipes[j].Nom" />
                                                        <div class="form-check">
                                                            <input type="checkbox" class="form-check-input"
                                                                   name="Ecoles[@i].Equipes[@j].Selectionne" value="true"
                                                                   id="equipe_@Model.Ecoles[i].Equipes[j].Id"
                                                                   @(Model.Ecoles[i].Equipes[j].Selectionne ? "checked" : "") />
                                                            <label class="form-check-label small" for="equipe_@Model.Ecoles[i].Equipes[j].Id">
                                                                <i class="bi bi-people me-1 text-muted"></i>@Model.Ecoles[i].Equipes[j].Nom
                                                            </label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="card-body py-2 ps-4" id="equipes_@Model.Ecoles[i].Id"
                                             style="@(Model.Ecoles[i].AccesComplet ? "display:none" : "")">
                                            <small class="text-muted">Aucune équipe dans cette école.</small>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Créer
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Rôle Admin → cacher la section écoles
document.getElementById('roleSelect').addEventListener('change', function() {
    document.getElementById('ecolesSection').style.display =
        this.value === '@Roles.Admin' ? 'none' : '';
});

// Accès complet école → cacher les équipes spécifiques
document.querySelectorAll('.ecole-check').forEach(function(cb) {
    cb.addEventListener('change', function() {
        var equipesDiv = document.getElementById(this.dataset.equipes);
        if (equipesDiv) {
            equipesDiv.style.display = this.checked ? 'none' : '';
            // Décocher les équipes si accès complet activé
            if (this.checked) {
                equipesDiv.querySelectorAll('input[type="checkbox"]').forEach(function(eq) {
                    eq.checked = false;
                });
            }
        }
    });
});
</script>
}
