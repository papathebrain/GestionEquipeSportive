@model GestionEquipeSportive.ViewModels.UtilisateurCreateViewModel
@using GestionEquipeSportive.Models
@{
    ViewData["Title"] = "Nouvel utilisateur";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center mb-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0"><i class="bi bi-person-plus me-2"></i>Nouvel utilisateur</h2>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NomUtilisateur" class="form-label fw-semibold"></label>
                            <input asp-for="NomUtilisateur" class="form-control" autocomplete="off" />
                            <span asp-validation-for="NomUtilisateur" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NomComplet" class="form-label fw-semibold"></label>
                            <input asp-for="NomComplet" class="form-control" />
                            <span asp-validation-for="NomComplet" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Role" class="form-label fw-semibold"></label>
                            <select asp-for="Role" class="form-select">
                                <option value="@Roles.Utilisateur">Utilisateur</option>
                                <option value="@Roles.Admin">Administrateur</option>
                            </select>
                        </div>
                        <div class="col-md-8 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="ChangerMotDePasse" class="form-check-input" />
                                <label asp-for="ChangerMotDePasse" class="form-check-label"></label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MotDePasse" class="form-label fw-semibold"></label>
                            <input asp-for="MotDePasse" class="form-control" autocomplete="new-password" id="nvMdp" />
                            <span asp-validation-for="MotDePasse" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmerMotDePasse" class="form-label fw-semibold"></label>
                            <input asp-for="ConfirmerMotDePasse" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmerMotDePasse" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-info small mt-3">
                        <strong>Exigences :</strong> 8+ caractères, majuscule, minuscule, chiffre, caractère spécial (@@ # $ % ! &amp; *)
                    </div>

                    <div id="ecolesSection" class="mt-3" style="@(Model.Role == Roles.Admin ? "display:none" : "")">
                        <label class="form-label fw-semibold"><i class="bi bi-building me-1"></i>Écoles accessibles</label>
                        <div class="card border">
                            <div class="card-body py-2">
                                @if (!Model.Ecoles.Any())
                                {
                                    <p class="text-muted small mb-0">Aucune école disponible. Créez d'abord des écoles.</p>
                                }
                                else
                                {
                                    @for (int i = 0; i < Model.Ecoles.Count; i++)
                                    {
                                        <div class="form-check">
                                            <input type="hidden" name="Ecoles[@i].Id" value="@Model.Ecoles[i].Id" />
                                            <input type="hidden" name="Ecoles[@i].Nom" value="@Model.Ecoles[i].Nom" />
                                            <input type="checkbox" class="form-check-input"
                                                   name="Ecoles[@i].Selectionne" value="true"
                                                   id="ecole_@Model.Ecoles[i].Id"
                                                   @(Model.Ecoles[i].Selectionne ? "checked" : "") />
                                            <label class="form-check-label" for="ecole_@Model.Ecoles[i].Id">
                                                @Model.Ecoles[i].Nom
                                            </label>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                        <small class="text-muted">Les administrateurs ont accès à toutes les écoles automatiquement.</small>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Créer
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelector('[name="Role"]').addEventListener('change', function() {
    document.getElementById('ecolesSection').style.display =
        this.value === '@Roles.Admin' ? 'none' : '';
});
</script>
}
