@model GestionEquipeSportive.Models.Match
@{
    var ecole = ViewBag.Ecole as GestionEquipeSportive.Models.Ecole;
    var medias = ViewBag.Medias as List<GestionEquipeSportive.Models.MatchMedia> ?? new();
    bool peutModifier = ViewBag.PeutModifier == true;
    var photos = medias.Where(m => m.TypeMedia == GestionEquipeSportive.Models.TypeMedia.Photo).ToList();
    var videos = medias.Where(m => m.TypeMedia == GestionEquipeSportive.Models.TypeMedia.Video).ToList();
    ViewData["Title"] = $"Match vs {Model.Adversaire}";
}

@section BannerContent {
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <small class="text-white opacity-75">@ecole?.Nom — @Model.Equipe?.Nom</small>
            <h2 class="text-white mb-0 fw-bold">vs @Model.Adversaire</h2>
            <div class="d-flex gap-2 mt-1 flex-wrap">
                <span class="badge bg-white text-dark">
                    <i class="bi bi-calendar3 me-1"></i>@Model.DateMatch.ToString("dddd d MMMM yyyy")
                </span>
                <span class="badge @(Model.EstDomicile ? "bg-success" : "bg-secondary")">
                    @(Model.EstDomicile ? "Domicile" : "Extérieur")
                </span>
                @if (Model.AResultat)
                {
                    var cls = Model.Resultat switch { "V" => "bg-success", "D" => "bg-danger", _ => "bg-secondary" };
                    var lbl = Model.Resultat switch { "V" => "Victoire", "D" => "Défaite", _ => "Nul" };
                    <span class="badge @cls">@lbl @Model.ScoreEquipe – @Model.ScoreAdversaire</span>
                }
            </div>
        </div>
        @if (peutModifier)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-light">
                <i class="bi bi-pencil me-1"></i>Modifier
            </a>
        }
    </div>
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@ecole?.Id">@ecole?.Nom</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-equipeId="@Model.EquipeId">Matchs</a></li>
        <li class="breadcrumb-item active">vs @Model.Adversaire</li>
    </ol>
</nav>

<div class="row g-4 mb-4">
    @* Horaire *@
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-clock me-2"></i>Horaire</h6></div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    @if (!string.IsNullOrEmpty(Model.HeureArriveeVestiaire))
                    {
                        <dt class="col-7 text-muted"><i class="bi bi-door-open me-1"></i>Vestiaire</dt>
                        <dd class="col-5 fw-semibold">@Model.HeureArriveeVestiaire</dd>
                    }
                    @if (!Model.EstDomicile && !string.IsNullOrEmpty(Model.HeureDepartAutobus))
                    {
                        <dt class="col-7 text-muted"><i class="bi bi-bus-front me-1"></i>Autobus</dt>
                        <dd class="col-5 fw-semibold">@Model.HeureDepartAutobus</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.HeureDebutMatch))
                    {
                        <dt class="col-7 text-muted"><i class="bi bi-play-circle me-1"></i>Début du match</dt>
                        <dd class="col-5 fw-semibold">@Model.HeureDebutMatch</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.Lieu))
                    {
                        <dt class="col-7 text-muted"><i class="bi bi-geo-alt me-1"></i>Lieu</dt>
                        <dd class="col-5 fw-semibold">@Model.Lieu</dd>
                    }
                    @if (Model.EstDomicile)
                    {
                        <dt class="col-12 text-success small mt-1">
                            <i class="bi bi-house-fill me-1"></i>Match à domicile — pas d'autobus
                        </dt>
                    }
                </dl>
            </div>
        </div>
    </div>

    @* Résultat *@
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-trophy me-2"></i>Résultat</h6></div>
            <div class="card-body text-center">
                @if (Model.AResultat)
                {
                    var (cls, lbl) = Model.Resultat switch
                    {
                        "V" => ("text-success", "Victoire"),
                        "D" => ("text-danger", "Défaite"),
                        _ => ("text-secondary", "Nul")
                    };
                    <div class="@cls fw-bold fs-1">@Model.ScoreEquipe – @Model.ScoreAdversaire</div>
                    <div class="fs-5 fw-semibold @cls mt-1">@lbl</div>
                    <small class="text-muted">@(Model.Equipe?.Nom ?? "Notre équipe") vs @Model.Adversaire</small>
                }
                else
                {
                    <div class="text-muted py-3">
                        <i class="bi bi-hourglass-split" style="font-size:2rem"></i>
                        <p class="mt-2 mb-0">Résultat non encore saisi</p>
                        @if (peutModifier)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary mt-2">
                                <i class="bi bi-pencil-square me-1"></i>Entrer le résultat
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @* Notes *@
    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-header"><h6 class="mb-0"><i class="bi bi-journal-text me-2"></i>Notes</h6></div>
                <div class="card-body">
                    <p class="mb-0 small">@Model.Notes</p>
                </div>
            </div>
        </div>
    }
</div>

@* Galerie médias *@
<div class="card shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-images me-2"></i>Galerie du match
            <span class="badge bg-secondary ms-1">@medias.Count</span>
        </h5>
    </div>

    @if (peutModifier)
    {
        <div class="card-body border-bottom">
            <form asp-action="AjouterMedia" method="post" enctype="multipart/form-data" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="matchId" value="@Model.Id" />
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Type</label>
                    <select name="typeMedia" class="form-select form-select-sm">
                        <option value="Photo">Photo</option>
                        <option value="Video">Vidéo</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Fichier(s)</label>
                    <input type="file" name="fichiers" class="form-control form-control-sm"
                           accept="image/*,video/*" multiple />
                    <div class="form-text">Sélectionner une ou plusieurs images/vidéos</div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Description (optionnel)</label>
                    <input type="text" name="description" class="form-control form-control-sm" />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-upload"></i>
                    </button>
                </div>
            </form>
        </div>
    }

    <div class="card-body">
        @if (!medias.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun média pour ce match.</p>
        }
        else
        {
            @* Photos *@
            @if (photos.Any())
            {
                <h6 class="text-muted mb-3"><i class="bi bi-camera me-1"></i>Photos (@photos.Count)</h6>
                <div class="row g-2 mb-4">
                    @foreach (var photo in photos)
                    {
                        <div class="col-6 col-md-3 col-lg-2">
                            <div class="position-relative gallery-item">
                                <a href="@photo.CheminFichier" target="_blank">
                                    <img src="@photo.CheminFichier" alt="@photo.Description"
                                         class="img-fluid rounded w-100" style="height:120px;object-fit:cover;" />
                                </a>
                                @if (!string.IsNullOrEmpty(photo.Description))
                                {
                                    <small class="d-block text-muted text-truncate mt-1">@photo.Description</small>
                                }
                                @if (peutModifier)
                                {
                                    <form asp-action="SupprimerMedia" method="post" class="mt-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@photo.Id" />
                                        <input type="hidden" name="matchId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm w-100 py-0"
                                                onclick="return confirm('Supprimer cette photo ?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @* Vidéos *@
            @if (videos.Any())
            {
                <h6 class="text-muted mb-3"><i class="bi bi-camera-video me-1"></i>Vidéos (@videos.Count)</h6>
                <div class="row g-3">
                    @foreach (var video in videos)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card">
                                <video class="card-img-top" controls style="max-height:200px;">
                                    <source src="@video.CheminFichier" />
                                    Votre navigateur ne supporte pas la vidéo.
                                </video>
                                <div class="card-body p-2">
                                    @if (!string.IsNullOrEmpty(video.Description))
                                    {
                                        <small class="text-muted">@video.Description</small>
                                    }
                                    @if (peutModifier)
                                    {
                                        <form asp-action="SupprimerMedia" method="post" class="mt-1">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@video.Id" />
                                            <input type="hidden" name="matchId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm w-100"
                                                    onclick="return confirm('Supprimer cette vidéo ?')">
                                                <i class="bi bi-trash me-1"></i>Supprimer
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
