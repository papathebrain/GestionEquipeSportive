@{
    ViewData["Title"] = "Ajouter des photos";
    var equipe = ViewBag.Equipe as GestionEquipeSportive.Models.Equipe;
    var ecole = equipe?.Ecole;
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@ecole?.Id">@ecole?.Nom</a></li>
            <li class="breadcrumb-item"><a asp-controller="Galerie" asp-action="Index" asp-route-equipeId="@equipe?.Id">Galerie</a></li>
            <li class="breadcrumb-item active">Ajouter une photo</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-cloud-upload me-2 text-success"></i>Ajouter une photo à la galerie</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-image me-2"></i>@equipe?.Nom — Galerie</h5>
            </div>
            <div class="card-body">
                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Upload" asp-route-equipeId="@equipe?.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="photoFile" class="form-label fw-semibold">Photo <span class="text-danger">*</span></label>
                        <div class="upload-drop-zone" id="dropZone" onclick="document.getElementById('photoFile').click()">
                            <div id="dropZonePlaceholder">
                                <i class="bi bi-cloud-upload text-muted" style="font-size: 3rem;"></i>
                                <p class="mt-2 text-muted">Cliquez ou glissez une photo ici</p>
                                <small class="text-muted">JPG, PNG, GIF (max 10 Mo)</small>
                            </div>
                            <div id="dropZonePreview" style="display:none;">
                                <img id="photoPreview" src="#" alt="Aperçu" style="max-height: 250px; max-width: 100%; border-radius: 8px;" />
                            </div>
                        </div>
                        <input type="file" id="photoFile" name="photoFile" class="d-none" accept="image/*"
                               onchange="previewPhoto(this)" required />
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label fw-semibold">Description (optionnel)</label>
                        <input type="text" id="description" name="description" class="form-control"
                               placeholder="Ex: Match contre l'équipe XYZ, 15 octobre 2025" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cloud-upload me-2"></i>Ajouter à la galerie
                        </button>
                        <a asp-action="Index" asp-route-equipeId="@equipe?.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('photoPreview').src = e.target.result;
                    document.getElementById('dropZonePlaceholder').style.display = 'none';
                    document.getElementById('dropZonePreview').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Drag & Drop
        const dropZone = document.getElementById('dropZone');
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('drag-over');
            const fileInput = document.getElementById('photoFile');
            const dt = new DataTransfer();
            dt.items.add(e.dataTransfer.files[0]);
            fileInput.files = dt.files;
            previewPhoto(fileInput);
        });
    </script>
}
