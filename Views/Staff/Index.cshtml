@model List<GestionEquipeSportive.Models.Staff>
@{
    var equipe = ViewBag.Equipe as GestionEquipeSportive.Models.Equipe;
    var ecole = ViewBag.Ecole as GestionEquipeSportive.Models.Ecole;
    bool peutModifier = ViewBag.PeutModifier == true;
    ViewData["Title"] = "Staff";

    // Regrouper par titre
    var groupes = Model.GroupBy(s => s.Titre).OrderBy(g => g.Key).ToList();
}

@section BannerContent {
    <div class="d-flex align-items-center gap-3">
        @if (!string.IsNullOrEmpty(ecole?.LogoPath))
        {
            <img src="@ecole.LogoPath" alt="Logo" class="school-logo" />
        }
        <div>
            <small class="text-white opacity-75">@ecole?.Nom</small>
            <h2 class="text-white mb-0 fw-bold">@equipe?.Nom</h2>
        </div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Ecole" asp-action="Index">Écoles</a></li>
            <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@equipe?.EcoleId">@ecole?.Nom</a></li>
            <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Details" asp-route-id="@equipe?.Id">@equipe?.Nom</a></li>
            <li class="breadcrumb-item active">Staff</li>
        </ol>
    </nav>
    @if (peutModifier)
    {
        <div class="d-flex gap-2">
            <a asp-action="Importer" asp-route-equipeId="@equipe?.Id" class="btn btn-outline-primary">
                <i class="bi bi-arrow-down-circle me-2"></i>Importer
            </a>
            <a asp-action="Create" asp-route-equipeId="@equipe?.Id" class="btn btn-primary">
                <i class="bi bi-person-plus me-2"></i>Ajouter un membre
            </a>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-people text-muted" style="font-size:4rem"></i>
        <h4 class="mt-3 text-muted">Aucun membre du staff</h4>
        @if (peutModifier)
        {
            <div class="d-flex gap-2 justify-content-center mt-3">
                <a asp-action="Importer" asp-route-equipeId="@equipe?.Id" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-down-circle me-2"></i>Importer
                </a>
                <a asp-action="Create" asp-route-equipeId="@equipe?.Id" class="btn btn-primary">
                    <i class="bi bi-person-plus me-2"></i>Ajouter un membre
                </a>
            </div>
        }
    </div>
}
else
{
    @foreach (var groupe in groupes)
    {
        <h5 class="mb-3">
            <span class="badge bg-secondary me-2">@groupe.Key</span>
            <span class="text-muted small">@groupe.Count() personne@(groupe.Count() > 1 ? "s" : "")</span>
        </h5>
        <div class="row g-3 mb-4">
            @foreach (var membre in groupe)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card shadow-sm h-100 text-center">
                        <div class="card-body pt-4">
                            @if (!string.IsNullOrEmpty(membre.PhotoPath))
                            {
                                <img src="@membre.PhotoPath" alt="@membre.Prenom @membre.Nom"
                                     class="rounded-circle mb-3"
                                     style="width:90px;height:90px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-3"
                                     style="width:90px;height:90px;">
                                    <i class="bi bi-person-fill text-white" style="font-size:2.5rem"></i>
                                </div>
                            }
                            <h6 class="fw-bold mb-0">@membre.Prenom @membre.Nom</h6>
                            <small class="text-muted d-block">@membre.Titre</small>
                            @if (!string.IsNullOrEmpty(membre.ResponsableDe))
                            {
                                <span class="badge bg-light text-dark border mt-1">
                                    <i class="bi bi-clipboard-check me-1"></i>@membre.ResponsableDe
                                </span>
                            }
                        </div>
                        @if (peutModifier)
                        {
                            <div class="card-footer bg-transparent d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@membre.Id"
                                   class="btn btn-sm btn-outline-warning flex-fill">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger flex-fill"
                                        onclick="confirmDelete(@membre.Id, '@membre.Prenom @membre.Nom', @equipe!.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
}

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Confirmer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Retirer <strong id="deleteNom"></strong> du staff ?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteEquipeId" name="equipeId" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmDelete(id, nom, equipeId) {
        document.getElementById('deleteNom').textContent = nom;
        document.getElementById('deleteEquipeId').value = equipeId;
        document.getElementById('deleteForm').action = '/Staff/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>
}
