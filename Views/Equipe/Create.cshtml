@model GestionEquipeSportive.ViewModels.EquipeViewModel
@{
    ViewData["Title"] = "Nouvelle équipe";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            @await Html.PartialAsync("_BreadcrumbEcoles")
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-ecoleId="@Model.EcoleId">@Model.NomEcole</a></li>
            <li class="breadcrumb-item active">Nouvelle équipe</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-plus-circle me-2 text-primary"></i>Nouvelle équipe</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-people me-2"></i>Informations de l'équipe</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="EcoleId" type="hidden" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="TypeSport" class="form-label fw-semibold"></label>
                            <select asp-for="TypeSport" asp-items="Model.SportsList" class="form-select" id="sportSelect">
                                <option value="">-- Sélectionner un sport --</option>
                            </select>
                            <span asp-validation-for="TypeSport" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Niveau" class="form-label fw-semibold"></label>
                            <select asp-for="Niveau" asp-items="Model.NiveauxList" class="form-select" id="niveauSelect">
                                <option value="">-- Sélectionner un niveau --</option>
                            </select>
                            <span asp-validation-for="Niveau" class="text-danger small"></span>
                        </div>
                    </div>

                    @await Html.PartialAsync("_ThemeSelector", Model)

                    <div class="mb-3">
                        <label asp-for="AnneeScolaire" class="form-label fw-semibold"></label>
                        <select asp-for="AnneeScolaire" asp-items="Model.AnneesList" class="form-select" id="anneeSelect">
                            <option value="">-- Sélectionner une année --</option>
                        </select>
                        <span asp-validation-for="AnneeScolaire" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nom" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Nom" id="nomEquipeInput" class="form-control" placeholder="Généré automatiquement" />
                            <button type="button" class="btn btn-outline-secondary" id="btnResetNom" title="Regénérer le nom automatiquement">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </button>
                        </div>
                        <div class="form-text">Laissez vide pour générer automatiquement à partir du sport, niveau et année.</div>
                    </div>

                    <div class="form-check mt-3">
                        <input asp-for="AfficherPublic" class="form-check-input" />
                        <label asp-for="AfficherPublic" class="form-check-label fw-semibold"></label>
                        <div class="form-text">Rend la page de cette équipe accessible publiquement sans connexion.</div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Créer l'équipe
                        </button>
                        <a asp-action="Index" asp-route-ecoleId="@Model.EcoleId" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const nomInput   = document.getElementById('nomEquipeInput');
        const sportSel   = document.getElementById('sportSelect');
        const niveauSel  = document.getElementById('niveauSelect');
        const anneeSel   = document.getElementById('anneeSelect');
        let nomModifié   = nomInput.value.trim() !== '';

        const sportLabels  = { FootballAmericain:'Football', FlagFootball:'Flag Football', Soccer:'Soccer', Volleyball:'Volleyball', Hockey:'Hockey' };
        const niveauLabels = { Benjamin:'Benjamin', Cadet:'Cadet', Juvenil:'Juvénile', Atome:'Atome', PeeWee:'Pee-Wee', Bantam:'Bantam' };

        function genererNomAuto() {
            const s = sportSel.value  ? (sportLabels[sportSel.value]  || sportSel.value)  : '';
            const n = niveauSel.value ? (niveauLabels[niveauSel.value] || niveauSel.value) : '';
            const a = anneeSel.value  || '';
            const parts = [s, n, a].filter(x => x);
            return parts.join(' — ');
        }

        function mettreAJourNom() {
            if (!nomModifié) nomInput.value = genererNomAuto();
        }

        nomInput.addEventListener('input', function () {
            nomModifié = this.value.trim() !== '';
        });

        document.getElementById('btnResetNom').addEventListener('click', function () {
            nomModifié = false;
            nomInput.value = genererNomAuto();
        });

        sportSel.addEventListener('change', function () {
            const sport = this.value;
            niveauSel.innerHTML = '<option value="">-- Sélectionner un niveau --</option>';
            if (!sport) { mettreAJourNom(); return; }

            fetch('/Equipe/GetNiveaux?sport=' + encodeURIComponent(sport))
                .then(r => r.json())
                .then(niveaux => {
                    niveaux.forEach(n => {
                        const opt = document.createElement('option');
                        opt.value = n.value;
                        opt.textContent = n.text;
                        niveauSel.appendChild(opt);
                    });
                    mettreAJourNom();
                });
        });

        niveauSel.addEventListener('change', mettreAJourNom);
        anneeSel.addEventListener('change', mettreAJourNom);
    </script>
}
