@model GestionEquipeSportive.ViewModels.EquipeViewModel
@{
    ViewData["Title"] = "Modifier l'équipe";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            <li class="breadcrumb-item"><a asp-controller="Ecole" asp-action="Index">Écoles</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-ecoleId="@Model.EcoleId">@Model.NomEcole</a></li>
            <li class="breadcrumb-item active">Modifier l'équipe</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-pencil-square me-2 text-primary"></i>Modifier l'équipe</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Informations de l'équipe</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="EcoleId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Nom" class="form-label fw-semibold"></label>
                        <input asp-for="Nom" class="form-control" />
                        <span asp-validation-for="Nom" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="TypeSport" class="form-label fw-semibold"></label>
                            <select asp-for="TypeSport" asp-items="Model.SportsList" class="form-select" id="sportSelect">
                                <option value="">-- Sélectionner un sport --</option>
                            </select>
                            <span asp-validation-for="TypeSport" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Niveau" class="form-label fw-semibold"></label>
                            <select asp-for="Niveau" class="form-select" id="niveauSelect">
                                <option value="">-- Sélectionner un niveau --</option>
                                @foreach (var item in Model.NiveauxList)
                                {
                                    <option value="@item.Value" @(item.Selected ? "selected" : "")>@item.Text</option>
                                }
                            </select>
                            <span asp-validation-for="Niveau" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AnneeScolaire" class="form-label fw-semibold"></label>
                        <select asp-for="AnneeScolaire" asp-items="Model.AnneesList" class="form-select">
                            <option value="">-- Sélectionner une année --</option>
                        </select>
                        <span asp-validation-for="AnneeScolaire" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Enregistrer
                        </button>
                        <a asp-action="Index" asp-route-ecoleId="@Model.EcoleId" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const currentNiveau = '@Model.Niveau.ToString()';

        document.getElementById('sportSelect').addEventListener('change', function () {
            loadNiveaux(this.value, null);
        });

        function loadNiveaux(sport, selectedNiveau) {
            const niveauSelect = document.getElementById('niveauSelect');
            niveauSelect.innerHTML = '<option value="">-- Sélectionner un niveau --</option>';
            if (!sport) return;

            fetch('/Equipe/GetNiveaux?sport=' + encodeURIComponent(sport))
                .then(r => r.json())
                .then(niveaux => {
                    const displayNames = {
                        'Benjamin': 'Benjamin', 'Cadet': 'Cadet', 'Juvenil': 'Juvénile',
                        'Atome': 'Atome', 'PeeWee': 'Pee-Wee', 'Bantam': 'Bantam'
                    };
                    niveaux.forEach(n => {
                        const opt = document.createElement('option');
                        opt.value = n;
                        opt.textContent = displayNames[n] || n;
                        if (n === (selectedNiveau || currentNiveau)) opt.selected = true;
                        niveauSelect.appendChild(opt);
                    });
                });
        }

        // Charger les niveaux pour le sport actuel
        loadNiveaux('@Model.TypeSport.ToString()', '@Model.Niveau.ToString()');
    </script>
}
