@model List<GestionEquipeSportive.Models.Equipe>
@{
    ViewData["Title"] = "Équipes";
    var ecole = ViewBag.Ecole as GestionEquipeSportive.Models.Ecole;
}

@section BannerContent {
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
            @if (!string.IsNullOrEmpty(ecole?.LogoPath))
            {
                <img src="@ecole.LogoPath" alt="Logo" class="school-logo" />
            }
            <div>
                <small class="text-white opacity-75">École</small>
                <h2 class="text-white mb-0 fw-bold">@ecole?.Nom</h2>
            </div>
        </div>
    </div>
}

@{
    var annees = Model.Select(e => e.AnneeScolaire).Where(a => !string.IsNullOrEmpty(a))
        .Distinct().OrderByDescending(a => a).ToList();
    var anneeActive = annees.FirstOrDefault() ?? "";
    bool peutModifier = ViewBag.PeutModifier == true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
                <li class="breadcrumb-item"><a asp-controller="Ecole" asp-action="Index">Écoles</a></li>
                <li class="breadcrumb-item"><a asp-controller="Ecole" asp-action="Details" asp-route-id="@ecole?.Id">@ecole?.Nom</a></li>
                <li class="breadcrumb-item active">Équipes</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0"><i class="bi bi-people me-2 text-primary"></i>Équipes de @ecole?.Nom</h1>
    </div>
    @if (peutModifier)
    {
        <a asp-action="Create" asp-route-ecoleId="@ecole?.Id" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Nouvelle équipe
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
        <h3 class="mt-3 text-muted">Aucune équipe</h3>
        @if (peutModifier)
        {
            <a asp-action="Create" asp-route-ecoleId="@ecole?.Id" class="btn btn-primary mt-3">
                <i class="bi bi-plus-circle me-2"></i>Créer la première équipe
            </a>
        }
    </div>
}
else
{
    <!-- Filtre par année scolaire -->
    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="d-flex align-items-center gap-3">
                <label class="form-label mb-0 fw-semibold text-nowrap">
                    <i class="bi bi-calendar2-range me-1"></i>Année scolaire :
                </label>
                <select id="filtreAnnee" class="form-select form-select-sm w-auto">
                    @foreach (var annee in annees)
                    {
                        <option value="@annee" @(annee == anneeActive ? "selected" : "")>@annee</option>
                    }
                </select>
                <span class="text-muted small" id="compteEquipes"></span>
            </div>
        </div>
    </div>

    <!-- Équipes groupées par sport, toutes années incluses (filtrées par JS) -->
    @foreach (var sport in Model.Select(e => e.TypeSport).Distinct().OrderBy(s => s.ToString()))
    {
        var equipesSport = Model.Where(e => e.TypeSport == sport).OrderBy(e => e.Niveau.ToString()).ToList();
        <div class="sport-section mb-4" data-sport="@sport">
            <h4 class="d-flex align-items-center gap-2 mb-3">
                <span class="badge sport-badge fs-6 @GetSportBadgeClass(sport)">
                    @GetSportIcon(sport) @GetSportDisplayName(sport)
                </span>
                <span class="text-muted sport-count"></span>
            </h4>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                @foreach (var equipe in equipesSport)
                {
                    <div class="col equipe-card" data-annee="@equipe.AnneeScolaire">
                        <div class="card h-100 shadow-sm team-card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-0 fw-semibold">@equipe.Nom</h5>
                                    <span class="badge niveau-badge">@GetNiveauDisplayName(equipe.Niveau)</span>
                                </div>
                                <p class="text-muted small mb-0">
                                    <i class="bi bi-calendar3 me-1"></i>@equipe.AnneeScolaire
                                </p>
                            </div>
                            <div class="card-footer bg-transparent">
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@equipe.Id"
                                       class="btn btn-sm btn-outline-primary flex-fill">
                                        <i class="bi bi-eye me-1"></i>Détails
                                    </a>
                                    <a asp-controller="Joueur" asp-action="Index" asp-route-equipeId="@equipe.Id"
                                       class="btn btn-sm btn-outline-success flex-fill">
                                        <i class="bi bi-person-lines-fill me-1"></i>Joueurs
                                    </a>
                                    @if (peutModifier)
                                    {
                                        <a asp-action="Edit" asp-route-id="@equipe.Id"
                                           class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="confirmDelete(@equipe.Id, '@equipe.Nom', @ecole!.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    <div id="aucuneEquipe" class="text-center py-4 d-none">
        <i class="bi bi-calendar-x text-muted" style="font-size:3rem"></i>
        <p class="text-muted mt-2">Aucune équipe pour cette année scolaire.</p>
    </div>
}

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Supprimer l'équipe <strong id="deleteEquipeName"></strong> ?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteEcoleId" name="ecoleId" value="" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filtrerParAnnee(annee) {
            let total = 0;
            document.querySelectorAll('.sport-section').forEach(function (section) {
                let visibles = 0;
                section.querySelectorAll('.equipe-card').forEach(function (card) {
                    const afficher = card.dataset.annee === annee;
                    card.style.display = afficher ? '' : 'none';
                    if (afficher) { visibles++; total++; }
                });
                // Cacher la section sport entière si aucune équipe visible
                section.style.display = visibles > 0 ? '' : 'none';
                const compteur = section.querySelector('.sport-count');
                if (compteur) compteur.textContent = visibles > 0
                    ? '(' + visibles + ' équipe' + (visibles > 1 ? 's' : '') + ')'
                    : '';
            });
            const aucune = document.getElementById('aucuneEquipe');
            if (aucune) aucune.classList.toggle('d-none', total > 0);
            const compte = document.getElementById('compteEquipes');
            if (compte) compte.textContent = total + ' équipe' + (total > 1 ? 's' : '');
        }

        document.getElementById('filtreAnnee')?.addEventListener('change', function () {
            filtrerParAnnee(this.value);
        });

        // Appliquer le filtre au chargement
        const selectAnnee = document.getElementById('filtreAnnee');
        if (selectAnnee) filtrerParAnnee(selectAnnee.value);

        function confirmDelete(id, nom, ecoleId) {
            document.getElementById('deleteEquipeName').textContent = nom;
            document.getElementById('deleteEcoleId').value = ecoleId;
            document.getElementById('deleteForm').action = '/Equipe/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}

@functions {
    string GetSportBadgeClass(GestionEquipeSportive.Models.TypeSport sport) => sport switch
    {
        GestionEquipeSportive.Models.TypeSport.FootballAmericain => "bg-danger",
        GestionEquipeSportive.Models.TypeSport.Soccer => "bg-success",
        GestionEquipeSportive.Models.TypeSport.Hockey => "bg-info",
        _ => "bg-secondary"
    };

    string GetSportIcon(GestionEquipeSportive.Models.TypeSport sport) => sport switch
    {
        GestionEquipeSportive.Models.TypeSport.FootballAmericain => "🏈",
        GestionEquipeSportive.Models.TypeSport.Soccer => "⚽",
        GestionEquipeSportive.Models.TypeSport.Hockey => "🏒",
        _ => "🏅"
    };

    string GetSportDisplayName(GestionEquipeSportive.Models.TypeSport sport) => sport switch
    {
        GestionEquipeSportive.Models.TypeSport.FootballAmericain => "Football américain",
        GestionEquipeSportive.Models.TypeSport.Soccer => "Soccer",
        GestionEquipeSportive.Models.TypeSport.Hockey => "Hockey",
        _ => sport.ToString()
    };

    string GetNiveauDisplayName(GestionEquipeSportive.Models.NiveauEquipe niveau) => niveau switch
    {
        GestionEquipeSportive.Models.NiveauEquipe.Juvenil => "Juvénile",
        GestionEquipeSportive.Models.NiveauEquipe.PeeWee => "Pee-Wee",
        _ => niveau.ToString()
    };
}
