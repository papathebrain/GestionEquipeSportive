@section Scripts {
<script>
    // Persister l'onglet actif
    var tabKey = 'equipe_@(Model.Id)_tab';
    var savedTab = localStorage.getItem(tabKey);
    if (savedTab) {
        var el = document.querySelector('[href="' + savedTab + '"]');
        if (el) bootstrap.Tab.getOrCreateInstance(el).show();
    }
    document.querySelectorAll('#equipeTabs [data-bs-toggle="tab"]').forEach(function(tab) {
        tab.addEventListener('shown.bs.tab', function(e) {
            localStorage.setItem(tabKey, e.target.getAttribute('href'));
        });
    });

    function confirmDeleteJoueur(id, nom, equipeId) {
        document.getElementById('deleteJoueurNom').textContent = nom;
        document.getElementById('deleteJoueurEquipeId').value = equipeId;
        document.getElementById('deleteJoueurForm').action = '/Joueur/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteJoueurModal')).show();
    }
    function confirmDeleteMatch(id, adversaire, equipeId) {
        document.getElementById('deleteMatchAdversaire').textContent = adversaire;
        document.getElementById('deleteMatchEquipeId').value = equipeId;
        document.getElementById('deleteMatchForm').action = '/Match/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteMatchModal')).show();
    }
    function confirmDeleteStaff(id, nom, equipeId) {
        document.getElementById('deleteStaffNom').textContent = nom;
        document.getElementById('deleteStaffEquipeId').value = equipeId;
        document.getElementById('deleteStaffForm').action = '/Staff/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteStaffModal')).show();
    }
    function confirmDeleteEvenement(id, titre, equipeId) {
        document.getElementById('deleteEvenementTitre').textContent = titre;
        document.getElementById('deleteEvenementEquipeId').value = equipeId;
        document.getElementById('deleteEvenementForm').action = '/Evenement/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteEvenementModal')).show();
    }

    // Event delegation for evenement delete buttons
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-action="delete-evenement"]');
        if (btn) {
            confirmDeleteEvenement(
                btn.dataset.evId,
                btn.dataset.evTitre,
                btn.dataset.equipeId
            );
        }
    });

    // Open calendrier tab if URL has tab=calendrier
    (function() {
        var params = new URLSearchParams(window.location.search);
        if (params.get('tab') === 'calendrier') {
            var el = document.querySelector('[href="#tab-calendrier"]');
            if (el) bootstrap.Tab.getOrCreateInstance(el).show();
        }
    })();
</script>
}

@functions {
    string GetSportDisplay(TypeSport s) => s switch {
        TypeSport.FootballAmericain => "Football",
        TypeSport.Soccer => "Soccer",
        TypeSport.Hockey => "Hockey",
        _ => s.ToString()
    };
    string GetNiveauDisplay(NiveauEquipe n) => n switch {
        NiveauEquipe.Juvenil => "Juvénile",
        NiveauEquipe.PeeWee => "Pee-Wee",
        _ => n.ToString()
    };
}
