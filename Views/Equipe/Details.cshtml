                </button>
                <a asp-controller="Staff" asp-action="Create" asp-route-equipeId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter un membre
                </a>
            </div>
        }
        @if (!staff.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun entraineur.</p>
        }
        else
        {
            <div class="staff-admin-grid">
                <div class="staff-admin-header">
                    <div class="sa-col-avatar"></div>
                    <div class="sa-col-nom">Nom</div>
                    <div class="sa-col-titre">Titre</div>
                    <div class="sa-col-respo">Responsable de</div>
                    <div class="sa-col-actions">Actions</div>
                </div>
                @foreach (var s in staff.OrderBy(s => s.Titre).ThenBy(s => s.Nom))
                {
                    <div class="staff-admin-row">
                        <div class="sa-col-avatar">
