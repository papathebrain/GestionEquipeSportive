@section Scripts {
<script>
    // Persister l'onglet actif
    var tabKey = 'equipe_@(Model.Id)_tab';
    var savedTab = localStorage.getItem(tabKey);
    if (savedTab) {
        var el = document.querySelector('[href="' + savedTab + '"]');
        if (el) bootstrap.Tab.getOrCreateInstance(el).show();
    }
    document.querySelectorAll('#equipeTabs [data-bs-toggle="tab"]').forEach(function(tab) {
        tab.addEventListener('shown.bs.tab', function(e) {
            localStorage.setItem(tabKey, e.target.getAttribute('href'));
        });
    });

    function confirmDeleteJoueur(id, nom, equipeId) {
        document.getElementById('deleteJoueurNom').textContent = nom;
        document.getElementById('deleteJoueurEquipeId').value = equipeId;
        document.getElementById('deleteJoueurForm').action = '/Joueur/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteJoueurModal')).show();
    }
    function confirmDeleteMatch(id, adversaire, equipeId) {
        document.getElementById('deleteMatchAdversaire').textContent = adversaire;
        document.getElementById('deleteMatchEquipeId').value = equipeId;
        document.getElementById('deleteMatchForm').action = '/Match/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteMatchModal')).show();
    }
    function confirmDeleteStaff(id, nom, equipeId) {
        document.getElementById('deleteStaffNom').textContent = nom;
        document.getElementById('deleteStaffEquipeId').value = equipeId;
        document.getElementById('deleteStaffForm').action = '/Staff/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteStaffModal')).show();
    }
    function confirmDeleteEvenement(id, titre, equipeId) {
        document.getElementById('deleteEvenementTitre').textContent = titre;
        document.getElementById('deleteEvenementEquipeId').value = equipeId;
        document.getElementById('deleteEvenementForm').action = '/Evenement/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteEvenementModal')).show();
    }

    // Event delegation for evenement delete + joueur deplacer
    document.addEventListener('click', function(e) {
        var evBtn = e.target.closest('[data-action="delete-evenement"]');
        if (evBtn) {
            confirmDeleteEvenement(evBtn.dataset.evId, evBtn.dataset.evTitre, evBtn.dataset.equipeId);
            return;
        }
        var depBtn = e.target.closest('[data-deplacer-joueur-id]');
        if (depBtn) {
            document.getElementById('deplacerJoueurNom').textContent = depBtn.dataset.deplacerJoueurNom;
            document.getElementById('deplacerJoueurId').value = depBtn.dataset.deplacerJoueurId;
            document.getElementById('deplacerNouvelleEquipeId').value =
                document.getElementById('deplacerEquipeSelect').value;
            new bootstrap.Modal(document.getElementById('deplacerModal')).show();
        }
    });

    document.getElementById('deplacerEquipeSelect')?.addEventListener('change', function () {
        document.getElementById('deplacerNouvelleEquipeId').value = this.value;
    });

    // ── Importer joueurs existants ─────────────────────────────────────────
    var importEquipeId = @Model.Id;
    var importSelectedIds = new Set();
    var importTousJoueurs = [];

    document.getElementById('btnImporterExistant')?.addEventListener('click', function () {
        document.getElementById('importRecherche').value = '';
        document.getElementById('importAucun').style.display = 'none';
        document.getElementById('importSelectionInfo').textContent = '';
        document.getElementById('btnConfirmerImport').disabled = true;
        document.getElementById('importSelectAll').checked = false;
        document.getElementById('importFiltreDisponibles').checked = true;
        importSelectedIds = new Set();
        importTousJoueurs = [];

        document.getElementById('importChargement').style.display = '';
        document.getElementById('importListe').style.display = 'none';

        new bootstrap.Modal(document.getElementById('importerModal')).show();

        fetch('/Joueur/RechercherJoueur?equipeId=' + importEquipeId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                document.getElementById('importChargement').style.display = 'none';
                importTousJoueurs = data.joueurs || [];
                appliquerFiltresImport();
                setTimeout(function() { document.getElementById('importRecherche').focus(); }, 50);
            });
    });

    // Filtre texte + filtre disponibles → re-render
    document.getElementById('importRecherche')?.addEventListener('input', appliquerFiltresImport);
    document.getElementById('importFiltreDisponibles')?.addEventListener('change', appliquerFiltresImport);
    document.getElementById('importFiltreTous')?.addEventListener('change', appliquerFiltresImport);

    function appliquerFiltresImport() {
        var q = (document.getElementById('importRecherche')?.value ?? '').toLowerCase().trim();
        var disponiblesOnly = document.getElementById('importFiltreDisponibles')?.checked ?? true;

        var filtre = importTousJoueurs.filter(function(j) {
            var textMatch = !q
                || (j.nom + ' ' + j.prenom).toLowerCase().includes(q)
                || (j.prenom + ' ' + j.nom).toLowerCase().includes(q)
                || j.noFiche.toLowerCase().includes(q);
            var dispoMatch = !disponiblesOnly || !j.dejaPresent;
            return textMatch && dispoMatch;
        });
        afficherJoueursImport(filtre);
    }

    document.getElementById('importSelectAll')?.addEventListener('change', function () {
        var cbs = document.querySelectorAll('#importListeItems .import-cb:not(:disabled)');
        cbs.forEach(function(cb) {
            cb.checked = this.checked;
            if (this.checked) importSelectedIds.add(cb.value);
            else importSelectedIds.delete(cb.value);
        }, this);
        majSelectionImport();
    });

    document.getElementById('importListeItems')?.addEventListener('change', function(e) {
        if (!e.target.classList.contains('import-cb')) return;
        if (e.target.checked) importSelectedIds.add(e.target.value);
        else importSelectedIds.delete(e.target.value);
        majSelectionImport();
    });

    function afficherJoueursImport(joueurs) {
        document.getElementById('importAucun').style.display = 'none';
        document.getElementById('importListe').style.display = 'none';

        if (!joueurs || joueurs.length === 0) {
            document.getElementById('importAucunMsg').textContent = 'Aucun joueur trouvé.';
            document.getElementById('importAucun').style.display = '';
            majSelectionImport();
            return;
        }

        var html = joueurs.map(function(j) {
            var avatar = j.photoPath
                ? '<img src="' + escHtml(j.photoPath) + '" class="rounded-circle flex-shrink-0" style="width:38px;height:38px;object-fit:cover;" />'
                : '<div class="rounded-circle d-flex align-items-center justify-content-center bg-primary text-white fw-bold flex-shrink-0" style="width:38px;height:38px;font-size:.8rem;">'
                  + (j.prenom.charAt(0) + j.nom.charAt(0)).toUpperCase() + '</div>';
            var fiche = j.noFiche ? '<span class="badge bg-light text-dark border ms-2 fw-normal">' + escHtml(j.noFiche) + '</span>' : '';
            var disabled = j.dejaPresent ? 'disabled' : '';
            var badge = j.dejaPresent
                ? '<span class="badge bg-secondary ms-2 small fw-normal">Déjà dans l\'équipe</span>'
                : '';
            var checked = importSelectedIds.has(String(j.id)) ? 'checked' : '';
            return '<label class="d-flex align-items-center gap-3 px-3 py-2 border-bottom ' + (j.dejaPresent ? 'text-muted bg-light' : 'import-row-hover') + '" style="cursor:' + (j.dejaPresent ? 'default' : 'pointer') + ';">'
                + '<input type="checkbox" class="import-cb form-check-input flex-shrink-0" value="' + j.id + '" ' + disabled + ' ' + checked + '>'
                + avatar
                + '<div class="flex-grow-1">'
                +   '<div class="fw-semibold">' + escHtml(j.prenom) + ' ' + escHtml(j.nom) + badge + fiche + '</div>'
                + '</div>'
                + '</label>';
        }).join('');

        document.getElementById('importListeItems').innerHTML = html;
        var total = importTousJoueurs.length;
        var dispo = importTousJoueurs.filter(function(j) { return !j.dejaPresent; }).length;
        document.getElementById('importCountInfo').textContent =
            joueurs.length + ' affiché' + (joueurs.length > 1 ? 's' : '')
            + ' · ' + dispo + ' disponible' + (dispo > 1 ? 's' : '')
            + ' / ' + total;
        document.getElementById('importListe').style.display = '';
        majSelectionImport();
    }

    function majSelectionImport() {
        var n = importSelectedIds.size;
        document.getElementById('btnConfirmerImport').disabled = n === 0;
        document.getElementById('btnConfirmerImport').textContent = n > 0
            ? 'Importer (' + n + ' joueur' + (n > 1 ? 's' : '') + ')'
            : 'Importer';
        document.getElementById('importSelectionInfo').textContent = n > 0
            ? n + ' joueur' + (n > 1 ? 's' : '') + ' sélectionné' + (n > 1 ? 's' : '')
            : '';
        document.getElementById('importJoueurSourceIds').value = Array.from(importSelectedIds).join(',');
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Importer entraineurs existants ────────────────────────────────────────
    var importStaffSelectedIds = new Set();

    document.getElementById('btnImporterStaffExistant')?.addEventListener('click', function () {
        document.getElementById('importStaffRecherche').value = '';
        document.getElementById('importStaffListe').style.display = 'none';
        document.getElementById('importStaffAucun').style.display = 'none';
        document.getElementById('importStaffSelectionInfo').textContent = '';
        document.getElementById('btnConfirmerImportStaff').disabled = true;
        importStaffSelectedIds = new Set();
        new bootstrap.Modal(document.getElementById('importerStaffModal')).show();
        setTimeout(function() { document.getElementById('importStaffRecherche').focus(); }, 300);
    });

    document.getElementById('btnRechercherStaff')?.addEventListener('click', rechercherStaff);
    document.getElementById('importStaffRecherche')?.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); rechercherStaff(); }
    });

    document.getElementById('importStaffSelectAll')?.addEventListener('change', function () {
        var cbs = document.querySelectorAll('#importStaffListeItems .import-staff-cb:not(:disabled)');
        cbs.forEach(function(cb) {
            cb.checked = this.checked;
            if (this.checked) importStaffSelectedIds.add(cb.value);
            else importStaffSelectedIds.delete(cb.value);
        }, this);
        majSelectionImportStaff();
    });

    document.getElementById('importStaffListeItems')?.addEventListener('change', function(e) {
        if (!e.target.classList.contains('import-staff-cb')) return;
        if (e.target.checked) importStaffSelectedIds.add(e.target.value);
        else importStaffSelectedIds.delete(e.target.value);
        majSelectionImportStaff();
    });

    function rechercherStaff() {
        var q = document.getElementById('importStaffRecherche').value.trim();
        if (q.length < 2) return;
        importStaffSelectedIds = new Set();
        document.getElementById('importStaffSelectAll').checked = false;

        fetch('/Staff/RechercherStaff?q=' + encodeURIComponent(q) + '&equipeId=' + importEquipeId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                document.getElementById('importStaffListe').style.display = 'none';
                document.getElementById('importStaffAucun').style.display = 'none';

                if (!data.staff || data.staff.length === 0) {
                    document.getElementById('importStaffAucunMsg').textContent = data.message || 'Aucun entraineur trouvé.';
                    document.getElementById('importStaffAucun').style.display = '';
                    majSelectionImportStaff();
                    return;
                }

                var html = data.staff.map(function(s) {
                    var disabled = s.dejaPresent ? 'disabled' : '';
                    var badge = s.dejaPresent ? '<span class="badge bg-secondary ms-2 small">Déjà dans l\'équipe</span>' : '';
                    var avatar = s.photoPath
                        ? '<img src="' + escHtml(s.photoPath) + '" class="rounded-circle flex-shrink-0" style="width:38px;height:38px;object-fit:cover;" />'
                        : '<div class="rounded-circle d-flex align-items-center justify-content-center bg-secondary text-white flex-shrink-0" style="width:38px;height:38px;"><i class="bi bi-person-fill"></i></div>';
                    return '<label class="d-flex align-items-center gap-3 px-3 py-2 border-bottom ' + (s.dejaPresent ? 'text-muted bg-light' : '') + '" style="cursor:' + (s.dejaPresent ? 'default' : 'pointer') + ';">'
                        + '<input type="checkbox" class="import-staff-cb form-check-input flex-shrink-0" value="' + s.id + '" ' + disabled + '>'
                        + avatar
                        + '<div class="flex-grow-1">'
                        +   '<div class="fw-semibold">' + escHtml(s.prenom) + ' ' + escHtml(s.nom) + badge + '</div>'
                        +   '<div class="small text-muted"><span class="badge bg-info text-dark me-1">' + escHtml(s.titre) + '</span> · <i class="bi bi-people"></i> ' + escHtml(s.equipeActuelle) + '</div>'
                        + '</div>'
                        + '</label>';
                }).join('');

                document.getElementById('importStaffListeItems').innerHTML = html;
                var dispo = data.staff.filter(function(s) { return !s.dejaPresent; }).length;
                document.getElementById('importStaffCountInfo').textContent =
                    data.staff.length + ' résultat(s) · ' + dispo + ' disponible(s)';
                document.getElementById('importStaffListe').style.display = '';
                majSelectionImportStaff();
            });
    }

    function majSelectionImportStaff() {
        var n = importStaffSelectedIds.size;
        document.getElementById('btnConfirmerImportStaff').disabled = n === 0;
        document.getElementById('btnConfirmerImportStaff').textContent = n > 0
            ? 'Importer (' + n + ' employé' + (n > 1 ? 's' : '') + ')'
            : 'Importer';
        document.getElementById('importStaffSelectionInfo').textContent = n > 0
            ? n + ' employé' + (n > 1 ? 's' : '') + ' sélectionné' + (n > 1 ? 's' : '')
            : '';
        document.getElementById('importStaffSourceIds').value = Array.from(importStaffSelectedIds).join(',');
    }

    // Open calendrier tab if URL has tab=calendrier
    (function() {
        var params = new URLSearchParams(window.location.search);
        var tabParam = params.get('tab');
        if (tabParam === 'calendrier' || tabParam === 'joueurs') {
            var el = document.querySelector('[href="#tab-' + tabParam + '"]');
            if (el) bootstrap.Tab.getOrCreateInstance(el).show();
        }
    })();
</script>
}

@functions {
    string GetSportDisplay(TypeSport s) => s switch {
        TypeSport.FootballAmericain => "Football",
        TypeSport.FlagFootball      => "Flag Football",
        TypeSport.Soccer            => "Soccer",
        TypeSport.Volleyball        => "Volleyball",
        TypeSport.Hockey            => "Hockey",
        _ => s.ToString()
    };
    string GetNiveauDisplay(NiveauEquipe n) => n switch {
        NiveauEquipe.Juvenil => "Juvénile",
        NiveauEquipe.PeeWee => "Pee-Wee",
        _ => n.ToString()
    };
}
