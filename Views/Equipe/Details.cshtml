@model GestionEquipeSportive.Models.Equipe
@using GestionEquipeSportive.Models
@using GestionEquipeSportive.ViewModels
@using System.Globalization
@{
    ViewData["Title"] = Model.Nom;
    var ecole = Model.Ecole;
    int nbJoueurs = ViewBag.NbJoueurs is int n ? n : 0;
    bool peutModifier = ViewBag.PeutModifier == true;
    var joueurs = ViewBag.Joueurs as List<JoueurEquipe> ?? new();
    var staff = ViewBag.Staff as List<Staff> ?? new();
    var matchs = ViewBag.Matchs as List<Match> ?? new();
    var advLogos = ViewBag.AdvLogos as Dictionary<int, string> ?? new();
    var stats = ViewBag.Stats as StatistiquesMatchViewModel ?? new();
    var evenements = ViewBag.Evenements as List<Evenement> ?? new();
    var equipesEcole = ViewBag.EquipesEcole as List<Equipe> ?? new();
    var activeTab = ViewBag.ActiveTab as string ?? "matchs";
    var photoParJoueur = ViewBag.PhotoParJoueur as Dictionary<int, string?> ?? new();
    var frCA = new CultureInfo("fr-CA");
    var now = DateTime.Now;
}

<style>
    /* ── Grille joueurs ──────────────────────────────────────────────────── */
    .joueurs-grid {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
        font-size: .875rem;
    }
    /* Colonnes : avatar | nom | posspec | fiche | actif | photo | actions */
    .joueurs-grid-header,
    .joueurs-grid-row {
        display: grid;
        grid-template-columns: 100px 1fr 180px 100px 95px 75px 155px;
        align-items: center;
        column-gap: 12px;
        padding: 4px 12px;
    }
    @@media (max-width: 991px) {
        .joueurs-grid-header,
        .joueurs-grid-row { grid-template-columns: 100px 1fr 180px 95px 75px 155px; }
        .jg-col-fiche { display: none; }
    }
    @@media (max-width: 767px) {
        .joueurs-grid-header,
        .joueurs-grid-row { grid-template-columns: 56px 1fr 95px 75px 130px; }
        .jg-col-fiche, .jg-col-posspec { display: none; }
    }
    .joueurs-grid-header {
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
        font-weight: 600;
        font-size: .78rem;
        text-transform: uppercase;
        color: #6c757d;
        letter-spacing: .03em;
        white-space: nowrap;
    }
    .joueurs-grid-groupe {
        padding: 5px 12px;
        background: #f1f3f5;
        border-top: 1px solid #dee2e6;
        border-bottom: 1px solid #dee2e6;
    }
    .joueurs-grid-groupe:first-of-type { border-top: none; }
    .joueurs-grid-row {
        border-bottom: 1px solid #f0f0f0;
        transition: background .12s;
    }
    .joueurs-grid-row:last-child { border-bottom: none; }
    .joueurs-grid-row:hover { background: #f8f9fb; }
    .joueur-inactif { opacity: .5; }
    /* Dans le header : avatar caché, nom s'étend sur 2 colonnes pour partir à gauche */
    .joueurs-grid-header { grid-template-columns: 0 1fr 180px 100px 95px 75px 155px; padding-left: 12px; }
    @@media (max-width: 991px) {
        .joueurs-grid-header { grid-template-columns: 0 1fr 180px 95px 75px 155px; }
    }
    @@media (max-width: 767px) {
        .joueurs-grid-header { grid-template-columns: 0 1fr 95px 75px 130px; }
    }
    .joueurs-grid-header .jg-col-avatar { width: 0; overflow: hidden; padding: 0; }
    /* Header actions aligné droite, contenu actions aligné droite */
    .jg-col-actions { text-align: right; white-space: nowrap; }
    .jg-col-actif, .jg-col-photo { white-space: nowrap; }

    /* ── Grille staff admin ───────────────────────────────────────────────── */
    .staff-admin-grid { border:1px solid #dee2e6; border-radius:8px; overflow:hidden; font-size:.875rem; }
    .staff-admin-header,
    .staff-admin-row {
        display: grid;
        grid-template-columns: 48px 1fr 130px 1fr 90px;
        align-items: center; column-gap: 12px; padding: 6px 12px;
    }
    @@media (max-width: 767px) {
        .staff-admin-header,
        .staff-admin-row { grid-template-columns: 48px 1fr 110px 80px; }
        .sa-col-respo { display: none; }
    }
    .staff-admin-header {
        background:#f8f9fa; border-bottom:2px solid #dee2e6;
        font-weight:600; font-size:.78rem; text-transform:uppercase;
        color:#6c757d; letter-spacing:.03em; white-space:nowrap;
    }
    /* Header : masquer visuellement la colonne avatar sans la retirer du grid */
    .staff-admin-header .sa-col-avatar { visibility:hidden; }
    .staff-admin-row { border-bottom:1px solid #f0f0f0; transition:background .12s; }
    .staff-admin-row:last-child { border-bottom:none; }
    .staff-admin-row:hover { background:#f8f9fb; }
    .sa-col-actions { text-align:right; white-space:nowrap; }

    /* ── Grille matchs ───────────────────────────────────────────────────── */
    /* Colonnes : date+heures | adversaire | lieu | résultat | actions */
    .matchs-grid {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
        font-size: .875rem;
    }
    .matchs-grid-header,
    .matchs-grid-row {
        display: grid;
        grid-template-columns: 160px 1fr 150px 110px 100px;
        align-items: center;
        column-gap: 12px;
        padding: 6px 12px;
    }
    @@media (max-width: 991px) {
        .matchs-grid-header,
        .matchs-grid-row { grid-template-columns: 160px 1fr 110px 100px; }
        .mg-col-lieu { display: none; }
    }
    @@media (max-width: 767px) {
        .matchs-grid-header,
        .matchs-grid-row { grid-template-columns: 140px 1fr 90px; }
        .mg-col-lieu, .mg-col-resultat { display: none; }
    }
    .matchs-grid-header {
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
        font-weight: 600;
        font-size: .78rem;
        text-transform: uppercase;
        color: #6c757d;
        letter-spacing: .03em;
        white-space: nowrap;
    }
    .matchs-grid-header .mg-col-actions { text-align: right; }
    .matchs-grid-row {
        border-bottom: 1px solid #f0f0f0;
        transition: background .12s;
    }
    .matchs-grid-row:last-child { border-bottom: none; }
    .matchs-grid-row:hover { background: #f8f9fb; }
    .mg-col-actions { text-align: right; white-space: nowrap; }
</style>

@section BannerContent {
    @{
        var imageEquipe = ViewBag.ImageEquipe as string;
    }
    <div class="d-flex align-items-center justify-content-between text-white flex-wrap gap-2">
        <div class="d-flex align-items-center gap-3">
            @if (!string.IsNullOrEmpty(imageEquipe))
            {
                <img src="@imageEquipe" alt="@Model.Nom"
                     class="rounded shadow"
                     style="width:72px;height:72px;object-fit:contain;opacity:.92;flex-shrink:0;" />
            }
            <div>
                <small class="opacity-75">@ecole?.Nom — @GetSportDisplay(Model.TypeSport)</small>
                <h2 class="mb-0 fw-bold">@Model.Nom</h2>
                <div class="d-flex gap-2 mt-1 flex-wrap">
                    <span class="badge bg-white text-dark">@GetNiveauDisplay(Model.Niveau)</span>
                    <span class="badge bg-white text-dark">@Model.AnneeScolaire</span>
                    <span class="badge bg-white text-dark">
                        <i class="bi bi-person-fill me-1"></i>@nbJoueurs joueur@(nbJoueurs > 1 ? "s" : "")
                    </span>
                    @if (Model.AfficherPublic)
                    {
                        <span class="badge bg-success"><i class="bi bi-globe me-1"></i>Public</span>
                    }
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            @if (peutModifier)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-light">
                    <i class="bi bi-pencil me-1"></i>Modifier l'équipe
                </a>
                <a asp-action="Copier" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light">
                    <i class="bi bi-copy me-1"></i>Copier l'équipe
                </a>
            }
            @if (Model.AfficherPublic && ecole != null)
            {
                var publicUrl = $"/p/{Ecole.ToSlug(ecole.Nom)}/{Model.AnneeScolaire}/{Model.TypeSport}/{Model.Niveau}";
                <a href="@publicUrl" target="_blank" class="btn btn-sm btn-success">
                    <i class="bi bi-globe me-1"></i>Page publique
                </a>
            }
        </div>
    </div>
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
        <li class="breadcrumb-item"><a asp-controller="Ecole" asp-action="Index">Écoles</a></li>
        <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@ecole?.Id">@ecole?.Nom</a></li>
        <li class="breadcrumb-item active">@Model.Nom</li>
    </ol>
</nav>

@* ── Stats rapides ────────────────────────────────────────────────────────── *@
@if (stats.MatchsJoues > 0 || stats.MatchsAVenir > 0)
{
    <div class="row g-2 mb-3">
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-success">@stats.Victoires</div>
                    <div class="small text-muted">Victoires</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-danger">@stats.Defaites</div>
                    <div class="small text-muted">Défaites</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-secondary">@stats.Nuls</div>
                    <div class="small text-muted">Nuls</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4">@stats.MatchsAVenir</div>
                    <div class="small text-muted">À venir</div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Onglets ──────────────────────────────────────────────────────────────── *@
<ul class="nav nav-tabs mb-0" id="equipeTabs">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "matchs" ? "active" : "") fw-semibold" data-bs-toggle="tab" href="#tab-matchs">
            <i class="bi bi-trophy me-1"></i>Matchs
            <span class="badge bg-secondary ms-1">@matchs.Count</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "joueurs" ? "active" : "") fw-semibold" data-bs-toggle="tab" href="#tab-joueurs">
            <i class="bi bi-people me-1"></i>Joueurs
            <span class="badge bg-secondary ms-1">@joueurs.Count</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "staff" ? "active" : "") fw-semibold" data-bs-toggle="tab" href="#tab-staff">
            <i class="bi bi-person-badge me-1"></i>Entraineurs
            <span class="badge bg-secondary ms-1">@staff.Count</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "calendrier" ? "active" : "") fw-semibold" data-bs-toggle="tab" href="#tab-calendrier">
            <i class="bi bi-calendar3 me-1"></i>Calendrier
            <span class="badge bg-secondary ms-1">@(matchs.Count + evenements.Count)</span>
        </a>
    </li>
</ul>

<div class="tab-content border border-top-0 rounded-bottom shadow-sm bg-white p-3 mb-4">

    @* ── Onglet Matchs ─────────────────────────────────────────────────────── *@
    <div class="tab-pane fade @(activeTab == "matchs" ? "show active" : "")" id="tab-matchs">
        @if (peutModifier)
        {
            <div class="d-flex justify-content-end mb-3">
                <a asp-controller="Match" asp-action="Create" asp-route-equipeId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter un match
                </a>
            </div>
        }
        @if (!matchs.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun match planifié.</p>
        }
        else
        {
            <div class="matchs-grid">
                <div class="matchs-grid-header">
                    <div class="mg-col-date">Date</div>
                    <div class="mg-col-adversaire">Adversaire</div>
                    <div class="mg-col-lieu">Lieu</div>
                    <div class="mg-col-resultat">Résultat</div>
                    <div class="mg-col-actions">Actions</div>
                </div>
                @foreach (var m in matchs.OrderByDescending(m => m.DateMatch))
                {
                    <div class="matchs-grid-row">
                        <div class="mg-col-date small">
                            <div class="fw-semibold">@m.DateMatch.ToString("d MMM yyyy", frCA)</div>
                            @if (!string.IsNullOrEmpty(m.HeureArriveeVestiaire))
                            {
                                <div class="text-muted"><i class="bi bi-door-open me-1"></i>Vestiaire @m.HeureArriveeVestiaire</div>
                            }
                            @if (!string.IsNullOrEmpty(m.HeureDepartAutobus))
                            {
                                <div class="text-muted"><i class="bi bi-bus-front me-1"></i>Autobus @m.HeureDepartAutobus</div>
                            }
                            @if (!string.IsNullOrEmpty(m.HeureDebutMatch))
                            {
                                <div class="text-muted"><i class="bi bi-play-circle me-1"></i>Début @m.HeureDebutMatch</div>
                            }
                        </div>
                        <div class="mg-col-adversaire d-flex align-items-center gap-2">
                            @{
                                var advLogo = m.AdversaireId.HasValue && advLogos.TryGetValue(m.AdversaireId.Value, out var lp) ? lp : null;
                            }
                            @if (!string.IsNullOrEmpty(advLogo))
                            {
                                <img src="@advLogo" alt="Logo @m.Adversaire" style="width:28px;height:28px;object-fit:contain;flex-shrink:0;" />
                            }
                            <span class="fw-semibold">@m.Adversaire</span>
                            @if (m.EstDomicile)
                            {
                                <span class="badge bg-info text-dark ms-1 small">Dom.</span>
                            }
                        </div>
                        <div class="mg-col-lieu text-muted small">@m.Lieu</div>
                        <div class="mg-col-resultat">
                            @if (m.AResultat)
                            {
                                var cls = m.Resultat switch { "V" => "bg-success", "D" => "bg-danger", _ => "bg-secondary" };
                                <span class="badge @cls me-1">@m.Resultat</span>
                                <span class="small fw-semibold">@m.ScoreEquipe – @m.ScoreAdversaire</span>
                            }
                            else if (m.DateMatch >= now)
                            {
                                <span class="badge bg-light text-dark border small">À venir</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </div>
                        <div class="mg-col-actions">
                            @if (peutModifier)
                            {
                                <a asp-controller="Match" asp-action="Edit" asp-route-id="@m.Id"
                                   class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger py-0 px-1 ms-1"
                                        onclick="confirmDeleteMatch(@m.Id, '@Html.Raw(m.Adversaire.Replace("'","\\'"))', @Model.Id)"
                                        title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* ── Onglet Joueurs ─────────────────────────────────────────────────────── *@
    <div class="tab-pane fade @(activeTab == "joueurs" ? "show active" : "")" id="tab-joueurs">
        @if (peutModifier)
        {
            <div class="d-flex justify-content-end gap-2 mb-3 flex-wrap">
                <button type="button" class="btn btn-sm btn-outline-primary" id="btnImporterExistant">
                    <i class="bi bi-person-check me-1"></i>Importer Joueur
                </button>
            </div>
        }
        @if (!joueurs.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun joueur dans cette équipe.</p>
        }
        else
        {
            var groupesJoueurs = joueurs.GroupBy(j => j.Position).OrderBy(g => g.Key ?? "").ToList();
            <div class="joueurs-grid">
                @* En-tête *@
                <div class="joueurs-grid-header">
                    <div class="jg-col-avatar"></div>
                    <div class="jg-col-nom">Joueur</div>
                    <div class="jg-col-posspec">Position spécifique</div>
                    <div class="jg-col-fiche">Fiche</div>
                    <div class="jg-col-actif">Actif</div>
                    <div class="jg-col-photo">Photo</div>
                    <div class="jg-col-actions">Actions</div>
                </div>
                @foreach (var groupe in groupesJoueurs)
                {
                    @* Séparateur de groupe *@
                    <div class="joueurs-grid-groupe">
                        <span class="fw-bold text-uppercase small text-muted">@Html.Raw(System.Net.WebUtility.HtmlDecode(groupe.Key))</span>
                        <span class="badge bg-secondary ms-1 text-lowercase fw-normal">@groupe.Count()</span>
                    </div>
                    @foreach (var j in groupe.OrderBy(g => g.Numero))
                    {
                        <div class="joueurs-grid-row @(!j.Actif ? "joueur-inactif" : "")">
                            <div class="jg-col-avatar">
                                @{
                                    photoParJoueur.TryGetValue(j.JoueurId, out var photoJoueur);
                                }
                                @if (!string.IsNullOrEmpty(photoJoueur))
                                {
                                    <img src="@photoJoueur" class="rounded-circle"
                                         style="width:100px;height:100px;object-fit:cover;" />
                                }
                                else if (!string.IsNullOrEmpty(Model.Theme?.LogoPath))
                                {
                                    <img src="@Model.Theme.LogoPath" alt="Logo"
                                         class="rounded-circle"
                                         style="width:100px;height:100px;object-fit:contain;padding:8px;background:#f8f9fa;" />
                                }
                                else
                                {
                                    <span class="badge bg-dark">#@j.Numero</span>
                                }
                            </div>
                            <div class="jg-col-nom">
                                <span class="fw-semibold">@j.Joueur?.Prenom @j.Joueur?.Nom</span>
                                @if (!string.IsNullOrEmpty(j.PhotoPath))
                                {
                                    <span class="text-muted small ms-1">#@j.Numero</span>
                                }
                            </div>
                            <div class="jg-col-posspec">
                                @if (j.PositionPairs.Any())
                                {
                                    var groupesPairs = j.PositionPairs
                                        .GroupBy(p => p.Pos)
                                        .ToList();
                                    <div class="small">
                                        @foreach (var g in groupesPairs)
                                        {
                                            <div class="fw-semibold">@Html.Raw(System.Net.WebUtility.HtmlDecode(g.Key))</div>
                                            @foreach (var pair in g.Where(p => !string.IsNullOrEmpty(p.Spec)))
                                            {
                                                <div class="text-muted ms-2">— @Html.Raw(System.Net.WebUtility.HtmlDecode(pair.Spec))</div>
                                            }
                                        }
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(j.Position))
                                {
                                    <span class="small fw-semibold">@j.Position</span>
                                }
                            </div>
                            <div class="jg-col-fiche text-muted small">@j.Joueur?.NoFiche</div>
                            <div class="jg-col-actif">
                                @if (j.Actif)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-check-circle-fill me-1"></i>Actif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                        <i class="bi bi-x-circle-fill me-1"></i>Inactif
                                    </span>
                                }
                            </div>
                            <div class="jg-col-photo">
                                @if (j.Joueur?.ConsentementPhoto == true)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-check-circle-fill me-1"></i>Oui
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                        <i class="bi bi-x-circle-fill me-1"></i>Non
                                    </span>
                                }
                            </div>
                            <div class="jg-col-actions">
                                @if (peutModifier)
                                {
                                    <a asp-controller="Joueur" asp-action="EditAssignation" asp-route-id="@j.Id"
                                       class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier l'assignation">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (equipesEcole.Any())
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary py-0 px-1 ms-1"
                                                data-deplacer-joueur-id="@j.Id"
                                                data-deplacer-joueur-nom="@j.Joueur?.Prenom @j.Joueur?.Nom"
                                                title="Déplacer vers une autre équipe">
                                            <i class="bi bi-arrow-left-right"></i>
                                        </button>
                                    }
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger py-0 px-1 ms-1"
                                            onclick="confirmDeleteJoueur(@j.JoueurId, '@Html.Raw((j.Joueur?.Prenom ?? "").Replace("'","\\'")) @Html.Raw((j.Joueur?.Nom ?? "").Replace("'","\\'"))', @Model.Id)"
                                            title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>

    @* ── Onglet Calendrier ─────────────────────────────────────────────────── *@
    <div class="tab-pane fade @(activeTab == "calendrier" ? "show active" : "")" id="tab-calendrier">
        @if (peutModifier)
        {
            <div class="d-flex justify-content-end gap-2 mb-3 flex-wrap">
                <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#importerCalendrierModal">
                    <i class="bi bi-file-earmark-excel me-1"></i>Importer calendrier Excel
                </button>
                <a asp-controller="Evenement" asp-action="Create" asp-route-equipeId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter un événement
                </a>
            </div>
        }
        @{
            // Merge matches and events into a unified calendar
            var calItems = new List<(DateTime Date, string Titre, string SousTexte, string Lieu, string IconClass, string IconColor, int? MatchId, int? EvenementId, int EquipeId, string? AdvLogo)>();

            foreach (var m in matchs)
            {
                var resultIcon = "bi-flag-fill";
                var resultColor = m.AResultat
                    ? (m.Resultat switch { "V" => "#198754", "D" => "#dc3545", _ => "#6c757d" })
                    : "#adb5bd";
                var adversaire = m.Adversaire;
                var sous = m.AResultat ? $"{m.ScoreEquipe}–{m.ScoreAdversaire} ({m.Resultat})" : "À venir";
                var calAdvLogo = m.AdversaireId.HasValue && advLogos.TryGetValue(m.AdversaireId.Value, out var calLp) ? calLp : null;
                calItems.Add((m.DateMatch, adversaire, sous, m.Lieu ?? "", resultIcon, resultColor, m.Id, null, m.EquipeId, calAdvLogo));
            }

            foreach (var ev in evenements)
            {
                var (icon, color) = ev.Type switch
                {
                    TypeEvenement.Pratique => ("bi-stopwatch-fill", "#0d6efd"),
                    TypeEvenement.ReunionParents => ("bi-people-fill", "#6f42c1"),
                    TypeEvenement.Tournoi => ("bi-trophy-fill", "#ffc107"),
                    TypeEvenement.Jamboree => ("bi-flag-fill", "#20c997"),
                    TypeEvenement.Evaluation => ("bi-clipboard-check-fill", "#fd7e14"),
                    TypeEvenement.ActiviteEquipe => ("bi-star-fill", "#198754"),
                    _ => ("bi-calendar-event", "#6c757d")
                };
                var typeLabel = ev.Type switch
                {
                    TypeEvenement.Pratique => "Pratique",
                    TypeEvenement.ReunionParents => "Réunion de parents",
                    TypeEvenement.Tournoi => "Tournoi",
                    TypeEvenement.Jamboree => "Jamborée",
                    TypeEvenement.Evaluation => "Évaluation / Tryout",
                    TypeEvenement.ActiviteEquipe => "Activité d'équipe",
                    _ => "Autre"
                };
                calItems.Add((ev.DateDebut, ev.Titre, typeLabel, ev.Lieu ?? "", icon, color, null, ev.Id, ev.EquipeId, null));
            }

            var grouped = calItems
                .OrderBy(x => x.Date)
                .GroupBy(x => new DateTime(x.Date.Year, x.Date.Month, 1))
                .ToList();
        }
        @if (!calItems.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun événement au calendrier.</p>
        }
        else
        {
            foreach (var grp in grouped)
            {
                <div class="mb-3">
                    <div class="fw-bold text-uppercase small text-muted border-bottom pb-1 mb-2">
                        @grp.Key.ToString("MMMM yyyy", frCA)
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var item in grp)
                        {
                            <div class="list-group-item px-0 py-2">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="text-center" style="min-width:42px;">
                                        <div class="fw-bold" style="font-size:1.2rem;line-height:1;">@item.Date.Day</div>
                                        <div class="text-muted" style="font-size:.65rem;text-transform:uppercase;">@item.Date.ToString("ddd", frCA)</div>
                                    </div>
                                    <div style="width:3px;border-radius:2px;background:@item.IconColor;align-self:stretch;flex-shrink:0;"></div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 fw-semibold">
                                            @if (!string.IsNullOrEmpty(item.AdvLogo))
                                            {
                                                <img src="@item.AdvLogo" alt="" style="width:22px;height:22px;object-fit:contain;flex-shrink:0;" />
                                            }
                                            else
                                            {
                                                <i class="bi @item.IconClass" style="color:@item.IconColor;font-size:.9rem;"></i>
                                            }
                                            @item.Titre
                                        </div>
                                        <div class="small text-muted">@item.SousTexte</div>
                                        @if (!string.IsNullOrEmpty(item.Lieu))
                                        {
                                            <div class="small text-muted"><i class="bi bi-geo-alt me-1"></i>@item.Lieu</div>
                                        }
                                    </div>
                                    @if (peutModifier)
                                    {
                                        <div class="text-nowrap">
                                            @if (item.MatchId.HasValue)
                                            {
                                                <a asp-controller="Match" asp-action="Edit" asp-route-id="@item.MatchId"
                                                   class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            }
                                            @if (item.EvenementId.HasValue)
                                            {
                                                <a asp-controller="Evenement" asp-action="Edit" asp-route-id="@item.EvenementId"
                                                   class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger py-0 px-1 ms-1"
                                                        data-ev-id="@item.EvenementId"
                                                        data-ev-titre="@Html.Raw(item.Titre.Replace("'", "\\'"))"
                                                        data-equipe-id="@item.EquipeId"
                                                        data-action="delete-evenement"
                                                        title="Supprimer">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @* ── Onglet Équipe école ────────────────────────────────────────────────── *@
    <div class="tab-pane fade @(activeTab == "staff" ? "show active" : "")" id="tab-staff">
        @if (peutModifier)
