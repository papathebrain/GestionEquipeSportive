@model GestionEquipeSportive.Models.Equipe
@using GestionEquipeSportive.Models
@using GestionEquipeSportive.ViewModels
@using System.Globalization
@{
    ViewData["Title"] = Model.Nom;
    var ecole = Model.Ecole;
    int nbJoueurs = ViewBag.NbJoueurs is int n ? n : 0;
    bool peutModifier = ViewBag.PeutModifier == true;
    var joueurs = ViewBag.Joueurs as List<Joueur> ?? new();
    var staff = ViewBag.Staff as List<Staff> ?? new();
    var matchs = ViewBag.Matchs as List<Match> ?? new();
    var stats = ViewBag.Stats as StatistiquesMatchViewModel ?? new();
    var evenements = ViewBag.Evenements as List<Evenement> ?? new();
    var frCA = new CultureInfo("fr-CA");
    var now = DateTime.Now;
}

@section BannerContent {
    <div class="d-flex align-items-center justify-content-between text-white flex-wrap gap-2">
        <div>
            <small class="opacity-75">@ecole?.Nom — @GetSportDisplay(Model.TypeSport)</small>
            <h2 class="mb-0 fw-bold">@Model.Nom</h2>
            <div class="d-flex gap-2 mt-1 flex-wrap">
                <span class="badge bg-white text-dark">@GetNiveauDisplay(Model.Niveau)</span>
                <span class="badge bg-white text-dark">@Model.AnneeScolaire</span>
                <span class="badge bg-white text-dark">
                    <i class="bi bi-person-fill me-1"></i>@nbJoueurs joueur@(nbJoueurs > 1 ? "s" : "")
                </span>
                @if (Model.AfficherPublic)
                {
                    <span class="badge bg-success"><i class="bi bi-globe me-1"></i>Public</span>
                }
            </div>
        </div>
        <div class="d-flex gap-2">
            @if (peutModifier)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-light">
                    <i class="bi bi-pencil me-1"></i>Modifier l'équipe
                </a>
                <a asp-action="Copier" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light">
                    <i class="bi bi-copy me-1"></i>Copier l'équipe
                </a>
            }
            @if (Model.AfficherPublic && ecole != null)
            {
                var publicUrl = $"/p/{Ecole.ToSlug(ecole.Nom)}/{Model.AnneeScolaire}/{Model.TypeSport}/{Model.Niveau}";
                <a href="@publicUrl" target="_blank" class="btn btn-sm btn-success">
                    <i class="bi bi-globe me-1"></i>Page publique
                </a>
            }
        </div>
    </div>
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
        <li class="breadcrumb-item"><a asp-controller="Ecole" asp-action="Index">Écoles</a></li>
        <li class="breadcrumb-item"><a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@ecole?.Id">@ecole?.Nom</a></li>
        <li class="breadcrumb-item active">@Model.Nom</li>
    </ol>
</nav>

@* ── Stats rapides ────────────────────────────────────────────────────────── *@
@if (stats.MatchsJoues > 0 || stats.MatchsAVenir > 0)
{
    <div class="row g-2 mb-3">
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-success">@stats.Victoires</div>
                    <div class="small text-muted">Victoires</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-danger">@stats.Defaites</div>
                    <div class="small text-muted">Défaites</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4 text-secondary">@stats.Nuls</div>
                    <div class="small text-muted">Nuls</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fw-bold fs-4">@stats.MatchsAVenir</div>
                    <div class="small text-muted">À venir</div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Onglets ──────────────────────────────────────────────────────────────── *@
<ul class="nav nav-tabs mb-0" id="equipeTabs">
    <li class="nav-item">
        <a class="nav-link active fw-semibold" data-bs-toggle="tab" href="#tab-matchs">
            <i class="bi bi-trophy me-1"></i>Matchs
            <span class="badge bg-secondary ms-1">@matchs.Count</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-joueurs">
            <i class="bi bi-people me-1"></i>Joueurs
            <span class="badge bg-secondary ms-1">@joueurs.Count</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-staff">
            <i class="bi bi-person-badge me-1"></i>Entraineurs
            <span class="badge bg-secondary ms-1">@staff.Count</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-calendrier">
            <i class="bi bi-calendar3 me-1"></i>Calendrier
            <span class="badge bg-secondary ms-1">@(matchs.Count + evenements.Count)</span>
        </a>
    </li>
</ul>

<div class="tab-content border border-top-0 rounded-bottom shadow-sm bg-white p-3 mb-4">

    @* ── Onglet Matchs ─────────────────────────────────────────────────────── *@
    <div class="tab-pane fade show active" id="tab-matchs">
        @if (peutModifier)
        {
            <div class="d-flex justify-content-end mb-3">
                <a asp-controller="Match" asp-action="Create" asp-route-equipeId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter un match
                </a>
            </div>
        }
        @if (!matchs.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun match planifié.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Adversaire</th>
                            <th class="d-none d-md-table-cell">Lieu</th>
                            <th class="text-center">Résultat</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in matchs.OrderByDescending(m => m.DateMatch))
                        {
                            <tr>
                                <td class="text-nowrap small">
                                    @m.DateMatch.ToString("d MMM yyyy", frCA)
                                    @if (!string.IsNullOrEmpty(m.HeureDebutMatch))
                                    {
                                        <span class="text-muted ms-1">@m.HeureDebutMatch</span>
                                    }
                                </td>
                                <td>
                                    <span class="fw-semibold">@(m.EstDomicile ? "vs" : "@") @m.Adversaire</span>
                                    @if (m.EstDomicile)
                                    {
                                        <span class="badge bg-info text-dark ms-1 small">Dom.</span>
                                    }
                                </td>
                                <td class="text-muted small d-none d-md-table-cell">@m.Lieu</td>
                                <td class="text-center">
                                    @if (m.AResultat)
                                    {
                                        var cls = m.Resultat switch { "V" => "bg-success", "D" => "bg-danger", _ => "bg-secondary" };
                                        <span class="badge @cls me-1">@m.Resultat</span>
                                        <span class="small fw-semibold">@m.ScoreEquipe – @m.ScoreAdversaire</span>
                                    }
                                    else if (m.DateMatch >= now)
                                    {
                                        <span class="badge bg-light text-dark border small">À venir</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-end text-nowrap">
                                    <a asp-controller="Match" asp-action="Details" asp-route-id="@m.Id"
                                       class="btn btn-sm btn-outline-info py-0 px-1" title="Détails / Galerie">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (peutModifier)
                                    {
                                        <a asp-controller="Match" asp-action="Edit" asp-route-id="@m.Id"
                                           class="btn btn-sm btn-outline-warning py-0 px-1 ms-1" title="Modifier">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger py-0 px-1 ms-1"
                                                onclick="confirmDeleteMatch(@m.Id, '@Html.Raw(m.Adversaire.Replace("'","\\'"))', @Model.Id)"
                                                title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @* ── Onglet Joueurs ─────────────────────────────────────────────────────── *@
    <div class="tab-pane fade" id="tab-joueurs">
        @if (peutModifier)
        {
            <div class="d-flex justify-content-end mb-3">
                <a asp-controller="Joueur" asp-action="Create" asp-route-equipeId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter un joueur
                </a>
            </div>
        }
        @if (!joueurs.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun joueur dans cette équipe.</p>
        }
        else
        {
            @foreach (var groupe in joueurs.GroupBy(j => j.Position).OrderBy(g => g.Key))
            {
                <div class="mb-4">
                    <div class="fw-bold text-uppercase small text-muted border-bottom pb-1 mb-2">
                        @groupe.Key
                        <span class="badge bg-secondary ms-1 text-lowercase fw-normal">@groupe.Count()</span>
                    </div>
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:48px">#</th>
                                <th>Nom</th>
                                <th class="d-none d-sm-table-cell">Position spécifique</th>
                                <th class="d-none d-md-table-cell">Fiche</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var j in groupe.OrderBy(j => j.Numero))
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(j.PhotoPath))
                                        {
                                            <img src="@j.PhotoPath" class="rounded-circle"
                                                 style="width:32px;height:32px;object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark">#@j.Numero</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="fw-semibold">@j.Prenom @j.Nom</span>
                                        @if (!string.IsNullOrEmpty(j.PhotoPath))
                                        {
                                            <span class="text-muted small ms-1">#@j.Numero</span>
                                        }
                                    </td>
                                    <td class="d-none d-sm-table-cell">
                                        @if (!string.IsNullOrEmpty(j.PositionSpecifique))
                                        {
                                            <span class="badge bg-primary">@j.PositionSpecifique</span>
                                        }
                                    </td>
                                    <td class="text-muted small d-none d-md-table-cell">@j.NoFiche</td>
                                    <td class="text-end text-nowrap">
                                        <a asp-controller="Joueur" asp-action="Details" asp-route-id="@j.Id"
                                           class="btn btn-sm btn-outline-info py-0 px-1" title="Détails">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (peutModifier)
                                        {
                                            <a asp-controller="Joueur" asp-action="Edit" asp-route-id="@j.Id"
                                               class="btn btn-sm btn-outline-warning py-0 px-1 ms-1" title="Modifier">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger py-0 px-1 ms-1"
                                                    onclick="confirmDeleteJoueur(@j.Id, '@Html.Raw(j.Prenom.Replace("'","\\'")) @Html.Raw(j.Nom.Replace("'","\\'"))', @Model.Id)"
                                                    title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>

    @* ── Onglet Calendrier ─────────────────────────────────────────────────── *@
    <div class="tab-pane fade" id="tab-calendrier">
        @if (peutModifier)
        {
            <div class="d-flex justify-content-end mb-3">
                <a asp-controller="Evenement" asp-action="Create" asp-route-equipeId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter un événement
                </a>
            </div>
        }
        @{
            // Merge matches and events into a unified calendar
            var calItems = new List<(DateTime Date, string Titre, string SousTexte, string Lieu, string IconClass, string IconColor, int? MatchId, int? EvenementId, int EquipeId)>();

            foreach (var m in matchs)
            {
                var resultIcon = "bi-flag-fill";
                var resultColor = m.AResultat
                    ? (m.Resultat switch { "V" => "#198754", "D" => "#dc3545", _ => "#6c757d" })
                    : "#adb5bd";
                var adversaire = (m.EstDomicile ? "vs " : "@ ") + m.Adversaire;
                var sous = m.AResultat ? $"{m.ScoreEquipe}–{m.ScoreAdversaire} ({m.Resultat})" : "À venir";
                calItems.Add((m.DateMatch, adversaire, sous, m.Lieu ?? "", resultIcon, resultColor, m.Id, null, m.EquipeId));
            }

            foreach (var ev in evenements)
            {
                var (icon, color) = ev.Type switch
                {
                    TypeEvenement.Pratique => ("bi-stopwatch-fill", "#0d6efd"),
                    TypeEvenement.ReunionParents => ("bi-people-fill", "#6f42c1"),
                    TypeEvenement.Tournoi => ("bi-trophy-fill", "#ffc107"),
                    TypeEvenement.Jamboree => ("bi-flag-fill", "#20c997"),
                    TypeEvenement.Evaluation => ("bi-clipboard-check-fill", "#fd7e14"),
                    TypeEvenement.ActiviteEquipe => ("bi-star-fill", "#198754"),
                    _ => ("bi-calendar-event", "#6c757d")
                };
                var typeLabel = ev.Type switch
                {
                    TypeEvenement.Pratique => "Pratique",
                    TypeEvenement.ReunionParents => "Réunion de parents",
                    TypeEvenement.Tournoi => "Tournoi",
                    TypeEvenement.Jamboree => "Jamborée",
                    TypeEvenement.Evaluation => "Évaluation / Tryout",
                    TypeEvenement.ActiviteEquipe => "Activité d'équipe",
                    _ => "Autre"
                };
                calItems.Add((ev.DateDebut, ev.Titre, typeLabel, ev.Lieu ?? "", icon, color, null, ev.Id, ev.EquipeId));
            }

            var grouped = calItems
                .OrderBy(x => x.Date)
                .GroupBy(x => new DateTime(x.Date.Year, x.Date.Month, 1))
                .ToList();
        }
        @if (!calItems.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun événement au calendrier.</p>
        }
        else
        {
            foreach (var grp in grouped)
            {
                <div class="mb-3">
                    <div class="fw-bold text-uppercase small text-muted border-bottom pb-1 mb-2">
                        @grp.Key.ToString("MMMM yyyy", frCA)
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var item in grp)
                        {
                            <div class="list-group-item px-0 py-2">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="text-center" style="min-width:42px;">
                                        <div class="fw-bold" style="font-size:1.2rem;line-height:1;">@item.Date.Day</div>
                                        <div class="text-muted" style="font-size:.65rem;text-transform:uppercase;">@item.Date.ToString("ddd", frCA)</div>
                                    </div>
                                    <div style="width:3px;border-radius:2px;background:@item.IconColor;align-self:stretch;flex-shrink:0;"></div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 fw-semibold">
                                            <i class="bi @item.IconClass" style="color:@item.IconColor;font-size:.9rem;"></i>
                                            @item.Titre
                                        </div>
                                        <div class="small text-muted">@item.SousTexte</div>
                                        @if (!string.IsNullOrEmpty(item.Lieu))
                                        {
                                            <div class="small text-muted"><i class="bi bi-geo-alt me-1"></i>@item.Lieu</div>
                                        }
                                    </div>
                                    @if (peutModifier)
                                    {
                                        <div class="text-nowrap">
                                            @if (item.MatchId.HasValue)
                                            {
                                                <a asp-controller="Match" asp-action="Edit" asp-route-id="@item.MatchId"
                                                   class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            }
                                            @if (item.EvenementId.HasValue)
                                            {
                                                <a asp-controller="Evenement" asp-action="Edit" asp-route-id="@item.EvenementId"
                                                   class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger py-0 px-1 ms-1"
                                                        data-ev-id="@item.EvenementId"
                                                        data-ev-titre="@Html.Raw(item.Titre.Replace("'", "\\'"))"
                                                        data-equipe-id="@item.EquipeId"
                                                        data-action="delete-evenement"
                                                        title="Supprimer">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @* ── Onglet Équipe école ────────────────────────────────────────────────── *@
    <div class="tab-pane fade" id="tab-staff">
        @if (peutModifier)
        {
            <div class="d-flex justify-content-end mb-3">
                <a asp-controller="Staff" asp-action="Create" asp-route-equipeId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter un membre
                </a>
            </div>
        }
        @if (!staff.Any())
        {
            <p class="text-muted text-center py-3 mb-0">Aucun entraineur.</p>
        }
        else
        {
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:48px"></th>
                        <th>Nom</th>
                        <th>Titre</th>
                        <th class="d-none d-md-table-cell">Responsable de</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in staff.OrderBy(s => s.Titre).ThenBy(s => s.Nom))
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(s.PhotoPath))
                                {
                                    <img src="@s.PhotoPath" class="rounded-circle"
                                         style="width:36px;height:36px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center"
                                         style="width:36px;height:36px;color:#fff;">
                                        <i class="bi bi-person-fill" style="font-size:.85rem;"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-semibold">@s.Prenom @s.Nom</td>
                            <td><span class="badge bg-info text-dark">@s.Titre</span></td>
                            <td class="text-muted small d-none d-md-table-cell">@s.ResponsableDe</td>
                            <td class="text-end text-nowrap">
                                @if (peutModifier)
                                {
                                    <a asp-controller="Staff" asp-action="Edit" asp-route-id="@s.Id"
                                       class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger py-0 px-1 ms-1"
                                            onclick="confirmDeleteStaff(@s.Id, '@Html.Raw(s.Prenom.Replace("'","\\'")) @Html.Raw(s.Nom.Replace("'","\\'"))', @Model.Id)"
                                            title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>

@* ── Modales de suppression ───────────────────────────────────────────────── *@
<div class="modal fade" id="deleteJoueurModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Supprimer le joueur</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Supprimer <strong id="deleteJoueurNom"></strong> de l'équipe ?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteJoueurForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteJoueurEquipeId" name="equipeId" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteMatchModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Supprimer le match</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Supprimer le match contre <strong id="deleteMatchAdversaire"></strong> ?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteMatchForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteMatchEquipeId" name="equipeId" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteEvenementModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Supprimer l'événement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Supprimer <strong id="deleteEvenementTitre"></strong> ?</div>
            <div class="modal-footer">
