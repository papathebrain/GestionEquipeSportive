@model GestionEquipeSportive.Models.Ecole
@{
    ViewData["Title"] = Model.Nom;
    var equipes = ViewBag.Equipes as List<GestionEquipeSportive.Models.Equipe> ?? new();
    var annees = ViewBag.Annees as List<string> ?? new();
    bool peutModifier = ViewBag.PeutModifier == true;
    bool isAdmin = User.IsInRole("Admin");
    var nbJoueurs = ViewBag.NbJoueurs as Dictionary<int, int> ?? new();
    var anneeCourante = ViewBag.AnneeCourante as string ?? "";
}

@section BannerContent {
    <div class="d-flex align-items-center gap-3">
        @if (!string.IsNullOrEmpty(Model.LogoPath))
        {
            <img src="@Model.LogoPath" alt="Logo" class="school-logo" />
        }
        <div>
            <h2 class="text-white mb-0 fw-bold">@Model.Nom</h2>
            <small class="text-white opacity-75">@Model.NomEquipe</small>
        </div>
    </div>
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Écoles</a></li>
            <li class="breadcrumb-item active">@Model.Nom</li>
        </ol>
    </nav>
</div>

<div class="row g-4 mb-4">
    <!-- Informations école -->
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header" style="background-color: @Model.CouleurPrimaire;">
                <h5 class="mb-0 text-white"><i class="bi bi-info-circle me-2"></i>Informations</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Nom</dt>
                    <dd class="col-sm-7">@Model.Nom</dd>
                    <dt class="col-sm-5">Nom d'équipe</dt>
                    <dd class="col-sm-7"><span class="badge bg-secondary">@Model.NomEquipe</span></dd>
                    <dt class="col-sm-5">Couleur primaire</dt>
                    <dd class="col-sm-7">
                        <div class="d-flex align-items-center gap-2">
                            <div class="color-swatch-sm" style="background-color: @Model.CouleurPrimaire;"></div>
                            @Model.CouleurPrimaire
                        </div>
                    </dd>
                    <dt class="col-sm-5">Couleur secondaire</dt>
                    <dd class="col-sm-7">
                        <div class="d-flex align-items-center gap-2">
                            <div class="color-swatch-sm" style="background-color: @Model.CouleurSecondaire;"></div>
                            @Model.CouleurSecondaire
                        </div>
                    </dd>
                </dl>
            </div>
            @if (isAdmin)
            {
                <div class="card-footer bg-transparent">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil me-1"></i>Modifier l'école
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Équipes -->
    <div class="col-md-8">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <h5 class="mb-0">
                            <i class="bi bi-people me-2"></i>Équipes
                            <span class="badge bg-primary ms-1" id="compteEquipes">@equipes.Count</span>
                        </h5>
                        @if (annees.Any())
                        {
                            <div class="d-flex align-items-center gap-2">
                                <label class="form-label mb-0 small fw-semibold text-nowrap">
                                    <i class="bi bi-calendar2-range me-1"></i>Année :
                                </label>
                                <select id="filtreAnnee" class="form-select form-select-sm w-auto">
                                    <option value="">— Toutes —</option>
                                    @foreach (var annee in annees)
                                    {
                                        <option value="@annee">@annee</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>
                    @if (peutModifier)
                    {
                        <a asp-controller="Equipe" asp-action="Create" asp-route-ecoleId="@Model.Id"
                           class="btn btn-sm btn-primary">
                            <i class="bi bi-plus-circle me-1"></i>Nouvelle équipe
                        </a>
                    }
                </div>
            </div>

            <div class="card-body">
                @if (!equipes.Any())
                {
                    <p class="text-muted text-center py-3">Aucune équipe pour cette école.</p>
                }
                else
                {

                    <div class="list-group list-group-flush" id="listeEquipes">
                        @foreach (var eq in equipes)
                        {
                            <div class="equipe-item list-group-item list-group-item-action px-0"
                                 data-annee="@eq.AnneeScolaire">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-semibold">@eq.Nom</span>
                                        <div class="d-flex gap-1 mt-1 flex-wrap">
                                            <span class="badge @GetSportBadge(eq.TypeSport)">
                                                @GetSportIcon(eq.TypeSport) @GetSportDisplay(eq.TypeSport)
                                            </span>
                                            <span class="badge bg-secondary">@GetNiveauDisplay(eq.Niveau)</span>
                                            <span class="badge bg-light text-dark border">
                                                <i class="bi bi-calendar3 me-1"></i>@eq.AnneeScolaire
                                            </span>
                                            @{ var n = nbJoueurs.TryGetValue(eq.Id, out var cnt) ? cnt : 0; }
                                            <span class="badge bg-info text-dark">
                                                <i class="bi bi-person-fill me-1"></i>@n joueur@(n > 1 ? "s" : "")
                                            </span>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a asp-controller="Joueur" asp-action="Index" asp-route-equipeId="@eq.Id"
                                           class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-person-lines-fill me-1"></i>Joueurs
                                        </a>
                                        @if (peutModifier)
                                        {
                                            <a asp-controller="Equipe" asp-action="Edit" asp-route-id="@eq.Id"
                                               class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <p id="aucuneAnnee" class="text-muted small text-center mt-2 d-none">
                        Aucune équipe pour cette année scolaire.
                    </p>
                }
            </div>

            <div class="card-footer bg-transparent">
                <a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@Model.Id"
                   class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-people me-1"></i>Gérer les équipes
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var GLOBAL_KEY = 'annee_scolaire_globale';
    var anneeCourante = '@anneeCourante';
    var select = document.getElementById('filtreAnnee');
    if (!select) return;

    // Options disponibles (exclut l'option "— Toutes —" vide)
    var optionsDisponibles = Array.from(select.options).map(function (o) { return o.value; }).filter(Boolean);

    function filtrer(annee) {
        var items = document.querySelectorAll('.equipe-item');
        var count = 0;
        items.forEach(function (item) {
            var visible = !annee || item.dataset.annee === annee;
            item.style.display = visible ? '' : 'none';
            if (visible) count++;
        });
        var badge = document.getElementById('compteEquipes');
        if (badge) badge.textContent = count;
        var aucune = document.getElementById('aucuneAnnee');
        if (aucune) aucune.classList.toggle('d-none', count > 0);
    }

    select.addEventListener('change', function () {
        localStorage.setItem(GLOBAL_KEY, this.value);
        filtrer(this.value);
    });

    // Choisir l'année initiale : globale sauvegardée → courante → première dispo
    var saved = localStorage.getItem(GLOBAL_KEY);
    var anneeInitiale = (saved && optionsDisponibles.includes(saved)) ? saved
        : (anneeCourante && optionsDisponibles.includes(anneeCourante)) ? anneeCourante
        : (optionsDisponibles.length > 0 ? optionsDisponibles[0] : '');

    if (anneeInitiale) localStorage.setItem(GLOBAL_KEY, anneeInitiale);
    select.value = anneeInitiale;
    filtrer(anneeInitiale);
})();
</script>
}

@functions {
    string GetSportBadge(GestionEquipeSportive.Models.TypeSport s) => s switch {
        GestionEquipeSportive.Models.TypeSport.FootballAmericain => "bg-danger",
        GestionEquipeSportive.Models.TypeSport.Soccer => "bg-success",
        GestionEquipeSportive.Models.TypeSport.Hockey => "bg-info text-dark",
        _ => "bg-secondary"
    };
    string GetSportIcon(GestionEquipeSportive.Models.TypeSport s) => s switch {
        GestionEquipeSportive.Models.TypeSport.FootballAmericain => "🏈",
        GestionEquipeSportive.Models.TypeSport.Soccer => "⚽",
        GestionEquipeSportive.Models.TypeSport.Hockey => "🏒",
        _ => "🏅"
    };
    string GetSportDisplay(GestionEquipeSportive.Models.TypeSport s) => s switch {
        GestionEquipeSportive.Models.TypeSport.FootballAmericain => "Football",
        GestionEquipeSportive.Models.TypeSport.Soccer => "Soccer",
        GestionEquipeSportive.Models.TypeSport.Hockey => "Hockey",
        _ => s.ToString()
    };
    string GetNiveauDisplay(GestionEquipeSportive.Models.NiveauEquipe n) => n switch {
        GestionEquipeSportive.Models.NiveauEquipe.Juvenil => "Juvénile",
        GestionEquipeSportive.Models.NiveauEquipe.PeeWee => "Pee-Wee",
        _ => n.ToString()
    };
}
