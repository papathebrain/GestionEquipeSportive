@model List<GestionEquipeSportive.Models.Ecole>
@using GestionEquipeSportive.Models
@{
    ViewData["Title"] = "Gestion des écoles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
                <li class="breadcrumb-item active">Écoles</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0"><i class="bi bi-building me-2 text-primary"></i>Gestion des écoles</h1>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Nouvelle école
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-building text-muted" style="font-size: 4rem;"></i>
        <h3 class="mt-3 text-muted">Aucune école</h3>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary mt-3">
                <i class="bi bi-plus-circle me-2"></i>Ajouter une école
            </a>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Logo</th>
                    <th>Nom</th>
                    <th>Thèmes</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ecole in Model)
                {
                    @* Logo : école → premier thème *@
                    var logoSrc = ecole.LogoPath
                        ?? ecole.Themes.FirstOrDefault(t => !string.IsNullOrEmpty(t.LogoPath))?.LogoPath;
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(logoSrc))
                            {
                                <img src="@logoSrc" alt="Logo" class="school-logo-sm" />
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-building"></i></span>
                            }
                        </td>
                        <td class="fw-semibold">@ecole.Nom</td>
                        <td>
                            @if (!ecole.Themes.Any())
                            {
                                <span class="text-muted small fst-italic">Aucun thème</span>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var theme in ecole.Themes)
                                    {
                                        <div class="d-flex align-items-center gap-1 border rounded px-2 py-1" style="font-size:.8rem;">
                                            <div style="width:12px;height:12px;border-radius:3px;background:@theme.CouleurPrimaire;flex-shrink:0;" title="@theme.CouleurPrimaire"></div>
                                            <div style="width:12px;height:12px;border-radius:3px;background:@theme.CouleurSecondaire;flex-shrink:0;" title="@theme.CouleurSecondaire"></div>
                                            <span>@theme.NomEquipe</span>
                                        </div>
                                    }
                                </div>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a asp-controller="Equipe" asp-action="Index" asp-route-ecoleId="@ecole.Id"
                                   class="btn btn-outline-primary" title="Équipes">
                                    <i class="bi bi-people"></i>
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("AdminEcole"))
                                {
                                    <a asp-action="Edit" asp-route-id="@ecole.Id" class="btn btn-outline-warning" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <button type="button" class="btn btn-outline-danger" title="Supprimer"
                                            onclick="confirmDelete(@ecole.Id, '@ecole.Nom')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal de confirmation -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Êtes-vous sûr de vouloir supprimer l'école <strong id="deleteEcoleName"></strong> ?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, nom) {
            document.getElementById('deleteEcoleName').textContent = nom;
            document.getElementById('deleteForm').action = '/Ecole/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
