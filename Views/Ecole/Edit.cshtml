@section Scripts {
<script>
    // ── Activer l'onglet selon le paramètre ?tab= dans l'URL ──────────────────
    (function () {
        var urlTab = new URLSearchParams(window.location.search).get('tab');
        if (urlTab) {
            var tabEl = document.querySelector('#ecoleEditTabs a[href="#tab-' + urlTab + '"]');
            if (tabEl) new bootstrap.Tab(tabEl).show();
        }
    })();

    // ── Sync nom d'équipe dans aperçu
    document.querySelector('#modalAjouterTheme [name="NomEquipe"]')?.addEventListener('input', function() {
        document.getElementById('addPreviewNom').textContent = this.value || "Nom d'équipe";
    });

    function syncAddColor(prefix, which, value) {
        document.getElementById(prefix + 'Couleur' + which + 'Text').value = value;
        updateThemePreview(prefix);
    }
    function syncAddColorText(prefix, which, value) {
        if (/^#[0-9A-Fa-f]{6}$/.test(value)) {
            document.getElementById(prefix + 'Couleur' + which + 'Input').value = value;
            updateThemePreview(prefix);
        }
    }
    function updateThemePreview(prefix) {
        const p = document.getElementById(prefix + 'CouleurPrimaireInput').value;
        document.getElementById(prefix + 'ThemePreview').style.backgroundColor = p;
    }

    function previewThemeLogo(input, imgId, containerId, placeholderId) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById(imgId).src = e.target.result;
                document.getElementById(containerId).style.display = 'block';
                document.getElementById(placeholderId).style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function ouvrirModifierTheme(id) {
        fetch('/Ecole/GetTheme/' + id)
            .then(r => r.json())
            .then(t => {
                document.getElementById('editThemeId').value = t.id;
                document.getElementById('editNomEquipe').value = t.nomEquipe;
                document.getElementById('editPreviewNom').textContent = t.nomEquipe;
                document.getElementById('editCouleurPrimaireInput').value = t.couleurPrimaire;
                document.getElementById('editCouleurPrimaireText').value = t.couleurPrimaire;
                document.getElementById('editCouleurSecondaireInput').value = t.couleurSecondaire;
                document.getElementById('editCouleurSecondaireText').value = t.couleurSecondaire;
                document.getElementById('editThemePreview').style.backgroundColor = t.couleurPrimaire;
                if (t.logoPath) {
                    document.getElementById('editLogoActuel').src = t.logoPath;
                    document.getElementById('editLogoActuelWrap').style.display = 'block';
                    document.getElementById('editLogoPreview').src = t.logoPath;
                    document.getElementById('editLogoContainer').style.display = 'block';
                    document.getElementById('editLogoPlaceholder').style.display = 'none';
                } else {
                    document.getElementById('editLogoActuelWrap').style.display = 'none';
                    document.getElementById('editLogoContainer').style.display = 'none';
                    document.getElementById('editLogoPlaceholder').style.display = 'flex';
                }
                document.getElementById('editLogoFile').value = '';
                new bootstrap.Modal(document.getElementById('modalModifierTheme')).show();
            });
    }

    // ── Liens sociaux dynamiques ─────────────────────────────────────────────
    const typeOptions = ['Facebook','Instagram','X / Twitter','YouTube','TikTok','Site web','Autre'];

    function reindexLiens() {
        document.querySelectorAll('#liensList .lien-row').forEach(function(row, i) {
            row.querySelectorAll('[name]').forEach(function(el) {
                el.name = el.name.replace(/\[\d+\]/, '[' + i + ']');
            });
        });
    }

    document.getElementById('btnAjouterLien').addEventListener('click', function() {
        const list = document.getElementById('liensList');
        const idx = list.querySelectorAll('.lien-row').length;
        const opts = typeOptions.map(t => '<option value="' + t + '">' + t + '</option>').join('');
        const html = '<div class="row g-2 mb-2 lien-row align-items-center">'
            + '<div class="col-md-3"><select name="LiensSociaux[' + idx + '].Type" class="form-select form-select-sm">' + opts + '</select></div>'
            + '<div class="col-md-5"><input type="url" name="LiensSociaux[' + idx + '].Url" class="form-control form-control-sm" placeholder="https://..." /></div>'
            + '<div class="col-md-3"><input type="text" name="LiensSociaux[' + idx + '].Label" class="form-control form-control-sm" placeholder="Étiquette (optionnel)" /></div>'
            + '<div class="col-md-1"><button type="button" class="btn btn-sm btn-outline-danger btn-supprimer-lien"><i class="bi bi-trash"></i></button></div>'
            + '</div>';
        list.insertAdjacentHTML('beforeend', html);
    });

    document.addEventListener('click', function(e) {
        if (e.target.closest('.btn-supprimer-lien')) {
            e.target.closest('.lien-row').remove();
            reindexLiens();
        }
    });

    // ── Équipes adverses ─────────────────────────────────────────────────────
    function previewAdverseLogo(input, imgId, wrapId) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById(imgId).src = e.target.result;
                document.getElementById(wrapId).style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function ouvrirModifierAdverse(id) {
        fetch('/Ecole/GetAdverse/' + id)
            .then(r => r.json())
            .then(a => {
                document.getElementById('editAdvId').value = a.id;
                document.getElementById('editAdvTypeSport').value = a.typeSport;
                document.getElementById('editAdvNom').value = a.nom;
                document.getElementById('editAdvLieu').value = a.lieu || '';
                const wrap = document.getElementById('editAdvLogoWrap');
                const img = document.getElementById('editAdvLogoPreview');
                if (a.logoPath) {
                    img.src = a.logoPath;
                    wrap.style.display = 'block';
                } else {
                    wrap.style.display = 'none';
                }
                document.getElementById('editAdvLogoFile').value = '';
                new bootstrap.Modal(document.getElementById('modalModifierAdverse')).show();
            });
    }

// ── Filtre employés de l'école ───────────────────────────────────────────
    var employeEcoleInput = document.getElementById('employeEcoleRecherche');
    if (employeEcoleInput) {
        employeEcoleInput.addEventListener('input', function () {
            var q = this.value.toLowerCase().trim();
            var total = 0;
            document.querySelectorAll('.employe-item').forEach(function (item) {
                var match = !q
                    || item.dataset.nom.includes(q)
                    || item.dataset.titre.includes(q)
                    || item.dataset.equipe.includes(q);
                item.style.display = match ? '' : 'none';
                if (match) total++;
            });
            document.getElementById('employeEcoleAucun').style.display = total === 0 ? '' : 'none';
        });
    }

    // ── Filtre joueurs de l'école ─────────────────────────────────────────────
    function filtrerJoueurs() {
        var q     = (document.getElementById('joueurEcoleRecherche')?.value ?? '').toLowerCase().trim();
        var annee = document.getElementById('joueurAnneeFiltre')?.value ?? '';
        var total = 0;

        document.querySelectorAll('.joueur-ecole-row').forEach(function (row) {
            var nomMatch = !q || row.dataset.nom.includes(q) || row.dataset.fiche.includes(q);

            // Mettre à jour les cellules sport/niveau selon l'année sélectionnée
            var sportCell  = row.querySelector('.joueur-sport-cell');
            var niveauCell = row.querySelector('.joueur-niveau-cell');
            if (sportCell && niveauCell) {
                var equipeParAnnee = JSON.parse(row.dataset.equipesParAnnee || '{}');
                var eqs = annee ? (equipeParAnnee[annee] || []) : Object.values(equipeParAnnee).flat();
                // Dédupliquer par clé sport+niveau
                var seen = new Set();
                eqs = eqs.filter(function(e) {
                    var key = e.sportOrdre + '|' + e.niveauOrdre;
                    if (seen.has(key)) return false;
                    seen.add(key); return true;
                });
                // Trier : sport → niveau
                eqs.sort(function(a, b) {
                    if (a.sportOrdre !== b.sportOrdre) return a.sportOrdre - b.sportOrdre;
                    return a.niveauOrdre - b.niveauOrdre;
                });
                if (annee && eqs.length === 0) {
                    sportCell.innerHTML  = '<span class="text-muted fst-italic">Aucune équipe</span>';
                    niveauCell.innerHTML = '';
                } else {
                    sportCell.innerHTML  = eqs.map(function(e) { return '<div>' + e.sport  + '</div>'; }).join('');
                    niveauCell.innerHTML = eqs.map(function(e) { return '<div>' + e.niveau + '</div>'; }).join('');
                }
            }

            // Tous les joueurs actifs sont toujours visibles, seul le filtre texte s'applique
            row.style.display = nomMatch ? '' : 'none';
            if (nomMatch) total++;
        });

        var aucun = document.getElementById('joueurEcoleAucun');
        if (aucun) aucun.style.display = total === 0 ? '' : 'none';
    }

    // Auto-sélectionner l'année scolaire courante
    (function () {
        var now = new Date();
        var y = now.getFullYear();
        var m = now.getMonth() + 1; // 1-12
        var anneeCourante = m >= 9 ? (y + '-' + (y + 1)) : ((y - 1) + '-' + y);
        var sel = document.getElementById('joueurAnneeFiltre');
        if (sel) {
            var found = Array.from(sel.options).some(function (o) {
                if (o.value === anneeCourante) { sel.value = anneeCourante; return true; }
                return false;
            });
            if (!found && sel.options.length > 0) sel.value = sel.options[0].value;
        }
    })();

    filtrerJoueurs();

    document.getElementById('joueurEcoleRecherche')?.addEventListener('input', filtrerJoueurs);
    document.getElementById('joueurAnneeFiltre')?.addEventListener('change', filtrerJoueurs);
</script>
}
