                    </div>

                    @* Format attendu *@
                    <div class="border rounded p-3 bg-light">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-semibold small"><i class="bi bi-info-circle me-1 text-primary"></i>Format attendu</span>
                            <a asp-controller="Joueur" asp-action="GabaritExcelJoueurs"
                               class="btn btn-sm btn-outline-success">
                                <i class="bi bi-download me-1"></i>Télécharger le gabarit
                            </a>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-1" style="font-size:.8rem;">
                                <thead class="table-dark">
                                    <tr>
                                        <th>No Fiche</th>
                                        <th>Nom <span class="text-danger">*</span></th>
                                        <th>Prénom <span class="text-danger">*</span></th>
