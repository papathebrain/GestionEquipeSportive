@model GestionEquipeSportive.ViewModels.EcoleViewModel
@using GestionEquipeSportive.Models
@{
    bool isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "Nouvelle école" : "Modifier l'école";
    var themes          = ViewBag.Themes          as List<ThemeEcole>          ?? new();
    var adverses        = ViewBag.EquipesAdverses  as List<EquipeAdverse>       ?? new();
    var anneesScolaires = ViewBag.AnneesScolaires  as List<AnneeScolaireEcole>  ?? new();
    var sportsDict      = ViewBag.SportsDict       as List<(string Key, string Label)> ?? new();
    var joueurs         = ViewBag.Joueurs          as List<Joueur>              ?? new();
    var jeParJoueur           = ViewBag.JoueurEquipesParJoueur   as Dictionary<int, List<JoueurEquipe>> ?? new();
    var premierePhotoParJoueur = ViewBag.PremierePhotoParJoueur  as Dictionary<int, string?>             ?? new();
    var employes        = ViewBag.Employes         as List<Staff>               ?? new();
    var equipesParEmploye = ViewBag.EquipesParEmploye as Dictionary<string, List<Equipe?>> ?? new();
    var equipesEcole    = ViewBag.EquipesEcole     as List<Equipe>              ?? new();
}

<div class="mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Écoles</a></li>
            <li class="breadcrumb-item active">@(isNew ? "Nouvelle école" : "Modifier")</li>
        </ol>
    </nav>
    <h1 class="h3">
        <i class="bi @(isNew ? "bi-building-add" : "bi-pencil-square") me-2 text-primary"></i>
        @(isNew ? "Nouvelle école" : Model.Nom)
    </h1>
</div>

<ul class="nav nav-tabs mb-0" id="ecoleEditTabs">
    <li class="nav-item">
        <a class="nav-link active fw-semibold" data-bs-toggle="tab" href="#tab-info">
            <i class="bi bi-building me-1"></i>Informations
        </a>
    </li>
    @if (!isNew)
    {
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-themes">
            <i class="bi bi-palette me-1"></i>Thèmes
            @if (themes.Any()) { <span class="badge bg-secondary ms-1">@themes.Count</span> }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-annees">
            <i class="bi bi-calendar3 me-1"></i>Années scolaires
            @if (anneesScolaires.Any()) { <span class="badge bg-secondary ms-1">@anneesScolaires.Count</span> }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-adverses">
            <i class="bi bi-shield-fill-x me-1"></i>Équipes adverses
            @if (adverses.Any()) { <span class="badge bg-secondary ms-1">@adverses.Count</span> }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-joueurs">
            <i class="bi bi-people me-1"></i>Joueurs
            @if (joueurs.Any()) { <span class="badge bg-secondary ms-1">@joueurs.Count</span> }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#tab-employes">
            <i class="bi bi-person-badge me-1"></i>Employés
            @if (employes.Any()) { <span class="badge bg-secondary ms-1">@employes.Count</span> }
        </a>
    </li>
    }
</ul>

<div class="tab-content border border-top-0 rounded-bottom bg-white shadow-sm p-4 mb-4">

    @* ── Onglet Informations ── *@
    <div class="tab-pane fade show active" id="tab-info">
        <div class="row g-4">
            <div class="col-lg-7">
                <form asp-action="@(isNew ? "Create" : "Edit")" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Nom" class="form-label fw-semibold"></label>
                        <input asp-for="Nom" class="form-control" />
                        <span asp-validation-for="Nom" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NomEquipe" class="form-label fw-semibold">Nom d'équipe par défaut</label>
                        <input asp-for="NomEquipe" class="form-control" />
                        <div class="form-text">Utilisé si aucun thème n'est assigné à une équipe.</div>
                        <span asp-validation-for="NomEquipe" class="text-danger small"></span>
                    </div>

                    @* ── Liens sociaux ── *@
                    <div class="mt-3">
                        <label class="form-label fw-semibold"><i class="bi bi-share me-1"></i>Liens internet / réseaux sociaux</label>
                        <div id="liensList">
                            @for (int i = 0; i < Model.LiensSociaux.Count; i++)
                            {
                                <div class="row g-2 mb-2 lien-row align-items-center">
                                    <div class="col-md-3">
                                        <select name="LiensSociaux[@i].Type" class="form-select form-select-sm">
                                            @foreach (var t in new[] { "Facebook","Instagram","X / Twitter","YouTube","TikTok","Site web","Autre" })
                                            {
                                                if (Model.LiensSociaux[i].Type == t)
                                                { <option value="@t" selected>@t</option> }
                                                else
                                                { <option value="@t">@t</option> }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-5">
                                        <input type="url" name="LiensSociaux[@i].Url" class="form-control form-control-sm"
                                               placeholder="https://..." value="@Model.LiensSociaux[i].Url" />
                                    </div>
                                    <div class="col-md-3">
                                        <input type="text" name="LiensSociaux[@i].Label" class="form-control form-control-sm"
                                               placeholder="Étiquette (optionnel)" value="@(Model.LiensSociaux[i].Label ?? "")" />
                                    </div>
                                    <div class="col-md-1">
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-supprimer-lien">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                        <button type="button" id="btnAjouterLien" class="btn btn-sm btn-outline-primary mt-1">
                            <i class="bi bi-plus-circle me-1"></i>Ajouter un lien
                        </button>
                        <div class="form-text">Affiché sur la page publique de chaque équipe.</div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>@(isNew ? "Créer l'école" : "Enregistrer")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* ── Onglet Thèmes ── *@
    <div class="tab-pane fade" id="tab-themes">
        <div class="d-flex justify-content-end mb-3">
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalAjouterTheme">
                <i class="bi bi-plus-circle me-1"></i>Ajouter un thème
            </button>
        </div>
        @if (!themes.Any())
        {
            <p class="text-muted text-center py-3">Aucun thème défini. Ajoutez un thème pour personnaliser vos équipes.</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var theme in themes)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="theme-card border rounded overflow-hidden">
                            <div class="theme-header d-flex align-items-center gap-2 p-2 text-white"
                                 style="background-color: @theme.CouleurPrimaire;">
                                @if (!string.IsNullOrEmpty(theme.LogoPath))
                                {
                                    <img src="@theme.LogoPath" alt="Logo" style="width:36px;height:36px;object-fit:contain;background:transparent;" />
                                }
                                else
                                {
                                    <div style="width:36px;height:36px;background:rgba(255,255,255,0.2);border-radius:4px;display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-building-fill"></i>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <div class="fw-bold">@theme.NomEquipe</div>
                                </div>
                                <div class="d-flex gap-1">
                                    <div style="width:16px;height:16px;border-radius:50%;background:@theme.CouleurPrimaire;border:2px solid rgba(255,255,255,0.5);" title="@theme.CouleurPrimaire"></div>
                                    <div style="width:16px;height:16px;border-radius:50%;background:@theme.CouleurSecondaire;border:2px solid rgba(255,255,255,0.5);" title="@theme.CouleurSecondaire"></div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2 px-2 py-1" style="background:#f8f9fa;">
                                <div class="d-flex gap-1">
                                    <span class="badge" style="background-color:@theme.CouleurPrimaire;">@theme.CouleurPrimaire</span>
                                    <span class="badge" style="background-color:@theme.CouleurSecondaire;">@theme.CouleurSecondaire</span>
                                </div>
                                <div class="ms-auto d-flex gap-1">
                                    <button type="button" class="btn btn-sm btn-outline-warning py-0 px-2"
                                            onclick="ouvrirModifierTheme(@theme.Id)" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="SupprimerTheme" method="post" class="d-inline"
                                          onsubmit="return confirm('Supprimer ce thème ?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@theme.Id" />
                                        <input type="hidden" name="ecoleId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2" title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* ── Onglet Années scolaires ── *@
    <div class="tab-pane fade" id="tab-annees">
        <p class="text-muted small mb-3">Les années scolaires configurées ici seront disponibles dans les menus déroulants lors de la création/modification d'équipes.</p>
        @if (anneesScolaires.Any())
        {
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var annee in anneesScolaires)
                {
                    <div class="d-flex align-items-center gap-1 border rounded px-2 py-1 bg-light">
                        <span class="small fw-semibold">@annee.AnneeScolaire</span>
                        <form asp-action="SupprimerAnnee" method="post" class="d-inline"
                              onsubmit="return confirm('Supprimer l\'année @annee.AnneeScolaire ?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@annee.Id" />
                            <input type="hidden" name="ecoleId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0 ms-1" title="Supprimer">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
        <form asp-action="AjouterAnnee" method="post" class="d-flex gap-2 align-items-end" style="max-width:320px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ecoleId" value="@Model.Id" />
            <div class="flex-grow-1">
                <label class="form-label small fw-semibold mb-1">Ajouter une année</label>
                <input type="text" name="annee" class="form-control form-control-sm"
                       placeholder="Ex: 2025-2026" pattern="\d{4}-\d{4}"
                       title="Format : AAAA-AAAA (ex: 2025-2026)" required />
            </div>
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Ajouter
            </button>
        </form>
    </div>

    @* ── Onglet Équipes adverses ── *@
    <div class="tab-pane fade" id="tab-adverses">
        <div class="d-flex justify-content-end mb-3">
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalAjouterAdverse">
                <i class="bi bi-plus-circle me-1"></i>Ajouter une équipe adverse
            </button>
        </div>
        @if (!adverses.Any())
        {
            <p class="text-muted text-center py-3">Aucune équipe adverse définie. Ajoutez des équipes pour les sélectionner lors de la création de matchs.</p>
        }
        else
        {
            @foreach (var sportGroup in adverses.GroupBy(a => a.TypeSport).OrderBy(g => g.Key))
            {
                var sportLabel = sportsDict.FirstOrDefault(s => s.Key == sportGroup.Key).Label ?? sportGroup.Key;
                <div class="mb-4">
                    <div class="text-uppercase fw-bold small text-muted border-bottom pb-1 mb-2" style="letter-spacing:.05em;">
                        <i class="bi bi-shield me-1"></i>@sportLabel
                    </div>
                    <div class="row g-2">
                        @foreach (var adv in sportGroup.OrderBy(a => a.Nom))
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="border rounded p-2 d-flex align-items-center gap-2 bg-light">
                                    @if (!string.IsNullOrEmpty(adv.LogoPath))
                                    {
                                        <img src="@adv.LogoPath" alt="Logo" style="width:32px;height:32px;object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <div style="width:32px;height:32px;background:#dee2e6;border-radius:4px;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-shield text-muted"></i>
                                        </div>
                                    }
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="fw-semibold small text-truncate">@adv.Nom</div>
                                        @if (!string.IsNullOrEmpty(adv.Lieu))
                                        {
                                            <div class="text-muted" style="font-size:.75rem;">
                                                <i class="bi bi-geo-alt me-1"></i>@adv.Lieu
                                            </div>
                                        }
                                    </div>
                                    <div class="d-flex gap-1 flex-shrink-0">
                                        <button type="button" class="btn btn-sm btn-outline-warning py-0 px-1"
                                                onclick="ouvrirModifierAdverse(@adv.Id)" title="Modifier">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-action="SupprimerAdverse" method="post" class="d-inline"
                                              onsubmit="return confirm('Supprimer cette équipe adverse ?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@adv.Id" />
                                            <input type="hidden" name="ecoleId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @* ── Onglet Joueurs ── *@
    <div class="tab-pane fade" id="tab-joueurs">
        @{
            // Années scolaires disponibles (issues des équipes de l'école)
            var anneesDisponibles = equipesEcole
                .Select(e => e.AnneeScolaire)
                .Where(a => !string.IsNullOrEmpty(a))
                .Distinct()
                .OrderByDescending(a => a)
                .ToList();

            // Construire la structure : joueur → liste (equipe, joueurEquipe) pour l'année filtrée
            // On construit ici pour toutes les années; le filtre se fait côté JS
            // Pour chaque joueur : ses JoueurEquipes par annéeScolaire
            var lignesTout = new List<(Joueur J, JoueurEquipe? Je, Equipe? Eq)>();
            foreach (var j in joueurs)
            {
                if (jeParJoueur.TryGetValue(j.Id, out var jes) && jes.Any())
                    foreach (var je in jes.Where(x => x.Equipe != null))
                        lignesTout.Add((j, je, je.Equipe));
                // Toujours ajouter une ligne "sans équipe" pour chaque joueur (pour l'option "Tous")
                if (!jeParJoueur.TryGetValue(j.Id, out var _jes2) || !_jes2.Any())
                    lignesTout.Add((j, null, null));
            }
        }

        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <div class="input-group input-group-sm" style="max-width:220px;">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="joueurEcoleRecherche" class="form-control" placeholder="Nom, fiche…" autocomplete="off" />
                </div>
                <select id="joueurAnneeFiltre" class="form-select form-select-sm" style="max-width:160px;">
                    @foreach (var a in anneesDisponibles)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2">
                @if (equipesEcole.Any())
                {
                    <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#modalImporterJoueursExcel">
                        <i class="bi bi-file-earmark-excel me-1"></i>Importer Excel
                    </button>
                }
                <a asp-controller="Joueur" asp-action="Create" asp-route-ecoleId="@Model.Id"
                   class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Nouveau joueur
                </a>
            </div>
        </div>

        @if (!joueurs.Any())
        {
            <p class="text-muted text-center py-4 mb-0">
                <i class="bi bi-people me-1"></i>Aucun joueur dans cette école.
            </p>
        }
        else
        {
            <table class="table table-sm table-hover align-middle" id="joueurEcoleTable">
                <thead class="table-light">
                    <tr>
                        <th style="width:36px;"></th>
                        <th>Nom</th>
                        <th>Fiche</th>
                        <th>Statut</th>
                        <th>Sport</th>
                        <th>Niveau</th>
                        <th style="width:40px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var j in joueurs.Where(j => j.Actif))
                    {
                        var jesDuJoueur = jeParJoueur.TryGetValue(j.Id, out var jl) ? jl : new();
                        var photoSrc = jesDuJoueur.FirstOrDefault(x => !string.IsNullOrEmpty(x.PhotoPath))?.PhotoPath
                            ?? (premierePhotoParJoueur.TryGetValue(j.Id, out var pm) ? pm : null);
                        // Sérialiser les équipes par année pour le JS
                        var equipeParAnnee = jesDuJoueur
                            .Where(je => je.Equipe != null)
                            .GroupBy(je => je.Equipe!.AnneeScolaire ?? "")
                            .ToDictionary(g => g.Key, g => g.Select(je => new {
                                nom          = je.Equipe!.Nom,
                                sportOrdre   = (int)je.Equipe!.TypeSport,
                                sport        = je.Equipe!.TypeSport switch {
                                    TypeSport.FootballAmericain => "Football",
                                    TypeSport.FlagFootball      => "Flag Football",
                                    TypeSport.Soccer            => "Soccer",
                                    TypeSport.Volleyball        => "Volleyball",
                                    TypeSport.Hockey            => "Hockey",
                                    _                           => je.Equipe!.TypeSport.ToString()
                                },
                                niveauOrdre  = (int)je.Equipe!.Niveau,
                                niveau       = je.Equipe!.Niveau switch {
                                    NiveauEquipe.Juvenil => "Juvénile",
                                    NiveauEquipe.PeeWee  => "Pee-Wee",
                                    _                    => je.Equipe!.Niveau.ToString()
                                }
                            }).ToList());
                        var equipeParAnneeJson = System.Text.Json.JsonSerializer.Serialize(equipeParAnnee);
                        // Toutes les années où ce joueur apparaît
                        var anneesJoueur = equipeParAnnee.Keys.ToList();
                        var anneesJson = System.Text.Json.JsonSerializer.Serialize(anneesJoueur);
                        <tr class="joueur-ecole-row"
                            data-nom="@($"{j.Prenom} {j.Nom}".ToLower())"
                            data-fiche="@(j.NoFiche?.ToLower() ?? "")"
                            data-annees="@anneesJson"
                            data-equipes-par-annee="@equipeParAnneeJson">
                            <td>
                                @if (!string.IsNullOrEmpty(photoSrc) && j.ConsentementPhoto)
                                {
                                    <img src="@photoSrc" class="rounded-circle"
                                         style="width:32px;height:32px;object-fit:cover;" />
                                }
                                else if (!string.IsNullOrEmpty(Model.LogoPathActuel))
                                {
                                    <img src="@Model.LogoPathActuel" class="rounded-circle"
                                         style="width:32px;height:32px;object-fit:contain;padding:3px;background:#f8f9fa;" />
                                }
                                else
                                {
                                    <div class="rounded-circle d-flex align-items-center justify-content-center bg-light text-muted"
                                         style="width:32px;height:32px;">
                                        <i class="bi bi-person"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="fw-semibold">@j.Prenom @j.Nom</span>
                            </td>
                            <td class="text-muted small">@j.NoFiche</td>
                            <td>
                                @if (j.Actif)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle small">Actif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle small">Inactif</span>
                                }
                            </td>
                            <td class="joueur-sport-cell small"></td>
                            <td class="joueur-niveau-cell small"></td>
                            <td>
                                <a asp-controller="Joueur" asp-action="Edit" asp-route-id="@j.Id"
                                   class="btn btn-sm btn-outline-warning py-0 px-1" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <p id="joueurEcoleAucun" class="text-muted text-center py-2 mb-0" style="display:none;">
                <i class="bi bi-search me-1"></i>Aucun joueur trouvé.
            </p>
        }
    </div>

    @* ── Onglet Employés ── *@
    <div class="tab-pane fade" id="tab-employes">
        @if (!employes.Any())
        {
            <p class="text-muted text-center py-4 mb-0">
                <i class="bi bi-person-badge me-1"></i>Aucun employé dans cette école.
            </p>
        }
        else
        {
            <div class="d-flex justify-content-end mb-3">
                <div class="input-group input-group-sm" style="max-width:240px;">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="employeEcoleRecherche" class="form-control" placeholder="Nom, titre, équipe…" autocomplete="off" />
                </div>
            </div>

            <div class="row g-3" id="employesList">
                @foreach (var emp in employes)
                {
                    var cleEmp = emp.CleUnique.HasValue ? emp.CleUnique.Value.ToString() : $"__id_{emp.Id}";
                    var eqs = equipesParEmploye.ContainsKey(cleEmp) ? equipesParEmploye[cleEmp] : new();
                    var equipeNoms = string.Join(", ", eqs.Where(e => e != null).Select(e => e!.Nom));
                    <div class="col-12 col-md-6 col-lg-4 employe-item"
                         data-nom="@($"{emp.Prenom} {emp.Nom}".ToLower())"
                         data-titre="@emp.Titre.ToLower()"
                         data-equipe="@equipeNoms.ToLower()">
                        <div class="d-flex align-items-center gap-3 p-3 rounded border">
                            @if (!string.IsNullOrEmpty(emp.PhotoPath))
                            {
                                <img src="@emp.PhotoPath" class="rounded-circle flex-shrink-0"
                                     style="width:48px;height:48px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center bg-secondary text-white"
                                     style="width:48px;height:48px;font-size:1.2rem;">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                            }
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-semibold text-truncate">@emp.Prenom @emp.Nom</div>
                                <div class="small text-muted text-truncate">@emp.Titre</div>
                                @if (eqs.Count > 1)
                                {
                                    <div class="small mt-1 d-flex flex-wrap gap-1">
                                        @foreach (var eq in eqs.Where(e => e != null))
                                        {
                                            <span class="badge bg-light text-dark border">@eq!.Nom</span>
                                        }
                                    </div>
                                }
                                else if (eqs.Count == 1)
                                {
                                    <div class="small text-muted">@eqs[0]?.Nom</div>
                                }
                            </div>
                            <a asp-controller="Staff" asp-action="Edit" asp-route-id="@emp.Id"
                               class="btn btn-sm btn-outline-warning py-0 px-2 flex-shrink-0" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
            <p id="employeEcoleAucun" class="text-muted text-center py-2 mb-0 mt-2" style="display:none;">
                <i class="bi bi-search me-1"></i>Aucun employé trouvé.
            </p>
        }
    </div>

</div>


@* ── Modal Importer joueurs Excel ── *@
<div class="modal fade" id="modalImporterJoueursExcel" tabindex="-1">
