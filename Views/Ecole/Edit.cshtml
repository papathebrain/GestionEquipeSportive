@model GestionEquipeSportive.ViewModels.EcoleViewModel
@using GestionEquipeSportive.Models
@{
    ViewData["Title"] = "Modifier l'école";
    var themes = ViewBag.Themes as List<ThemeEcole> ?? new List<ThemeEcole>();
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Écoles</a></li>
            <li class="breadcrumb-item active">Modifier</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-pencil-square me-2 text-primary"></i>Modifier l'école</h1>
</div>

<div class="row g-4">
    @* ── Informations de l'école ── *@
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-building me-2"></i>Informations de l'école</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Nom" class="form-label fw-semibold"></label>
                        <input asp-for="Nom" class="form-control" />
                        <span asp-validation-for="Nom" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NomEquipe" class="form-label fw-semibold">
                            Nom d'équipe par défaut
                        </label>
                        <input asp-for="NomEquipe" class="form-control" />
                        <div class="form-text">Utilisé si aucun thème n'est assigné à une équipe.</div>
                        <span asp-validation-for="NomEquipe" class="text-danger small"></span>
                    </div>

                    @* ── Liens sociaux ── *@
                    <div class="mt-3">
                        <label class="form-label fw-semibold"><i class="bi bi-share me-1"></i>Liens internet / réseaux sociaux</label>
                        <div id="liensList">
                            @for (int i = 0; i < Model.LiensSociaux.Count; i++)
                            {
                                <div class="row g-2 mb-2 lien-row align-items-center">
                                    <div class="col-md-3">
                                        <select name="LiensSociaux[@i].Type" class="form-select form-select-sm">
                                            @foreach (var t in new[] { "Facebook","Instagram","X / Twitter","YouTube","TikTok","Site web","Autre" })
                                            {
                                                if (Model.LiensSociaux[i].Type == t)
                                                { <option value="@t" selected>@t</option> }
                                                else
                                                { <option value="@t">@t</option> }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-5">
                                        <input type="url" name="LiensSociaux[@i].Url" class="form-control form-control-sm"
                                               placeholder="https://..." value="@Model.LiensSociaux[i].Url" />
                                    </div>
                                    <div class="col-md-3">
                                        <input type="text" name="LiensSociaux[@i].Label" class="form-control form-control-sm"
                                               placeholder="Étiquette (optionnel)" value="@(Model.LiensSociaux[i].Label ?? "")" />
                                    </div>
                                    <div class="col-md-1">
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-supprimer-lien">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                        <button type="button" id="btnAjouterLien" class="btn btn-sm btn-outline-primary mt-1">
                            <i class="bi bi-plus-circle me-1"></i>Ajouter un lien
                        </button>
                        <div class="form-text">Affiché sur la page publique de chaque équipe.</div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Enregistrer
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Annuler
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* ── Thèmes ── *@
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-palette me-2"></i>Thèmes d'équipe</h5>
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalAjouterTheme">
                    <i class="bi bi-plus-circle me-1"></i>Ajouter
                </button>
            </div>
            <div class="card-body p-2">
                @if (!themes.Any())
                {
                    <p class="text-muted small p-2">Aucun thème défini. Ajoutez un thème pour personnaliser vos équipes.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2 p-1">
                        @foreach (var theme in themes)
                        {
                            <div class="theme-card border rounded overflow-hidden">
                                <div class="theme-header d-flex align-items-center gap-2 p-2 text-white"
                                     style="background-color: @theme.CouleurPrimaire;">
                                    @if (!string.IsNullOrEmpty(theme.LogoPath))
                                    {
                                        <img src="@theme.LogoPath" alt="Logo" style="width:36px;height:36px;object-fit:contain;background:transparent;" />
                                    }
                                    else
                                    {
                                        <div style="width:36px;height:36px;background:rgba(255,255,255,0.2);border-radius:4px;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-building-fill"></i>
                                        </div>
                                    }
                                    <div class="flex-grow-1">
                                        <div class="fw-bold">@theme.NomEquipe</div>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <div style="width:16px;height:16px;border-radius:50%;background:@theme.CouleurPrimaire;border:2px solid rgba(255,255,255,0.5);" title="@theme.CouleurPrimaire"></div>
                                        <div style="width:16px;height:16px;border-radius:50%;background:@theme.CouleurSecondaire;border:2px solid rgba(255,255,255,0.5);" title="@theme.CouleurSecondaire"></div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2 px-2 py-1" style="background:#f8f9fa;">
                                    <div class="d-flex gap-1">
                                        <span class="badge" style="background-color:@theme.CouleurPrimaire;">@theme.CouleurPrimaire</span>
                                        <span class="badge" style="background-color:@theme.CouleurSecondaire;">@theme.CouleurSecondaire</span>
                                    </div>
                                    <div class="ms-auto d-flex gap-1">
                                        <button type="button" class="btn btn-sm btn-outline-warning py-0 px-2"
                                                onclick="ouvrirModifierTheme(@theme.Id)"
                                                title="Modifier">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-action="SupprimerTheme" method="post" class="d-inline"
                                              onsubmit="return confirm('Supprimer ce thème ?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@theme.Id" />
                                            <input type="hidden" name="ecoleId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Modal Ajouter Thème ── *@
<div class="modal fade" id="modalAjouterTheme" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="AjouterTheme" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="EcoleId" value="@Model.Id" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-palette me-2"></i>Ajouter un thème</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Nom d'équipe <span class="text-danger">*</span></label>
                            <input type="text" name="NomEquipe" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Couleur primaire</label>
                            <div class="input-group">
                                <input type="color" id="addCouleurPrimaireInput" name="CouleurPrimaire"
                                       class="form-control form-control-color" value="#1a3a5c"
                                       oninput="syncAddColor('add','Primaire',this.value)" />
                                <input type="text" id="addCouleurPrimaireText" class="form-control"
                                       value="#1a3a5c" oninput="syncAddColorText('add','Primaire',this.value)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Couleur secondaire</label>
                            <div class="input-group">
                                <input type="color" id="addCouleurSecondaireInput" name="CouleurSecondaire"
                                       class="form-control form-control-color" value="#e8a020"
                                       oninput="syncAddColor('add','Secondaire',this.value)" />
                                <input type="text" id="addCouleurSecondaireText" class="form-control"
                                       value="#e8a020" oninput="syncAddColorText('add','Secondaire',this.value)" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Logo</label>
                            <input type="file" name="LogoFile" class="form-control" accept="image/*"
                                   onchange="previewThemeLogo(this,'addLogoPreview','addLogoContainer','addLogoPlaceholder')" />
                        </div>
                        @* Aperçu en temps réel *@
                        <div class="col-12">
                            <div id="addThemePreview" class="rounded p-2 text-white d-flex align-items-center gap-2"
                                 style="background-color:#1a3a5c;">
                                <div id="addLogoContainer" style="display:none;">
                                    <img id="addLogoPreview" src="#" alt="Logo" style="width:40px;height:40px;object-fit:contain;" />
                                </div>
                                <div id="addLogoPlaceholder" style="width:40px;height:40px;background:rgba(255,255,255,0.2);border-radius:4px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-building-fill"></i>
                                </div>
                                <span class="fw-bold" id="addPreviewNom">Nom d'équipe</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Ajouter</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── Modal Modifier Thème ── *@
<div class="modal fade" id="modalModifierTheme" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="ModifierTheme" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editThemeId" />
                <input type="hidden" name="EcoleId" value="@Model.Id" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Modifier le thème</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Nom d'équipe <span class="text-danger">*</span></label>
                            <input type="text" name="NomEquipe" id="editNomEquipe" class="form-control" required
                                   oninput="document.getElementById('editPreviewNom').textContent = this.value || 'Nom d\'équipe'" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Couleur primaire</label>
                            <div class="input-group">
                                <input type="color" id="editCouleurPrimaireInput" name="CouleurPrimaire"
                                       class="form-control form-control-color" value="#1a3a5c"
                                       oninput="syncAddColor('edit','Primaire',this.value)" />
                                <input type="text" id="editCouleurPrimaireText" class="form-control"
                                       value="#1a3a5c" oninput="syncAddColorText('edit','Primaire',this.value)" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Couleur secondaire</label>
                            <div class="input-group">
                                <input type="color" id="editCouleurSecondaireInput" name="CouleurSecondaire"
                                       class="form-control form-control-color" value="#e8a020"
                                       oninput="syncAddColor('edit','Secondaire',this.value)" />
                                <input type="text" id="editCouleurSecondaireText" class="form-control"
                                       value="#e8a020" oninput="syncAddColorText('edit','Secondaire',this.value)" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Nouveau logo (optionnel)</label>
                            <input type="file" name="LogoFile" id="editLogoFile" class="form-control" accept="image/*"
                                   onchange="previewThemeLogo(this,'editLogoPreview','editLogoContainer','editLogoPlaceholder')" />
                            <div id="editLogoActuelWrap" class="mt-1" style="display:none;">
                                <small class="text-muted">Logo actuel : </small>
                                <img id="editLogoActuel" src="#" alt="Logo actuel" style="height:30px;object-fit:contain;" />
                            </div>
                        </div>
                        @* Aperçu *@
                        <div class="col-12">
                            <div id="editThemePreview" class="rounded p-2 text-white d-flex align-items-center gap-2"
                                 style="background-color:#1a3a5c;">
                                <div id="editLogoContainer" style="display:none;">
                                    <img id="editLogoPreview" src="#" alt="Logo" style="width:40px;height:40px;object-fit:contain;" />
                                </div>
                                <div id="editLogoPlaceholder" style="width:40px;height:40px;background:rgba(255,255,255,0.2);border-radius:4px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-building-fill"></i>
                                </div>
                                <span class="fw-bold" id="editPreviewNom">Nom d'équipe</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Sync nom de l'équipe dans aperçu ajouter ────────────────────────────
    document.querySelector('#modalAjouterTheme [name="NomEquipe"]')?.addEventListener('input', function() {
        document.getElementById('addPreviewNom').textContent = this.value || "Nom d'équipe";
    });

    // ── Sync couleurs ────────────────────────────────────────────────────────
    function syncAddColor(prefix, which, value) {
        document.getElementById(prefix + 'Couleur' + which + 'Text').value = value;
        updateThemePreview(prefix);
    }
    function syncAddColorText(prefix, which, value) {
        if (/^#[0-9A-Fa-f]{6}$/.test(value)) {
            document.getElementById(prefix + 'Couleur' + which + 'Input').value = value;
            updateThemePreview(prefix);
        }
    }
    function updateThemePreview(prefix) {
        const p = document.getElementById(prefix + 'CouleurPrimaireInput').value;
        document.getElementById(prefix + 'ThemePreview').style.backgroundColor = p;
    }

    // ── Preview logo ─────────────────────────────────────────────────────────
    function previewThemeLogo(input, imgId, containerId, placeholderId) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById(imgId).src = e.target.result;
                document.getElementById(containerId).style.display = 'block';
                document.getElementById(placeholderId).style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    // ── Ouvrir modal modifier ────────────────────────────────────────────────
    function ouvrirModifierTheme(id) {
        fetch('/Ecole/GetTheme/' + id)
            .then(r => r.json())
            .then(t => {
                document.getElementById('editThemeId').value = t.id;
                document.getElementById('editNomEquipe').value = t.nomEquipe;
                document.getElementById('editPreviewNom').textContent = t.nomEquipe;
                document.getElementById('editCouleurPrimaireInput').value = t.couleurPrimaire;
                document.getElementById('editCouleurPrimaireText').value = t.couleurPrimaire;
                document.getElementById('editCouleurSecondaireInput').value = t.couleurSecondaire;
                document.getElementById('editCouleurSecondaireText').value = t.couleurSecondaire;
                document.getElementById('editThemePreview').style.backgroundColor = t.couleurPrimaire;
                // Logo actuel
                if (t.logoPath) {
                    document.getElementById('editLogoActuel').src = t.logoPath;
                    document.getElementById('editLogoActuelWrap').style.display = 'block';
                    document.getElementById('editLogoPreview').src = t.logoPath;
                    document.getElementById('editLogoContainer').style.display = 'block';
                    document.getElementById('editLogoPlaceholder').style.display = 'none';
                } else {
                    document.getElementById('editLogoActuelWrap').style.display = 'none';
                    document.getElementById('editLogoContainer').style.display = 'none';
                    document.getElementById('editLogoPlaceholder').style.display = 'flex';
                }
                // Réinitialiser input file
                document.getElementById('editLogoFile').value = '';
                new bootstrap.Modal(document.getElementById('modalModifierTheme')).show();
            });
    }

    // ── Liens sociaux dynamiques ─────────────────────────────────────────────
    const typeOptions = ['Facebook','Instagram','X / Twitter','YouTube','TikTok','Site web','Autre'];

    function reindexLiens() {
        document.querySelectorAll('#liensList .lien-row').forEach(function(row, i) {
            row.querySelectorAll('[name]').forEach(function(el) {
                el.name = el.name.replace(/\[\d+\]/, '[' + i + ']');
            });
        });
    }

    document.getElementById('btnAjouterLien').addEventListener('click', function() {
        const list = document.getElementById('liensList');
        const idx = list.querySelectorAll('.lien-row').length;
        const opts = typeOptions.map(t => '<option value="' + t + '">' + t + '</option>').join('');
        const html = '<div class="row g-2 mb-2 lien-row align-items-center">'
            + '<div class="col-md-3"><select name="LiensSociaux[' + idx + '].Type" class="form-select form-select-sm">' + opts + '</select></div>'
            + '<div class="col-md-5"><input type="url" name="LiensSociaux[' + idx + '].Url" class="form-control form-control-sm" placeholder="https://..." /></div>'
            + '<div class="col-md-3"><input type="text" name="LiensSociaux[' + idx + '].Label" class="form-control form-control-sm" placeholder="Étiquette (optionnel)" /></div>'
            + '<div class="col-md-1"><button type="button" class="btn btn-sm btn-outline-danger btn-supprimer-lien"><i class="bi bi-trash"></i></button></div>'
            + '</div>';
        list.insertAdjacentHTML('beforeend', html);
    });

    document.addEventListener('click', function(e) {
        if (e.target.closest('.btn-supprimer-lien')) {
            e.target.closest('.lien-row').remove();
            reindexLiens();
        }
    });
</script>
}
