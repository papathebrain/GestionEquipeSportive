@using GestionEquipeSportive.Models
@{
    ViewData["Title"] = "Gestion des dictionnaires";
    var toutes      = ViewBag.Entrees as List<DictionnaireEntree> ?? new List<DictionnaireEntree>();
    var sportsDico  = ViewBag.Sports  as List<DictionnaireEntree> ?? new List<DictionnaireEntree>();
    var sportsActifs = (ViewBag.SportsActifs as List<(string Key, string Label)>) ?? new List<(string, string)>();

    List<DictionnaireEntree> EntreesObjParCategorieSport(string categorie, string sport)
        => toutes.Where(e => e.Categorie == categorie && e.Sport == sport)
                 .OrderBy(e => e.Ordre).ThenBy(e => e.Valeur)
                 .ToList();

string firstTab = sportsActifs.Any() ? sportsActifs[0].Key : "Sports";
}

<div class="mb-4">
    <h1 class="h3"><i class="bi bi-journals me-2 text-primary"></i>Gestion des dictionnaires</h1>
    <p class="text-muted">Gérez les valeurs suggérées pour les positions de joueurs et les titres du staff.</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Onglets sports (seulement les actifs + onglet Sports) ── *@
<ul class="nav nav-tabs mb-4" id="dictTabs" role="tablist">
    @{ bool firstSport = true; }
    @foreach (var (sportKey, sportLabel) in sportsActifs)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link @(firstSport ? "active" : "")"
                    id="tab-@sportKey" data-bs-toggle="tab"
                    data-bs-target="#pane-@sportKey" type="button" role="tab">
                @sportLabel
            </button>
        </li>
        firstSport = false;
    }
    <li class="nav-item" role="presentation">
        <button class="nav-link @(!sportsActifs.Any() ? "active" : "")"
                id="tab-Sports" data-bs-toggle="tab" data-bs-target="#pane-Sports" type="button" role="tab">
            <i class="bi bi-trophy me-1"></i>Sports
        </button>
    </li>
</ul>

<div class="tab-content" id="dictTabsContent">

    @* ── Pane par sport actif ── *@
    @{ bool firstPane = true; }
    @foreach (var (sportKey, sportLabel) in sportsActifs)
    {
        var positions    = EntreesObjParCategorieSport("Position", sportKey);
        var posSpec      = EntreesObjParCategorieSport("PositionSpecifique", sportKey);
        var titresSport  = EntreesObjParCategorieSport("TitreStaff", sportKey);
        var niveauxSport = EntreesObjParCategorieSport("Niveau", sportKey);

        <div class="tab-pane fade @(firstPane ? "show active" : "")"
             id="pane-@sportKey" role="tabpanel">

            @* ── Sous-onglets ── *@
            <ul class="nav nav-pills mb-4" id="subTabs-@sportKey" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab"
                            data-bs-target="#sub-joueurs-@sportKey" type="button">
                        <i class="bi bi-person-running me-1"></i>Joueurs
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab"
                            data-bs-target="#sub-staff-@sportKey" type="button">
                        <i class="bi bi-whistle me-1"></i>Staff / Entraîneurs
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab"
                            data-bs-target="#sub-niveaux-@sportKey" type="button">
                        <i class="bi bi-bar-chart-steps me-1"></i>Niveaux
                    </button>
                </li>
            </ul>

            <div class="tab-content">

                @* ── Sous-onglet Joueurs ── *@
                <div class="tab-pane fade show active" id="sub-joueurs-@sportKey" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-12">
                            @await Html.PartialAsync("_DictSection", new GestionEquipeSportive.ViewModels.DictSectionViewModel {
                                Titre = "Positions", Icon = "bi-list-ul",
                                Entrees = positions, Categorie = "Position", Sport = sportKey,
                                Placeholder = "Nouvelle position..."
                            })
                        </div>
                    </div>
                    <div class="row g-4 mt-2">
                        <div class="col-md-12">
                            @await Html.PartialAsync("_DictSection", new GestionEquipeSportive.ViewModels.DictSectionViewModel {
                                Titre = "Positions spécifiques", Icon = "bi-list-nested",
                                Entrees = posSpec, Categorie = "PositionSpecifique", Sport = sportKey,
                                Placeholder = "Nouvelle position spécifique...",
                                ParentPositions = positions.Select(p => p.Valeur).ToList()
                            })
                        </div>
                    </div>
                </div>

                @* ── Sous-onglet Staff ── *@
                <div class="tab-pane fade" id="sub-staff-@sportKey" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-12">
                            @await Html.PartialAsync("_DictSection", new GestionEquipeSportive.ViewModels.DictSectionViewModel {
                                Titre = "Titres", Icon = "bi-person-badge",
                                Entrees = titresSport, Categorie = "TitreStaff", Sport = sportKey,
                                Placeholder = "Nouveau titre..."
                            })
                        </div>
                    </div>
                </div>

                @* ── Sous-onglet Niveaux ── *@
                <div class="tab-pane fade" id="sub-niveaux-@sportKey" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-12">
                            @await Html.PartialAsync("_DictSection", new GestionEquipeSportive.ViewModels.DictSectionViewModel {
                                Titre = "Niveaux", Icon = "bi-bar-chart-steps",
                                Entrees = niveauxSport, Categorie = "Niveau", Sport = sportKey,
                                Placeholder = "Nouveau niveau..."
                            })
                        </div>
                    </div>
                </div>

            </div>
        </div>
        firstPane = false;
    }

    @* ── Tab Sports ── *@
    <div class="tab-pane fade @(!sportsActifs.Any() ? "show active" : "")" id="pane-Sports" role="tabpanel">
        <div class="row g-4">
            <div class="col-md-8">
                <div class="card h-100">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-trophy me-2"></i>Sports disponibles
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            La <strong>clé</strong> est utilisée en interne (ex: <code>FootballAmericain</code>).
                            Le <strong>libellé</strong> est affiché dans les onglets.
                            Désactiver un sport le masque partout dans l'application sans supprimer ses données.
                        </p>
                        @if (!sportsDico.Any())
                        {
                            <p class="text-muted small">Aucun sport personnalisé — sports par défaut actifs.</p>
                        }
                        else
                        {
                            <table class="table table-sm align-middle mb-3">
                                <thead class="table-light">
                                    <tr>
                                        <th>Libellé</th>
                                        <th>Clé interne</th>
                                        <th class="text-center">Actif</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var entree in sportsDico)
                                {
                                    <tr>
                                        <td class="fw-semibold">@(string.IsNullOrEmpty(entree.Label) ? entree.Valeur : entree.Label)</td>
                                        <td><code class="text-muted small">@entree.Valeur</code></td>
                                        <td class="text-center">
                                            <form asp-controller="Dictionnaire" asp-action="ToggleActif" asp-route-id="@entree.Id"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm @(entree.Actif ? "btn-success" : "btn-outline-secondary")"
                                                        title="@(entree.Actif ? "Désactiver" : "Activer")">
                                                    <i class="bi @(entree.Actif ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                                    @(entree.Actif ? "Actif" : "Inactif")
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex gap-1 justify-content-end">
                                                <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-2"
                                                        onclick="ouvrirModifier(@entree.Id)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <form asp-controller="Dictionnaire" asp-action="Supprimer" asp-route-id="@entree.Id"
                                                      method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-2"
                                                            onclick="return confirm('Supprimer « @entree.Valeur » ? Les données liées resteront.')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        }
                        <form asp-controller="Dictionnaire" asp-action="Ajouter" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="categorie" value="Sport" />
                            <input type="hidden" name="sport" value="" />
                            <div class="row g-2 align-items-end">
                                <div class="col-4">
                                    <label class="form-label small fw-semibold mb-1">Clé interne</label>
                                    <input type="text" name="valeur" class="form-control form-control-sm"
                                           placeholder="Ex: Basketball" required
                                           pattern="[A-Za-z]+" title="Lettres seulement, sans espaces" />
                                    <div class="form-text">Sans espaces</div>
                                </div>
                                <div class="col-5">
                                    <label class="form-label small fw-semibold mb-1">Libellé affiché</label>
                                    <input type="text" name="label" class="form-control form-control-sm"
                                           placeholder="Ex: Basketball" />
                                    <div class="form-text">Dans les onglets</div>
                                </div>
                                <div class="col-3 pb-4">
                                    <button type="submit" class="btn btn-primary btn-sm w-100">Ajouter</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Modal Modifier ── *@
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2 text-primary"></i>Modifier une entrée</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editForm" asp-controller="Dictionnaire" asp-action="Modifier" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="editId" name="id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Valeur</label>
                        <input type="text" id="editValeur" name="valeur" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Libellé</label>
                        <input type="text" id="editLabel" name="label" class="form-control" />
                    </div>
                    <div class="mb-3" id="editAcronyme-group" style="display:none;">
                        <label class="form-label fw-semibold">Acronyme</label>
                        <input type="text" id="editAcronyme" name="acronyme" class="form-control" />
                    </div>
                    <div class="mb-3" id="editDescription-group" style="display:none;">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea id="editDescription" name="description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3" id="editParent-group" style="display:none;">
                        <label class="form-label fw-semibold">Position parente</label>
                        <input type="text" id="editParentValeur" name="parentValeur" class="form-control" />
                        <div class="form-text">Laissez vide si cette position spécifique n'est pas liée à une position.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function ouvrirModifier(id) {
    fetch('/Dictionnaire/Modifier?id=' + id)
        .then(r => r.json())
        .then(data => {
            document.getElementById('editId').value = data.id;
            document.getElementById('editValeur').value = data.valeur;
            document.getElementById('editLabel').value = data.label || '';
            document.getElementById('editAcronyme').value = data.acronyme || '';
            document.getElementById('editDescription').value = data.description || '';
            document.getElementById('editParentValeur').value = data.parentValeur || '';

            var isSpec = data.categorie === 'PositionSpecifique';
            document.getElementById('editAcronyme-group').style.display  = isSpec ? '' : 'none';
            document.getElementById('editDescription-group').style.display = isSpec ? '' : 'none';
            document.getElementById('editParent-group').style.display    = isSpec ? '' : 'none';

            new bootstrap.Modal(document.getElementById('editModal')).show();
        });
}
</script>
}
