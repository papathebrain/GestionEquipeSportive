<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @ViewBag.NomEcole</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --couleur-primaire: @(ViewBag.CouleurPrimaire ?? "#1a3a5c");
            --couleur-secondaire: @(ViewBag.CouleurSecondaire ?? "#e8a020");
        }
        body {
            background-color: #f8f9fa;
        }
        .public-header {
            background-color: var(--couleur-primaire);
            color: #fff;
            padding: 1rem 0;
        }
        .public-header .school-logo {
            width: 64px;
            height: 64px;
            object-fit: contain;
            border-radius: 8px;
            background: rgba(255,255,255,.15);
            padding: 4px;
        }
        .public-header .school-logo-placeholder {
            width: 64px;
            height: 64px;
            border-radius: 8px;
            background: rgba(255,255,255,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: rgba(255,255,255,.8);
        }
        .public-footer {
            background-color: var(--couleur-primaire);
            color: rgba(255,255,255,.7);
            padding: .75rem 0;
            font-size: .875rem;
            margin-top: 3rem;
        }
        .section-title {
            border-left: 4px solid var(--couleur-secondaire);
            padding-left: .75rem;
            margin-bottom: 1.25rem;
        }
        .header-social-link {
            color: rgba(255,255,255,.75);
            text-decoration: none;
            font-size: 1.15rem;
            transition: color .15s;
        }
        .header-social-link:hover { color: #fff; }
        .switcher-btn {
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            color: #fff;
            border-radius: 6px;
            padding: .3rem .75rem;
            font-size: .875rem;
            cursor: pointer;
            white-space: nowrap;
        }
        .switcher-btn:hover { background: rgba(255,255,255,.22); }
        .switcher-dropdown .dropdown-menu {
            min-width: 220px;
        }
    </style>
</head>
<body>
    <header class="public-header">
        <div class="container">
            <div class="d-flex align-items-center gap-3">
                @if (!string.IsNullOrEmpty(ViewBag.LogoPath as string))
                {
                    <img src="@ViewBag.LogoPath" alt="Logo" class="school-logo" />
                }
                else
                {
                    <div class="school-logo-placeholder"><i class="bi bi-shield-fill"></i></div>
                }
                <div class="flex-grow-1">
                    <div class="fw-bold fs-5">@ViewBag.NomEcole</div>
                    <div class="small opacity-75">@ViewData["Title"]</div>
                </div>
                @await RenderSectionAsync("HeaderRight", required: false)
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="public-footer">
        <div class="container text-center">
            <i class="bi bi-trophy me-1"></i>
            @ViewBag.NomEcole &copy; @DateTime.Now.Year
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
